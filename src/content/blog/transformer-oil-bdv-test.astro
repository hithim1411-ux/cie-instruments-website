      <rect x="80" y="40" width="340" height="120" rx="10" fill="#EFF6FF" stroke="#1B3A5B" stroke-width="2"/>
      <!-- Oil fill -->
      <rect x="82" y="100" width="336" height="58" rx="0" fill="#FEF9C3" opacity="0.7"/>
      <text x="250" y="145" text-anchor="middle" font-size="11" fill="#92400E" font-family="sans-serif">Transformer oil sample</text>
      <!-- Left electrode -->
      <ellipse cx="165" cy="80" rx="25" ry="18" fill="#475569" stroke="#0D1B2A" stroke-width="1.5"/>
      <rect x="120" y="40" width="20" height="45" fill="#475569" rx="2"/>
      <text x="155" y="35" text-anchor="middle" font-size="10" fill="#475569" font-family="sans-serif">HV</text>
      <!-- Right electrode -->
      <ellipse cx="335" cy="80" rx="25" ry="18" fill="#475569" stroke="#0D1B2A" stroke-width="1.5"/>
      <rect x="360" y="40" width="20" height="45" fill="#475569" rx="2"/>
      <text x="350" y="35" text-anchor="middle" font-size="10" fill="#475569" font-family="sans-serif">GND</text>
      <!-- Gap marker -->
      <line x1="190" y1="80" x2="310" y2="80" stroke="#E0252E" stroke-width="1.5" stroke-dasharray="4,3"/>
      <polygon points="193,80 200,74 200,86" fill="#E0252E"/>
      <polygon points="307,80 300,74 300,86" fill="#E0252E"/>
      <text x="250" y="72" text-anchor="middle" font-size="11" font-weight="700" fill="#E0252E" font-family="sans-serif">2.5 mm gap</text>
      <!-- HV supply -->
      <rect x="10" y="55" width="70" height="50" rx="6" fill="#0D1B2A" stroke="#E0252E" stroke-width="1.5"/>
      <text x="45" y="78" text-anchor="middle" font-size="9" fill="white" font-family="sans-serif">BDV TESTER</text>
