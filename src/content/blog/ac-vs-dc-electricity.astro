        <th class="text-center px-4 py-4 text-blue-300 font-bold">DC Measurement</th>
      </tr>
    </thead>
    <tbody>
      {[
        ['Voltage display','RMS value (230 V on Indian mains)','Actual voltage (12.6 V battery)'],
        ['Internal method','True-RMS or average-responding rectifier','Direct ADC measurement'],
        ['Zero crossing','Handled internally — not visible','No zero crossing exists'],
        ['Polarity shown','No — AC has no fixed polarity','Yes — + or − sign displayed'],
        ['Frequency measurement','Yes — dedicated Hz function','Not applicable'],
