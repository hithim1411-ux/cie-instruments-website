---
import { u } from '../utils/url';
import cieProducts    from '../data/products.json';
import cieCategories  from '../data/categories.json';
import vMM   from '../data/vartech-multimeters.json';
import vCM   from '../data/vartech-clamp-meters.json';
import vOSC  from '../data/vartech-oscilloscopes.json';
import vFG   from '../data/vartech-function-generators.json';
import vLCR  from '../data/vartech-lcr-meters.json';
import vDCL  from '../data/vartech-dc-loads.json';
import vSLM  from '../data/vartech-sound-level-meters.json';
import vANE  from '../data/vartech-anemometers.json';
import vCAL  from '../data/vartech-calibrators.json';
import vLUX  from '../data/vartech-lux-meters.json';
import vTHM  from '../data/vartech-thermometers.json';
import vPS   from '../data/vartech-dc-power-supplies.json';

const catNameMap: Record<string,string> = Object.fromEntries(
  (cieCategories as any[]).map(c => [c.id, c.shortName || c.name])
);

type Entry = {
  id: string; model: string; name: string; tagline: string;
  category: string; brand: 'cie'|'vartech'; href: string; image: string;
};

function vImg(slug: string, img: string) { return u(`/images/vartech/${slug}/${img}`); }

const vartechSections: { slug: string; label: string; items: any[] }[] = [
  { slug: 'multimeters',        label: 'Multimeters',          items: vMM  },
  { slug: 'clamp-meters',       label: 'Clamp Meters',         items: vCM  },
  { slug: 'oscilloscopes',      label: 'Oscilloscopes',        items: vOSC },
  { slug: 'function-generators',label: 'Function Generators',  items: vFG  },
  { slug: 'lcr-meters',         label: 'LCR & Cap Meters',     items: vLCR },
  { slug: 'dc-loads',           label: 'DC Electronic Loads',  items: vDCL },
  { slug: 'sound-level-meters', label: 'Sound Level Meters',   items: vSLM },
  { slug: 'anemometers',        label: 'Anemometers',          items: vANE },
  { slug: 'calibrators',        label: 'Calibrators',          items: vCAL },
  { slug: 'lux-meters',         label: 'Lux Meters',           items: vLUX },
  { slug: 'thermometers',       label: 'Thermometers',         items: vTHM },
  { slug: 'dc-power-supplies',  label: 'DC Power Supplies',    items: vPS  },
];

const searchIndex: Entry[] = [
  ...(cieProducts as any[]).filter(p => !p.brand || p.brand === 'cie').map(p => ({
    id: p.id, model: p.model, name: p.name, tagline: p.tagline || '',
    category: catNameMap[p.categoryId] || p.categoryId,
    brand: 'cie' as const,
    href: u(`/products/${p.categoryId}/${p.id}/`),
    image: p.image
      ? (p.image.startsWith('vartech/') ? u(`/images/${p.image}`) : u(`/images/products/${p.image}`))
      : u(`/images/products/${p.id}.webp`),
  })),
  ...vartechSections.flatMap(({ slug, label, items }) =>
    (items as any[]).map(p => ({
      id: p.id, model: p.model, name: p.name, tagline: p.tagline || '',
      category: label, brand: 'vartech' as const,
      href: u(`/authorised-dealership/${slug}/${p.id}/`),
      image: p.images?.[0] ? vImg(slug, p.images[0]) : '',
    }))
  ),
];

const suggestions = [
  "What do I need to measure motor insulation?",
  "Compare LCR-1B vs LCR-2A",
  "Best clamp meter for solar systems",
  "Earth tester for site work",
];
---

<dialog
  id="cie-search"
  aria-label="Search"
  class="fixed inset-0 z-[9999] w-full h-full bg-transparent p-0 m-0 max-w-none max-h-none border-0 backdrop:bg-[#0D1B2A]/80 backdrop:backdrop-blur-sm"
>
  <!-- Desktop: centred overlay. Mobile: full-screen panel -->
  <div id="search-outer" class="hidden sm:flex items-start justify-center min-h-full pt-[8vh] px-4 pb-10">
    <div id="search-box-desktop" class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col" style="max-height:84vh;">

      <!-- Desktop header -->
      <div class="flex items-center gap-3 px-4 py-3.5 border-b border-[#E8ECF2] shrink-0">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#1B3A5B] to-[#E0252E] flex items-center justify-center shrink-0">
          <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l1.5 4.5L14 7l-4.5 1.5L8 13l-1.5-4.5L2 7l4.5-1.5z"/></svg>
        </div>
        <input id="search-input" type="text" autocomplete="off" spellcheck="false"
          placeholder="Search products or ask anything…"
          class="flex-1 text-[#0D1B2A] text-[15px] bg-transparent outline-none placeholder:text-[#94A3B8] font-medium min-w-0"
          inputmode="search" enterkeyhint="search" />
        <button id="new-search-btn" class="hidden items-center gap-1 text-[11px] font-medium text-[#1B3A5B] bg-[#EEF2FF] hover:bg-[#E0E9FF] px-2.5 py-1.5 rounded-lg transition-colors shrink-0 whitespace-nowrap">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg> New
        </button>
        <button id="search-close-btn" class="flex items-center gap-1.5 text-[11px] font-medium text-[#64748B] hover:text-[#0D1B2A] hover:bg-[#F1F5F9] px-2.5 py-1.5 rounded-lg transition-colors shrink-0">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Desktop: single scrollable body containing AI answer + catalog -->
      <div class="flex-1 overflow-y-auto min-h-0" style="scrollbar-width:thin;">
        <div id="ai-panel" class="hidden border-b border-[#E8ECF2]">
          <div class="px-4 py-3">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded-md bg-gradient-to-br from-[#1B3A5B] to-[#E0252E] flex items-center justify-center shrink-0">
                <svg class="w-2.5 h-2.5 text-white" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l1.5 4.5L14 7l-4.5 1.5L8 13l-1.5-4.5L2 7l4.5-1.5z"/></svg>
              </div>
              <span class="text-[10px] font-mono uppercase tracking-widest text-[#1B3A5B] font-bold">AI Answer</span>
              <button id="ai-close" class="ml-auto text-[#94A3B8] hover:text-[#64748B]">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
            <div id="ai-content" class="text-sm text-[#0D1B2A] leading-relaxed ai-content"></div>
            <!-- Reply box -->
            <div id="ai-reply-box" class="hidden mt-3 flex items-center gap-2 bg-white border border-[#1B3A5B]/30 rounded-xl px-3 py-2.5 shadow-sm">
              <input id="ai-reply-input" type="text" placeholder="Type your answer here…"
                class="flex-1 text-sm text-[#0D1B2A] bg-transparent outline-none placeholder:text-[#94A3B8]"
                inputmode="search" enterkeyhint="send" />
              <button id="ai-reply-send" class="w-7 h-7 rounded-lg bg-[#1B3A5B] text-white flex items-center justify-center shrink-0 hover:bg-[#0D2547] transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </div>
          </div>
        </div>
        <div id="catalog-results">
          <div class="px-4 py-4">
            <p class="text-xs text-[#94A3B8] mb-3">Try asking a question or search by product name, model, or spec.</p>
            <div class="grid grid-cols-2 gap-2">
              {suggestions.map(s => (
                <button class="suggestion-chip text-left text-xs px-3 py-2.5 rounded-xl border border-[#E2E8F0] text-[#475569] hover:border-[#1B3A5B] hover:text-[#1B3A5B] hover:bg-[#F0F4FF] transition-all" data-query={s}>{s}</button>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop footer -->
      <div class="px-4 py-2 border-t border-[#E8ECF2] bg-[#F8FAFC] flex items-center justify-between shrink-0">
        <span class="text-[10px] text-[#94A3B8] font-mono">Powered by Groq · {searchIndex.length} instruments</span>
        <div class="flex items-center gap-3 text-[10px] text-[#94A3B8] font-mono">
          <span><kbd class="px-1 py-0.5 bg-white border border-[#E2E8F0] rounded text-[9px]">↵</kbd> ask AI</span>
          <span><kbd class="px-1 py-0.5 bg-white border border-[#E2E8F0] rounded text-[9px]">esc</kbd> close</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       MOBILE FULL-SCREEN PANEL (shown on sm and below)
  ════════════════════════════════════════════════════════ -->
  <div id="mobile-panel" class="sm:hidden fixed inset-0 bg-white flex flex-col" style="display:none;">

    <!-- Mobile header -->
    <div class="flex items-center gap-3 px-4 border-b border-[#E8ECF2] shrink-0" style="height:56px;">
      <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-[#1B3A5B] to-[#E0252E] flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-white" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l1.5 4.5L14 7l-4.5 1.5L8 13l-1.5-4.5L2 7l4.5-1.5z"/></svg>
      </div>
      <input id="search-input-mobile" type="text" autocomplete="off" spellcheck="false"
        placeholder="Search or ask anything…"
        class="flex-1 text-[#0D1B2A] text-[16px] bg-transparent outline-none placeholder:text-[#94A3B8] font-medium min-w-0"
        inputmode="search" enterkeyhint="search" />
      <button id="mobile-clear-btn" class="hidden w-8 h-8 rounded-full bg-[#F1F5F9] items-center justify-center text-[#64748B] active:bg-[#E2E8F0] shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Mobile AI answer — collapsible -->
    <div id="mobile-ai-panel" class="hidden border-b border-[#E8ECF2] shrink-0" style="max-height:40vh; overflow-y:auto; -webkit-overflow-scrolling:touch;">
      <button id="mobile-ai-toggle" class="w-full flex items-center gap-2 px-4 py-2.5 bg-[#F0F4FF] active:bg-[#E8EFFE]">
        <div class="w-4 h-4 rounded bg-gradient-to-br from-[#1B3A5B] to-[#E0252E] flex items-center justify-center shrink-0">
          <svg class="w-2 h-2 text-white" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l1.5 4.5L14 7l-4.5 1.5L8 13l-1.5-4.5L2 7l4.5-1.5z"/></svg>
        </div>
        <span class="text-[11px] font-bold text-[#1B3A5B] uppercase tracking-wider">AI Answer</span>
        <svg id="mobile-ai-chevron" class="w-4 h-4 text-[#94A3B8] ml-auto transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="mobile-ai-content" class="px-4 pt-1 pb-2 text-sm text-[#0D1B2A] leading-relaxed ai-content"></div>
      <!-- Mobile reply box -->
      <div id="mobile-ai-reply-box" class="hidden mx-4 mb-3 flex items-center gap-2 bg-white border border-[#1B3A5B]/30 rounded-xl px-3 py-2.5 shadow-sm">
        <input id="mobile-ai-reply-input" type="text" placeholder="Type your answer here…"
          class="flex-1 text-[15px] text-[#0D1B2A] bg-transparent outline-none placeholder:text-[#94A3B8]"
          inputmode="search" enterkeyhint="send" />
        <button id="mobile-ai-reply-send" class="w-8 h-8 rounded-xl bg-[#1B3A5B] text-white flex items-center justify-center shrink-0 active:bg-[#0D2547]">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile results — fills all remaining space, scrolls -->
    <div id="mobile-catalog-results" class="flex-1 overflow-y-auto min-h-0" style="-webkit-overflow-scrolling:touch; overscroll-behavior:contain;">
      <!-- welcome -->
      <div id="mobile-welcome" class="px-4 pt-5 pb-4">
        <p class="text-sm text-[#94A3B8] mb-4">Try a question or search by name, model, or spec.</p>
        <div class="flex flex-col gap-3">
          {suggestions.map(s => (
            <button class="suggestion-chip text-left text-[15px] px-4 py-4 rounded-2xl border border-[#E2E8F0] text-[#334155] active:bg-[#EEF2FF] active:border-[#1B3A5B]" data-query={s}>{s}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- Mobile bottom bar (always visible) -->
    <div class="flex items-center gap-3 px-4 border-t border-[#E8ECF2] bg-[#F8FAFC] shrink-0" style="height:60px; padding-bottom:env(safe-area-inset-bottom);">
      <span class="text-[10px] text-[#94A3B8] font-mono flex-1">Groq AI · {searchIndex.length} instruments</span>
      <button id="mobile-new-btn" class="text-sm font-semibold text-[#1B3A5B] bg-[#EEF2FF] px-4 py-2 rounded-xl active:bg-[#E0E9FF]">+ New</button>
      <button id="mobile-close-btn" class="text-sm font-semibold text-white bg-[#1B3A5B] px-4 py-2 rounded-xl active:bg-[#0D2547]">Close</button>
    </div>
  </div>

</dialog>

<script define:vars={{ searchIndex }}>
  window.__CIE_SEARCH_INDEX__ = searchIndex;
</script>

<script>
import Fuse from 'fuse.js';

type Entry = { id: string; model: string; name: string; tagline: string; category: string; brand: string; href: string; image: string; };
const index: Entry[] = (window as any).__CIE_SEARCH_INDEX__ || [];

// ── Fuse instances ────────────────────────────────────────────────────────
const fuse = new Fuse(index, {
  keys: [{ name: 'model', weight: 3 }, { name: 'name', weight: 2 }, { name: 'tagline', weight: 1 }, { name: 'category', weight: 0.5 }],
  threshold: 0.35, includeScore: true, minMatchCharLength: 2, ignoreLocation: true,
});
const fuseStrict = new Fuse(index, {
  keys: [{ name: 'model', weight: 3 }, { name: 'name', weight: 2 }, { name: 'tagline', weight: 1 }, { name: 'category', weight: 0.5 }],
  threshold: 0.15, includeScore: true, minMatchCharLength: 2, ignoreLocation: true,
});

// ── DOM refs ──────────────────────────────────────────────────────────────
const modal        = document.getElementById('cie-search')       as HTMLDialogElement;
// Desktop
const desktopOuter = document.getElementById('search-outer')     as HTMLElement;
const desktopInput = document.getElementById('search-input')     as HTMLInputElement;
const desktopNewBtn= document.getElementById('new-search-btn')   as HTMLButtonElement;
const desktopClose = document.getElementById('search-close-btn') as HTMLButtonElement;
const aiPanel      = document.getElementById('ai-panel')         as HTMLElement;
const aiContent      = document.getElementById('ai-content')         as HTMLElement;
const aiClose        = document.getElementById('ai-close')           as HTMLButtonElement;
const aiReplyBox     = document.getElementById('ai-reply-box')       as HTMLElement;
const aiReplyInput   = document.getElementById('ai-reply-input')     as HTMLInputElement;
const aiReplySend    = document.getElementById('ai-reply-send')      as HTMLButtonElement;
const mobReplyBox    = document.getElementById('mobile-ai-reply-box')    as HTMLElement;
const mobReplyInput  = document.getElementById('mobile-ai-reply-input')  as HTMLInputElement;
const mobReplySend   = document.getElementById('mobile-ai-reply-send')   as HTMLButtonElement;
const catalogDiv   = document.getElementById('catalog-results')  as HTMLElement;
// Mobile
const mobilePanel  = document.getElementById('mobile-panel')     as HTMLElement;
const mobileInput  = document.getElementById('search-input-mobile') as HTMLInputElement;
const mobileClearBtn= document.getElementById('mobile-clear-btn') as HTMLButtonElement;
const mobileAIPanel= document.getElementById('mobile-ai-panel') as HTMLElement;
const mobileAIToggle= document.getElementById('mobile-ai-toggle') as HTMLButtonElement;
const mobileAIChev = document.getElementById('mobile-ai-chevron') as HTMLElement;
const mobileAICont = document.getElementById('mobile-ai-content') as HTMLElement;
const mobileCatalog= document.getElementById('mobile-catalog-results') as HTMLElement;
const mobileNewBtn = document.getElementById('mobile-new-btn')   as HTMLButtonElement;
const mobileCloseBtn= document.getElementById('mobile-close-btn') as HTMLButtonElement;

// ── State ─────────────────────────────────────────────────────────────────
let isStreaming = false;
let history: { role: string; parts: string }[] = [];
let fuseDebounce: ReturnType<typeof setTimeout>;
let lastAICall = 0;
let mobileAIExpanded = true;

const isMobile = () => window.innerWidth < 640;

// ── Helpers: which panel is active ────────────────────────────────────────
function activeInput()   { return isMobile() ? mobileInput   : desktopInput; }
function activeCatalog() { return isMobile() ? mobileCatalog : catalogDiv; }
function activeAIPanel() { return isMobile() ? mobileAIPanel : aiPanel; }
function activeAICont()  { return isMobile() ? mobileAICont  : aiContent; }

// ── Open / close ──────────────────────────────────────────────────────────
function openSearch() {
  modal.showModal();
  document.body.style.overflow = 'hidden';
  if (isMobile()) {
    mobilePanel.style.display = 'flex';
    desktopOuter.style.display = 'none';
    adjustMobileHeight();
  } else {
    mobilePanel.style.display = 'none';
    desktopOuter.style.display = 'flex';
  }
  newSearch(false);
  setTimeout(() => activeInput().focus(), 100);
}

function closeSearch() {
  modal.close();
  document.body.style.overflow = '';
  mobilePanel.style.display = 'none';
  desktopOuter.style.display = 'none';
  mobileInput.value = '';
  desktopInput.value = '';
}

function newSearch(focusInput = true) {
  mobileInput.value = '';
  desktopInput.value = '';
  mobileClearBtn.classList.add('hidden');
  desktopNewBtn.classList.add('hidden');
  history = [];
  hideAI();
  showWelcome();
  if (focusInput) setTimeout(() => activeInput().focus(), 50);
}

// ── Mobile keyboard-aware height ──────────────────────────────────────────
function adjustMobileHeight() {
  if (!isMobile()) return;
  const h = window.visualViewport ? window.visualViewport.height : window.innerHeight;
  mobilePanel.style.height = h + 'px';
}
window.visualViewport?.addEventListener('resize', adjustMobileHeight);
window.addEventListener('resize', adjustMobileHeight);

// ── Backdrop click ────────────────────────────────────────────────────────
// Click anywhere outside the box closes search
modal.addEventListener('click', e => {
  const box = document.getElementById('search-box-desktop');
  const mob = document.getElementById('mobile-panel');
  if (!box?.contains(e.target as Node) && !mob?.contains(e.target as Node)) closeSearch();
});

// ── Button wiring ─────────────────────────────────────────────────────────
desktopClose?.addEventListener('click', closeSearch);
desktopNewBtn?.addEventListener('click', newSearch);
aiClose?.addEventListener('click', hideAI);
mobileCloseBtn?.addEventListener('click', closeSearch);
mobileNewBtn?.addEventListener('click', () => newSearch());
mobileClearBtn?.addEventListener('click', () => {
  mobileInput.value = '';
  mobileClearBtn.classList.add('hidden');
  hideAI();
  showWelcome();
  mobileInput.focus();
});

// Mobile AI panel collapse/expand
mobileAIToggle?.addEventListener('click', () => {
  mobileAIExpanded = !mobileAIExpanded;
  mobileAICont.style.display = mobileAIExpanded ? 'block' : 'none';
  mobileAIChev.style.transform = mobileAIExpanded ? 'rotate(0deg)' : 'rotate(-90deg)';
});

// ── Keyboard shortcuts ────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  const mac = navigator.platform.toUpperCase().includes('MAC');
  if ((mac ? e.metaKey : e.ctrlKey) && e.key === 'k') { e.preventDefault(); modal.open ? closeSearch() : openSearch(); }
  if (e.key === 'Escape' && modal.open) closeSearch();
});

// ── Input listeners ───────────────────────────────────────────────────────
function onInputChange(q: string) {
  mobileClearBtn.classList.toggle('hidden', !q.trim());
  desktopNewBtn.classList.toggle('hidden', !q.trim());
  desktopNewBtn.classList.toggle('flex', !!q.trim());
  clearTimeout(fuseDebounce);
  fuseDebounce = setTimeout(() => {
    if (!q.trim()) { showWelcome(); return; }
    renderCatalog(q.trim());
  }, 150);
}

mobileInput.addEventListener('input', () => onInputChange(mobileInput.value));
desktopInput.addEventListener('input', () => onInputChange(desktopInput.value));

function onEnter(q: string) {
  if (!q.trim() || isStreaming) return;
  renderCatalog(q.trim());
  askAI(q.trim());
}
mobileInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); onEnter(mobileInput.value); } });
desktopInput.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); onEnter(desktopInput.value); } });

// ── Suggestion chips ──────────────────────────────────────────────────────
document.addEventListener('click', e => {
  const chip = (e.target as HTMLElement).closest('.suggestion-chip') as HTMLElement | null;
  if (!chip) return;
  const q = chip.dataset.query || '';
  mobileInput.value = q;
  desktopInput.value = q;
  mobileClearBtn.classList.remove('hidden');
  desktopNewBtn.classList.remove('hidden');
  desktopNewBtn.classList.add('flex');
  history = [];
  renderCatalog(q);
  askAI(q);
});

// ── Synonym + keyword extraction ──────────────────────────────────────────
const SYNONYMS: [RegExp, string][] = [
  [/\b(light intensity|illuminance|brightness|luminance|lux level)\b/gi,       'lux'],
  [/\b(air speed|wind speed|airflow|air flow)\b/gi,                             'anemometer'],
  [/\b(noise|decibel|sound pressure|dba)\b/gi,                                  'sound'],
  [/\b(megger|megohm|insulation resistance)\b/gi,                               'insulation'],
  [/\b(grounding|earthing|earth electrode)\b/gi,                                'earth'],
  [/\b(winding resistance|contact resistance|micro.?ohm)\b/gi,                  'micro-ohm'],
  [/\b(solar|pv|photovoltaic)\b/gi,                                             'clamp'],
  [/\b(oscilloscope|waveform|signal capture)\b/gi,                              'oscilloscope'],
  [/\b(signal generator|waveform generator)\b/gi,                               'function generator'],
  [/\b(temperature|thermal|thermocouple)\b/gi,                                  'thermometer'],
  [/\b(voltage fluctuations?|voltage variations?|power fluctuations?|voltage dips?|voltage surges?|mains voltage|supply voltage|power quality)\b/gi, 'multimeter'],
  [/\b(continuity|short circuit|open circuit|fuse|wire break)\b/gi,             'multimeter'],
  [/\b(ev battery|electric vehicle battery|lithium battery|battery test|battery capacity)\b/gi, 'load clamp'],
  [/\b(battery|charge|discharge)\b/gi,                                          'clamp'],
  [/\b(rpm|rotation|speed|vibration)\b/gi,                                      'multimeter'],
  [/\b(humidity|moisture|dew point)\b/gi,                                       'thermometer'],
  [/\b(load bank|dummy load|burn.?in)\b/gi,                                     'load'],
];
const STOP = new Set(['what','do','i','need','to','for','the','a','an','best','good','which','is','are','can','how','me','my','us','we','should','use','get','buy','find','vs','versus','between','and','or','in','on','with','about','please','help','recommend','some','any','measure','measurement','measuring','using','used','suitable','type','types','kind','kinds','want','wish','looking','test','testing','instrument','instruments','device','devices','equipment','tool','tools','product','products','check','checking','high','low','level','range','accuracy','digital','analog','portable','bench','handheld','factory','site','field','lab','industrial','read','reading','current','voltage','resistance','frequency','power','signal','output','input','circuit','electrical','electronic','meter','meters','tester','testers','detector','detectors','recorder','recorders','controller','monitor','dc','ac','rms','true','phase','single','three','dual','channel','house','home','office','plant','site','building','room','residential','commercial','industrial','fluctuation','variation','fluctuations','variations',
    'at','by','of','up','per','as','so','no','if','be','it','am','ok','but','not','more','most','very','just','also','only','even','both','about','detail','details','detailed','simple','quick','fast','slow','basic','complete','full','all','new','old','first','second','third','small','large','big','little','great','better','worse','same','different','other','another','each','every','many','much','few','less','more','such','such','own','right','left','next','last','long','short','far','near']);

function extractKeywords(q: string): string {
  let expanded = q;
  for (const [p, r] of SYNONYMS) expanded = expanded.replace(p, r);
  const words = expanded.toLowerCase().replace(/[?!.,]/g,'').split(/\s+/).filter(w => w.length > 1 && !STOP.has(w));
  return words.length ? words.join(' ') : q;
}

// ── AI ────────────────────────────────────────────────────────────────────
async function askAI(q: string) {
  if (isStreaming) return;
  const now = Date.now();
  if (now - lastAICall < 2000) return;
  lastAICall = now;
  isStreaming = true;

  const panel = activeAIPanel();
  const cont  = activeAICont();
  panel.classList.remove('hidden');
  panel.style.display = 'block';
  mobileAIExpanded = true;
  if (mobileAICont) { mobileAICont.style.display = 'block'; }
  if (mobileAIChev) mobileAIChev.style.transform = 'rotate(0deg)';
  desktopNewBtn.classList.remove('hidden');
  desktopNewBtn.classList.add('flex');

  cont.innerHTML = `<span class="inline-flex gap-1.5 items-center py-1">
    <span class="w-2 h-2 bg-[#1B3A5B] rounded-full animate-bounce" style="animation-delay:0ms"></span>
    <span class="w-2 h-2 bg-[#1B3A5B] rounded-full animate-bounce" style="animation-delay:150ms"></span>
    <span class="w-2 h-2 bg-[#1B3A5B] rounded-full animate-bounce" style="animation-delay:300ms"></span>
  </span>`;

  let fullText = '';
  try {
    const res = await fetch('/api/search', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: q, history }),
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({ error: 'Unknown error' }));
      renderMD(cont, `_${err.error || 'AI temporarily unavailable.'}_`);
    } else {
      const reader = res.body!.getReader();
      const decoder = new TextDecoder();
      cont.innerHTML = '';
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        fullText += decoder.decode(value, { stream: true });
        renderMD(cont, fullText);
      }
      history.push({ role: 'user', parts: q });
      history.push({ role: 'model', parts: fullText });
      if (history.length > 12) history = history.slice(-12);
    }
  } catch {
    renderMD(cont, '_Connection error — please try again._');
  }
  isStreaming = false;

  // Show reply box if AI asked a question
  const askedQuestion = fullText.includes('❓') || fullText.includes('Quick question');
  showReplyBox(askedQuestion);

  // After AI responds, extract model numbers it mentioned and show those products
  // This handles follow-up answers like "TV", "LV motor" that don't map to catalog keywords
  if (fullText && !askedQuestion) {
    const modelMatches = fullText.match(/\*\*([A-Z0-9][A-Z0-9\s\/\-\.+]+?)\*\*/g);
    if (modelMatches) {
      const models = modelMatches.map(m => m.replace(/\*\*/g, '').trim().toLowerCase());
      const aiMentionedProducts = index.filter(item =>
        models.some(m => item.model.toLowerCase().includes(m) || m.includes(item.model.toLowerCase()))
      );
      if (aiMentionedProducts.length) {
        // Show the categories of AI-mentioned products
        const cats = new Set(aiMentionedProducts.map(p => p.category));
        const catProducts = index.filter(p => cats.has(p.category));
        const cie = catProducts.filter(p => p.brand === 'cie');
        const vt  = catProducts.filter(p => p.brand === 'vartech');
        let html = '';
        if (cie.length) html += section('CIE — Manufactured', 'text-[#E0252E]', cie, q, false);
        if (vt.length)  html += section('Vartech — Authorised Dealer', 'text-emerald-600', vt, q, !!cie.length);
        if (html) { catalogDiv.innerHTML = html; mobileCatalog.innerHTML = html; }
      }
    }
  }
}

function showReplyBox(show: boolean) {
  if (show) {
    aiReplyBox?.classList.remove('hidden');
    aiReplyBox?.classList.add('flex');
    mobReplyBox?.classList.remove('hidden');
    mobReplyBox?.classList.add('flex');
    setTimeout(() => (isMobile() ? mobReplyInput : aiReplyInput)?.focus(), 100);
  } else {
    aiReplyBox?.classList.add('hidden');
    aiReplyBox?.classList.remove('flex');
    mobReplyBox?.classList.add('hidden');
    mobReplyBox?.classList.remove('flex');
  }
}

function sendReply(input: HTMLInputElement) {
  const val = input.value.trim();
  if (!val) return;
  // Mirror reply into main search input so history context is right
  desktopInput.value = val;
  mobileInput.value = val;
  input.value = '';
  showReplyBox(false);
  renderCatalog(val);
  askAI(val);
}

// Wire reply inputs
aiReplyInput?.addEventListener('keydown', e => { if (e.key === 'Enter') sendReply(aiReplyInput); });
aiReplySend?.addEventListener('click', () => sendReply(aiReplyInput));
mobReplyInput?.addEventListener('keydown', e => { if (e.key === 'Enter') sendReply(mobReplyInput); });
mobReplySend?.addEventListener('click', () => sendReply(mobReplyInput));

function hideAI() {
  aiPanel.classList.add('hidden');
  aiContent.innerHTML = '';
  mobileAIPanel.style.display = 'none';
  mobileAICont.innerHTML = '';
  showReplyBox(false);
}

// ── Catalog ───────────────────────────────────────────────────────────────
const CHIPS = ['What do I need to measure motor insulation?','Compare LCR-1B vs LCR-2A','Best clamp meter for solar systems','Earth tester for site work'];

function showWelcome() {
  hideAI();
  const desktopWelcome = `<div class="px-4 py-4">
    <p class="text-xs text-[#94A3B8] mb-3">Try asking a question or search by product name, model, or spec.</p>
    <div class="grid grid-cols-2 gap-2">${CHIPS.map(s => `<button class="suggestion-chip text-left text-xs px-3 py-2.5 rounded-xl border border-[#E2E8F0] text-[#475569] hover:border-[#1B3A5B] hover:text-[#1B3A5B] hover:bg-[#F0F4FF] transition-all" data-query="${esc(s)}">${esc(s)}</button>`).join('')}</div>
  </div>`;
  const mobileWelcome = `<div class="px-4 pt-5 pb-4">
    <p class="text-sm text-[#94A3B8] mb-4">Try a question or search by name, model, or spec.</p>
    <div class="flex flex-col gap-3">${CHIPS.map(s => `<button class="suggestion-chip text-left text-[15px] font-medium px-4 py-4 rounded-2xl border-2 border-[#E8ECF2] text-[#334155] active:bg-[#EEF2FF] active:border-[#1B3A5B]" data-query="${esc(s)}">${esc(s)}</button>`).join('')}</div>
  </div>`;
  catalogDiv.innerHTML = desktopWelcome;
  mobileCatalog.innerHTML = mobileWelcome;
}

function smartSearch(q: string): Entry[] {
  const keywords = extractKeywords(q);
  const words = keywords.split(/\s+/).filter(w => w.length >= 2);
  const seen = new Set<string>();
  const scored: { item: Entry; score: number }[] = [];

  for (const r of fuse.search(keywords, { limit: 60 })) {
    if (!seen.has(r.item.id)) { seen.add(r.item.id); scored.push({ item: r.item, score: r.score ?? 1 }); }
  }
  for (const word of words) {
    for (const r of fuseStrict.search(word, { limit: 20 })) {
      if (!seen.has(r.item.id)) { seen.add(r.item.id); scored.push({ item: r.item, score: r.score ?? 1 }); }
    }
  }

  const candidates = scored.map(s => s.item);

  // Literal filter: at least one keyword appears in product text
  const filtered = words.length
    ? candidates.filter(item => {
        // Only match name/model/category — not tagline (too many false positives)
        const text = `${item.name} ${item.model} ${item.category}`.toLowerCase();
        return words.some(w => new RegExp(`\\b${w}\\b`).test(text));
      })
    : candidates;

  if (filtered.length) return filtered.slice(0, 40);

  // Literal filter found nothing (likely typos/vague query).
  // Don't guess — return empty so the no-match message shows and AI answer is visible.
  return [];
}

function renderCatalog(q: string) {
  const items = smartSearch(q);
  const noMatch = `<div class="px-6 py-6 text-center">
    <svg class="w-8 h-8 mx-auto mb-2 text-[#CBD5E1]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/></svg>
    <p class="text-[#64748B] font-medium text-sm mb-1">No direct catalog match</p>
    <p class="text-xs text-[#94A3B8]">The AI answer above has the right product recommendation for you.</p>
  </div>`;
  if (!items.length) { catalogDiv.innerHTML = noMatch; mobileCatalog.innerHTML = noMatch; return; }

  const cie = items.filter(i => i.brand === 'cie');
  const vt  = items.filter(i => i.brand === 'vartech');
  let html = '';
  if (cie.length) html += section('CIE — Manufactured', 'text-[#E0252E]', cie, q, false);
  if (vt.length)  html += section('Vartech — Authorised Dealer', 'text-emerald-600', vt, q, !!cie.length);

  catalogDiv.innerHTML   = html;
  mobileCatalog.innerHTML = html;
}

function section(label: string, cls: string, items: Entry[], q: string, border: boolean) {
  return `<div class="${border?'border-t border-[#F1F5F9]':''} pt-2.5 pb-1">
    <div class="px-4 mb-1.5 flex items-center gap-2">
      <span class="text-[9px] font-mono uppercase tracking-widest ${cls} font-bold">${label}</span>
      <span class="text-[9px] text-[#94A3B8]">${items.length} result${items.length!==1?'s':''}</span>
    </div>
    ${items.map(item => resultRow(item, q)).join('')}
  </div>`;
}

function resultRow(item: Entry, q: string): string {
  const isCIE = item.brand === 'cie';
  const badge = isCIE ? 'bg-[#0D2547] text-white' : 'bg-emerald-700 text-white';
  const tag = item.tagline.length > 75 ? item.tagline.slice(0, 75) + '…' : item.tagline;
  return `<a href="${esc(item.href)}" data-result
    class="flex items-center gap-3 px-4 py-3.5 sm:py-2.5 hover:bg-[#F0F4FF] active:bg-[#EEF2FF] transition-colors group border-b border-[#F8FAFC] last:border-0"
    onclick="document.getElementById('cie-search').close(); document.body.style.overflow='';">
    <div class="w-11 h-11 sm:w-10 sm:h-10 rounded-xl bg-[#F8FAFC] border border-[#E8ECF2] flex items-center justify-center shrink-0 overflow-hidden">
      ${item.image
        ? `<img src="${esc(item.image)}" alt="" class="w-10 h-10 sm:w-9 sm:h-9 object-contain p-0.5" loading="lazy" onerror="this.style.display='none'">`
        : `<svg class="w-5 h-5 text-[#CBD5E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/></svg>`}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-0.5">
        <span class="inline-block text-[9px] font-mono font-bold px-1.5 py-0.5 rounded ${badge} shrink-0">${highlight(item.model, q)}</span>
        <span class="text-[10px] text-[#94A3B8] truncate">${esc(item.category)}</span>
      </div>
      <p class="text-sm font-semibold text-[#0D1B2A] leading-snug truncate group-hover:text-[#1B3A5B]">${highlight(item.name, q)}</p>
      ${tag ? `<p class="text-[11px] text-[#64748B] truncate mt-0.5">${highlight(tag, q)}</p>` : ''}
    </div>
    <svg class="w-4 h-4 text-[#CBD5E1] shrink-0 group-hover:text-[#1B3A5B]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </a>`;
}

// ── Markdown ──────────────────────────────────────────────────────────────
function renderMD(el: HTMLElement, text: string) {
  const blocks = text.split(/\n\n+/);
  el.innerHTML = blocks.map(block => {
    const lines = block.trim().split('\n');
    const tl = lines.filter(l => l.trim().startsWith('|'));
    if (tl.length >= 2) {
      const rows = tl.filter(l => !/^\|[\s|:-]+\|$/.test(l.trim()));
      if (rows.length >= 1) {
        const pr = (row: string) => row.trim().replace(/^\||\|$/g,'').split('|').map(c => c.trim());
        const [head, ...body] = rows;
        const th = pr(head).map(h => `<th class="px-3 py-1.5 text-left text-[11px] font-semibold text-[#1B3A5B] bg-[#EEF2FF] border border-[#E0E9FF]">${boldify(h)}</th>`).join('');
        const tb = body.map(r => `<tr class="even:bg-[#F8FAFC]">${pr(r).map(c => `<td class="px-3 py-1.5 text-[12px] text-[#334155] border border-[#E8ECF2]">${boldify(c)}</td>`).join('')}</tr>`).join('');
        return `<div class="overflow-x-auto my-2 rounded-lg border border-[#E0E9FF]"><table class="w-full text-left border-collapse"><thead><tr>${th}</tr></thead><tbody>${tb}</tbody></table></div>`;
      }
    }
    let b = esc(block)
      .replace(/^### (.+)$/gm,'<strong class="block text-[#0D2547] font-semibold text-[13px] mt-1">$1</strong>')
      .replace(/^## (.+)$/gm, '<strong class="block text-[#0D2547] font-semibold mt-1">$1</strong>')
      .replace(/\*\*(.+?)\*\*/g, '<strong class="text-[#0D2547]">$1</strong>')
      .replace(/`([^`]+)`/g, '<code class="bg-[#E8ECF2] px-1 py-0.5 rounded text-[11px] font-mono text-[#1B3A5B]">$1</code>')
      .replace(/^[-•]\s(.+)$/gm, '<li class="ml-4 list-disc list-outside leading-snug">$1</li>')
      .replace(/\n/g, '<br>');
    if (b.includes('<li')) b = b.replace(/(<li[^>]*>.*?<\/li>(<br>)?)+/gs, m => `<ul class="space-y-0.5 my-1">${m.replace(/<br>/g,'')}</ul>`);
    return `<p class="text-sm leading-relaxed">${b}</p>`;
  }).join('');
}
function boldify(t: string) { return esc(t).replace(/\*\*(.+?)\*\*/g,'<strong class="text-[#0D2547]">$1</strong>'); }
function highlight(text: string, q: string): string {
  if (!q) return esc(text);
  const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
  return esc(text).replace(re, '<mark class="bg-yellow-100 text-yellow-800 rounded-sm px-0.5">$1</mark>');
}
function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ── Expose openSearch globally (called by header button) ──────────────────
(window as any).__openCIESearch = openSearch;
