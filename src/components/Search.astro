---
import { u } from '../utils/url';
import cieProducts    from '../data/products.json';
import cieCategories  from '../data/categories.json';
import vMM   from '../data/vartech-multimeters.json';
import vCM   from '../data/vartech-clamp-meters.json';
import vOSC  from '../data/vartech-oscilloscopes.json';
import vFG   from '../data/vartech-function-generators.json';
import vLCR  from '../data/vartech-lcr-meters.json';
import vDCL  from '../data/vartech-dc-loads.json';
import vSLM  from '../data/vartech-sound-level-meters.json';
import vANE  from '../data/vartech-anemometers.json';
import vCAL  from '../data/vartech-calibrators.json';
import vLUX  from '../data/vartech-lux-meters.json';
import vTHM  from '../data/vartech-thermometers.json';
import vPS   from '../data/vartech-dc-power-supplies.json';

const catNameMap: Record<string,string> = Object.fromEntries(
  (cieCategories as any[]).map(c => [c.id, c.shortName || c.name])
);

type Entry = {
  id: string; model: string; name: string; tagline: string;
  category: string; brand: 'cie'|'vartech'; href: string; image: string;
};

function vImg(slug: string, img: string) { return u(`/images/vartech/${slug}/${img}`); }

const vartechSections: { slug: string; label: string; items: any[] }[] = [
  { slug: 'multimeters',        label: 'Multimeters',          items: vMM  },
  { slug: 'clamp-meters',       label: 'Clamp Meters',         items: vCM  },
  { slug: 'oscilloscopes',      label: 'Oscilloscopes',        items: vOSC },
  { slug: 'function-generators',label: 'Function Generators',  items: vFG  },
  { slug: 'lcr-meters',         label: 'LCR & Cap Meters',     items: vLCR },
  { slug: 'dc-loads',           label: 'DC Electronic Loads',  items: vDCL },
  { slug: 'sound-level-meters', label: 'Sound Level Meters',   items: vSLM },
  { slug: 'anemometers',        label: 'Anemometers',          items: vANE },
  { slug: 'calibrators',        label: 'Calibrators',          items: vCAL },
  { slug: 'lux-meters',         label: 'Lux Meters',           items: vLUX },
  { slug: 'thermometers',       label: 'Thermometers',         items: vTHM },
  { slug: 'dc-power-supplies',  label: 'DC Power Supplies',    items: vPS  },
];

const searchIndex: Entry[] = [
  ...(cieProducts as any[]).filter(p => !p.brand || p.brand === 'cie').map(p => ({
    id: p.id, model: p.model, name: p.name, tagline: p.tagline || '',
    category: catNameMap[p.categoryId] || p.categoryId,
    brand: 'cie' as const,
    href: u(`/products/${p.categoryId}/${p.id}/`),
    image: p.image
      ? (p.image.startsWith('vartech/') ? u(`/images/${p.image}`) : u(`/images/products/${p.image}`))
      : u(`/images/products/${p.id}.webp`),
  })),
  ...vartechSections.flatMap(({ slug, label, items }) =>
    (items as any[]).map(p => ({
      id: p.id, model: p.model, name: p.name, tagline: p.tagline || '',
      category: label, brand: 'vartech' as const,
      href: u(`/authorised-dealership/${slug}/${p.id}/`),
      image: p.images?.[0] ? vImg(slug, p.images[0]) : '',
    }))
  ),
];

const suggestions = [
  "What do I need to measure motor insulation?",
  "Compare LCR-1B vs LCR-2A",
  "Best clamp meter for solar systems",
  "Earth tester for site work",
];
---

<dialog
  id="cie-search"
  aria-label="Search"
  class="fixed inset-0 z-[9999] w-full h-full bg-transparent p-0 m-0 max-w-none max-h-none border-0 backdrop:bg-[#0D1B2A]/75 backdrop:backdrop-blur-md"
>
  <div class="flex items-start justify-center min-h-full pt-[8vh] px-4 pb-10">
    <div id="search-box" class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col" style="max-height:86vh;">

      <!-- Single input bar -->
      <div class="flex items-center gap-3 px-4 py-3.5 border-b border-[#E8ECF2] shrink-0">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#1B3A5B] to-[#E0252E] flex items-center justify-center shrink-0">
          <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 1l1.5 4.5L14 7l-4.5 1.5L8 13l-1.5-4.5L2 7l4.5-1.5z"/>
          </svg>
        </div>
        <input
          id="search-input"
          type="text"
          autocomplete="off"
          spellcheck="false"
          placeholder="Search products or ask anything…"
          class="flex-1 text-[#0D1B2A] text-[15px] bg-transparent outline-none placeholder:text-[#94A3B8] font-medium"
        />
        <!-- Enter hint -->
        <span id="enter-hint" class="hidden sm:flex items-center gap-1 text-[10px] text-[#94A3B8] font-mono shrink-0">
          <kbd class="px-1.5 py-0.5 bg-[#F1F5F9] border border-[#E2E8F0] rounded text-[9px]">↵</kbd> ask AI
        </span>
        <button id="search-clear" class="hidden w-6 h-6 rounded-full bg-[#F1F5F9] items-center justify-center text-[#64748B] hover:bg-[#E2E8F0] transition-colors shrink-0">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Scrollable body -->
      <div id="search-body" class="flex-1 overflow-y-auto" style="scrollbar-width:thin;">

        <!-- AI answer panel (hidden until triggered) -->
        <div id="ai-panel" class="hidden border-b border-[#E8ECF2]">
          <div class="px-4 py-3">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded-md bg-gradient-to-br from-[#1B3A5B] to-[#E0252E] flex items-center justify-center shrink-0">
                <svg class="w-2.5 h-2.5 text-white" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l1.5 4.5L14 7l-4.5 1.5L8 13l-1.5-4.5L2 7l4.5-1.5z"/></svg>
              </div>
              <span class="text-[10px] font-mono uppercase tracking-widest text-[#1B3A5B] font-bold">AI Answer</span>
              <button id="ai-close" class="ml-auto text-[#94A3B8] hover:text-[#64748B] transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
            <div id="ai-content" class="text-sm text-[#0D1B2A] leading-relaxed ai-content"></div>
          </div>
        </div>

        <!-- Catalog results -->
        <div id="catalog-results">
          <!-- Welcome state -->
          <div id="welcome-state" class="px-4 py-4">
            <p class="text-xs text-[#94A3B8] mb-3">Try asking a question or search by product name, model, or spec.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {suggestions.map(s => (
                <button class="suggestion-chip text-left text-xs px-3 py-2.5 rounded-xl border border-[#E2E8F0] text-[#475569] hover:border-[#1B3A5B] hover:text-[#1B3A5B] hover:bg-[#F0F4FF] transition-all" data-query={s}>{s}</button>
              ))}
            </div>
          </div>
        </div>

      </div>

      <!-- Footer -->
      <div class="px-4 py-2 border-t border-[#E8ECF2] bg-[#F8FAFC] flex items-center justify-between shrink-0">
        <span class="text-[10px] text-[#94A3B8] font-mono">Powered by Groq · {searchIndex.length} instruments</span>
        <div class="flex items-center gap-3 text-[10px] text-[#94A3B8] font-mono">
          <span><kbd class="px-1 py-0.5 bg-white border border-[#E2E8F0] rounded text-[9px]">⌘K</kbd> toggle</span>
          <span><kbd class="px-1 py-0.5 bg-white border border-[#E2E8F0] rounded text-[9px]">esc</kbd> close</span>
        </div>
      </div>

    </div>
  </div>
</dialog>

<script define:vars={{ searchIndex }}>
  window.__CIE_SEARCH_INDEX__ = searchIndex;
</script>

<script>
import Fuse from 'fuse.js';

type Entry = { id: string; model: string; name: string; tagline: string; category: string; brand: string; href: string; image: string; };

const index: Entry[] = (window as any).__CIE_SEARCH_INDEX__ || [];

const fuse = new Fuse(index, {
  keys: [{ name: 'model', weight: 3 }, { name: 'name', weight: 2 }, { name: 'tagline', weight: 1 }, { name: 'category', weight: 0.5 }],
  threshold: 0.35, includeScore: true, minMatchCharLength: 2, ignoreLocation: true,
});

const modal       = document.getElementById('cie-search') as HTMLDialogElement;
const input       = document.getElementById('search-input') as HTMLInputElement;
const clearBtn    = document.getElementById('search-clear') as HTMLButtonElement;
const enterHint   = document.getElementById('enter-hint') as HTMLElement;
const aiPanel     = document.getElementById('ai-panel') as HTMLElement;
const aiContent   = document.getElementById('ai-content') as HTMLElement;
const aiClose     = document.getElementById('ai-close') as HTMLButtonElement;
const catalogDiv  = document.getElementById('catalog-results') as HTMLElement;
const welcomeDiv  = document.getElementById('welcome-state') as HTMLElement;

let isStreaming = false;
let history: { role: string; parts: string }[] = [];
let fuseDebounce: ReturnType<typeof setTimeout>;

// ── Open / close ──────────────────────────────────────────────────────────
function openSearch() {
  modal.showModal();
  input.value = '';
  clearBtn.classList.add('hidden');
  enterHint?.classList.remove('hidden');
  showWelcome();
  setTimeout(() => input.focus(), 50);
}
function closeSearch() { modal.close(); input.value = ''; }

modal.addEventListener('click', e => { if (e.target === modal) closeSearch(); });
document.addEventListener('keydown', e => {
  const mac = navigator.platform.toUpperCase().includes('MAC');
  if ((mac ? e.metaKey : e.ctrlKey) && e.key === 'k') { e.preventDefault(); modal.open ? closeSearch() : openSearch(); }
  if (e.key === 'Escape' && modal.open) closeSearch();
});

// ── Input handling ─────────────────────────────────────────────────────────
input.addEventListener('input', () => {
  const q = input.value;
  clearBtn.classList.toggle('hidden', !q.trim());

  clearTimeout(fuseDebounce);
  fuseDebounce = setTimeout(() => {
    if (!q.trim()) { showWelcome(); return; }
    renderCatalog(q.trim(), extractKeywords(q.trim()));
  }, 120);
});

// Extract meaningful keywords from a natural language query
function extractKeywords(q: string): string {
  const stop = new Set(['what','do','i','need','to','for','the','a','an','best','good','which','is','are','can','how','me','my','us','we','should','use','get','buy','find','vs','versus','between','and','or','in','on','with','about','please','help','recommend','some','any','measure','measuring','using','used','suitable','suitable','type','types','kind','kinds']);
  const words = q.toLowerCase().replace(/[?!.,]/g,'').split(/\s+/).filter(w => w.length > 1 && !stop.has(w));
  return words.length ? words.join(' ') : q;
}

input.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey && input.value.trim() && !isStreaming) {
    e.preventDefault();
    askAI(input.value.trim());
  }
});

clearBtn.addEventListener('click', () => {
  input.value = '';
  clearBtn.classList.add('hidden');
  hideAI();
  showWelcome();
  input.focus();
});

aiClose.addEventListener('click', hideAI);

// Suggestion chips
document.addEventListener('click', e => {
  const chip = (e.target as HTMLElement).closest('.suggestion-chip') as HTMLElement | null;
  if (!chip) return;
  const q = chip.dataset.query || '';
  input.value = q;
  clearBtn.classList.remove('hidden');
  history = []; // fresh question — don't carry old context
  renderCatalog(q, extractKeywords(q));
  askAI(q);
});

// ── AI ────────────────────────────────────────────────────────────────────
async function askAI(q: string) {
  if (isStreaming) return;
  isStreaming = true;

  aiPanel.classList.remove('hidden');
  aiContent.innerHTML = `<span class="inline-flex gap-1 items-center">
    <span class="w-1.5 h-1.5 bg-[#94A3B8] rounded-full animate-bounce" style="animation-delay:0ms"></span>
    <span class="w-1.5 h-1.5 bg-[#94A3B8] rounded-full animate-bounce" style="animation-delay:150ms"></span>
    <span class="w-1.5 h-1.5 bg-[#94A3B8] rounded-full animate-bounce" style="animation-delay:300ms"></span>
  </span>`;

  // scroll AI panel into view
  aiPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

  let fullText = '';
  try {
    const res = await fetch('/api/search', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: q, history }),
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({ error: 'Unknown error' }));
      renderMD(aiContent, `_${err.error || 'Could not reach AI. Check that GEMINI_API_KEY is set in Vercel.'}_`);
    } else {
      const reader = res.body!.getReader();
      const decoder = new TextDecoder();
      aiContent.innerHTML = '';
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        fullText += decoder.decode(value, { stream: true });
        renderMD(aiContent, fullText);
      }
      history.push({ role: 'user', parts: q });
      history.push({ role: 'model', parts: fullText });
      if (history.length > 12) history = history.slice(-12);
    }
  } catch {
    renderMD(aiContent, '_Connection error — please try again._');
  }
  isStreaming = false;
}

function hideAI() {
  aiPanel.classList.add('hidden');
  aiContent.innerHTML = '';
}

// ── Catalog ───────────────────────────────────────────────────────────────
function showWelcome() {
  hideAI();
  catalogDiv.innerHTML = '';
  const welcome = document.createElement('div');
  welcome.className = 'px-4 py-4';
  welcome.id = 'welcome-state';
  welcome.innerHTML = `
    <p class="text-xs text-[#94A3B8] mb-3">Try asking a question or search by product name, model, or spec.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      ${['What do I need to measure motor insulation?','Compare LCR-1B vs LCR-2A','Best clamp meter for solar systems','Earth tester for site work']
        .map(s => `<button class="suggestion-chip text-left text-xs px-3 py-2.5 rounded-xl border border-[#E2E8F0] text-[#475569] hover:border-[#1B3A5B] hover:text-[#1B3A5B] hover:bg-[#F0F4FF] transition-all" data-query="${esc(s)}">${esc(s)}</button>`).join('')}
    </div>`;
  catalogDiv.appendChild(welcome);
}

// Strict fuse for single-word lookups to avoid loose false matches
const fuseStrict = new Fuse(index, {
  keys: [{ name: 'model', weight: 3 }, { name: 'name', weight: 2 }, { name: 'tagline', weight: 1 }, { name: 'category', weight: 0.5 }],
  threshold: 0.15, includeScore: true, minMatchCharLength: 3, ignoreLocation: true,
});

function smartSearch(q: string): Entry[] {
  const keywords = extractKeywords(q);
  const words = keywords.split(/\s+/).filter(w => w.length > 2);
  const seen = new Set<string>();
  const candidates: Entry[] = [];

  // Gather fuzzy candidates
  for (const r of fuse.search(keywords, { limit: 30 })) {
    if (!seen.has(r.item.id)) { seen.add(r.item.id); candidates.push(r.item); }
  }
  for (const word of words) {
    for (const r of fuseStrict.search(word, { limit: 10 })) {
      if (!seen.has(r.item.id)) { seen.add(r.item.id); candidates.push(r.item); }
    }
  }

  // Post-filter: keep only items where at least one keyword literally appears
  // Eliminates false fuzzy matches like "motor" → "Micro-Ohm Meter"
  const filtered = words.length
    ? candidates.filter(item => {
        const text = `${item.name} ${item.model} ${item.category} ${item.tagline}`.toLowerCase();
        return words.some(w => new RegExp(`\\b${w}`).test(text));
      })
    : candidates;

  return (filtered.length ? filtered : candidates).slice(0, 40);
}

function renderCatalog(q: string, _keywords?: string) {
  const items = smartSearch(q);
  if (!items.length) {
    catalogDiv.innerHTML = `<div class="px-6 py-8 text-center">
      <p class="text-[#64748B] font-medium text-sm">No catalog match for "<span class="text-[#0D1B2A]">${esc(q)}</span>"</p>
      <p class="text-xs text-[#94A3B8] mt-1">Press <kbd class="px-1 py-0.5 bg-[#F1F5F9] border border-[#E2E8F0] rounded text-[9px]">↵</kbd> to ask the AI</p>
    </div>`;
    return;
  }

  const cie     = items.filter(i => i.brand === 'cie');
  const vartech = items.filter(i => i.brand === 'vartech');
  let html = '';

  if (cie.length) {
    html += `<div class="pt-2.5 pb-1">
      <div class="px-4 mb-1.5 flex items-center gap-2">
        <span class="text-[9px] font-mono uppercase tracking-widest text-[#E0252E] font-bold">CIE — Manufactured</span>
        <span class="text-[9px] text-[#94A3B8]">${cie.length} result${cie.length!==1?'s':''}</span>
      </div>
      ${cie.map(item => resultRow(item, q)).join('')}
    </div>`;
  }
  if (vartech.length) {
    html += `<div class="${cie.length?'border-t border-[#F1F5F9]':''} pt-2.5 pb-1">
      <div class="px-4 mb-1.5 flex items-center gap-2">
        <span class="text-[9px] font-mono uppercase tracking-widest text-emerald-600 font-bold">Vartech — Authorised Dealer</span>
        <span class="text-[9px] text-[#94A3B8]">${vartech.length} result${vartech.length!==1?'s':''}</span>
      </div>
      ${vartech.map(item => resultRow(item, q)).join('')}
    </div>`;
  }

  catalogDiv.innerHTML = html;
}

function resultRow(item: Entry, q: string): string {
  const isCIE = item.brand === 'cie';
  const badge = isCIE ? 'bg-[#0D2547] text-white' : 'bg-emerald-700 text-white';
  const tag = item.tagline.length > 75 ? item.tagline.slice(0, 75) + '…' : item.tagline;
  return `<a href="${esc(item.href)}" data-result
    class="flex items-center gap-3 px-4 py-2.5 hover:bg-[#F0F4FF] transition-colors group"
    onclick="document.getElementById('cie-search').close()">
    <div class="w-10 h-10 rounded-lg bg-[#F8FAFC] border border-[#E8ECF2] flex items-center justify-center shrink-0 overflow-hidden">
      ${item.image
        ? `<img src="${esc(item.image)}" alt="" class="w-9 h-9 object-contain p-0.5" loading="lazy" onerror="this.style.display='none'">`
        : `<svg class="w-5 h-5 text-[#CBD5E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/></svg>`}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-0.5">
        <span class="inline-block text-[9px] font-mono font-bold px-1.5 py-0.5 rounded ${badge} shrink-0">${highlight(item.model, q)}</span>
        <span class="text-[10px] text-[#94A3B8] truncate">${esc(item.category)}</span>
      </div>
      <p class="text-sm font-semibold text-[#0D1B2A] leading-snug truncate group-hover:text-[#1B3A5B]">${highlight(item.name, q)}</p>
      ${tag ? `<p class="text-[11px] text-[#64748B] truncate mt-0.5">${highlight(tag, q)}</p>` : ''}
    </div>
    <svg class="w-4 h-4 text-[#CBD5E1] shrink-0 group-hover:text-[#1B3A5B] transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </a>`;
}

// ── Markdown ──────────────────────────────────────────────────────────────
function renderMD(el: HTMLElement, text: string) {
  // Split into blocks first so tables can be handled separately
  const blocks = text.split(/\n\n+/);
  const rendered = blocks.map(block => {
    const lines = block.trim().split('\n');
    // Detect markdown table (has | in most lines)
    const tableLines = lines.filter(l => l.trim().startsWith('|'));
    if (tableLines.length >= 2) {
      const rows = tableLines.filter(l => !/^\|[\s|:-]+\|$/.test(l.trim())); // skip separator
      if (rows.length >= 1) {
        const parseRow = (row: string) =>
          row.trim().replace(/^\||\|$/g,'').split('|').map(c => c.trim());
        const [head, ...body] = rows;
        const headers = parseRow(head);
        const thHtml = headers.map(h => `<th class="px-3 py-1.5 text-left text-[11px] font-semibold text-[#1B3A5B] bg-[#EEF2FF] border border-[#E0E9FF]">${boldify(h)}</th>`).join('');
        const trHtml = body.map(row =>
          `<tr class="even:bg-[#F8FAFC]">${parseRow(row).map(c => `<td class="px-3 py-1.5 text-[12px] text-[#334155] border border-[#E8ECF2]">${boldify(c)}</td>`).join('')}</tr>`
        ).join('');
        return `<div class="overflow-x-auto my-2 rounded-lg border border-[#E0E9FF]"><table class="w-full text-left border-collapse"><thead><tr>${thHtml}</tr></thead><tbody>${trHtml}</tbody></table></div>`;
      }
    }
    // Normal block
    let b = esc(block)
      .replace(/^### (.+)$/gm, '<strong class="block text-[#0D2547] font-semibold text-[13px] mt-1">$1</strong>')
      .replace(/^## (.+)$/gm,  '<strong class="block text-[#0D2547] font-semibold mt-1">$1</strong>')
      .replace(/\*\*(.+?)\*\*/g, '<strong class="text-[#0D2547]">$1</strong>')
      .replace(/`([^`]+)`/g, '<code class="bg-[#E8ECF2] px-1 py-0.5 rounded text-[11px] font-mono text-[#1B3A5B]">$1</code>')
      .replace(/^[-•]\s(.+)$/gm, '<li class="ml-4 list-disc list-outside leading-snug">$1</li>')
      .replace(/\n/g, '<br>');
    if (b.includes('<li')) b = b.replace(/(<li[^>]*>.*?<\/li>(<br>)?)+/gs, m => `<ul class="space-y-0.5 my-1">${m.replace(/<br>/g,'')}</ul>`);
    return `<p class="text-sm leading-relaxed">${b}</p>`;
  }).join('');

  el.innerHTML = rendered;
}

function boldify(text: string): string {
  return esc(text).replace(/\*\*(.+?)\*\*/g, '<strong class="text-[#0D2547]">$1</strong>');
}

function highlight(text: string, q: string): string {
  if (!q) return esc(text);
  const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
  return esc(text).replace(re, '<mark class="bg-yellow-100 text-yellow-800 rounded-sm px-0.5">$1</mark>');
}
function esc(s: string) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>

<style>
#cie-search::backdrop { background: transparent; }
.ai-content p:first-child { margin-top: 0; }
.ai-content p:last-child  { margin-bottom: 0; }
</style>
