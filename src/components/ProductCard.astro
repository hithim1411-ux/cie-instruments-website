---
interface Props {
  model: string;
  name: string;
  tagline: string;
  categoryId: string;
  id: string;
  featured?: boolean;
  image?: string;
  hideImage?: boolean;
}
const { model, name, tagline, categoryId, id, featured = false, image, hideImage = false } = Astro.props;
import site from '../data/site.json';
import { u } from '../utils/url';
const waMsg = encodeURIComponent(`Hi, I'd like to enquire about the ${model} — ${name}`);
// Vartech images live at /images/vartech/... not /images/products/vartech/...
const imgSrc = image
  ? (image.startsWith('vartech/') ? u(`/images/${image}`) : u(`/images/products/${image}`))
  : u(`/images/products/${id}.webp`);
// Vartech products live under /authorised-dealership/{slug}/, not /products/{categoryId}/
// categoryId pattern: "vartech-oscilloscopes" → dealer slug: "oscilloscopes"
const detailHref = categoryId.startsWith('vartech-')
  ? u(`/authorised-dealership/${categoryId.replace('vartech-', '')}/${id}/`)
  : u(`/products/${categoryId}/${id}/`);
const isVartech = categoryId.startsWith('vartech-');
---

<article class={`bg-white rounded-lg border border-[#E8ECF2] overflow-hidden flex flex-col transition-shadow duration-200 hover:shadow-md ${featured ? 'ring-2 ring-[#E0252E]/20' : ''}`}>
  <!-- Product image -->
  {!hideImage && (
    <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] h-44 flex items-center justify-center relative">
      <img
        src={imgSrc}
        alt={`${model} — ${name}`}
        width="600"
        height="600"
        class="object-contain h-36 w-auto"
        loading="lazy"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
      />
      <!-- Placeholder when no image supplied -->
      <div class="hidden absolute inset-0 flex-col items-center justify-center gap-2 text-[#b0bec5]">
        <svg class="w-12 h-12 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/>
          <path d="M3 9l4-4 4 4 4-4 4 4" stroke-width="1.5"/>
        </svg>
        <span class="text-xs font-mono uppercase tracking-wider opacity-50">Image coming soon</span>
      </div>
      {isVartech ? (
        <span class="absolute top-2 left-2 text-[9px] font-mono font-bold uppercase tracking-widest text-emerald-700 bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 rounded">
          Vartech®
        </span>
      ) : featured && (
        <span class="absolute top-3 right-3 bg-[#E0252E] text-white text-xs font-mono px-2 py-0.5 rounded uppercase tracking-wider">
          Featured
        </span>
      )}
    </div>
  )}

  <div class="p-5 flex flex-col flex-1">
    <p class="model-code text-xs mb-1">{model}</p>
    <h3 class="font-bold text-[#0D2547] text-base mb-2 leading-snug">{name}</h3>
    <p class="text-sm text-[#64748B] mb-4 flex-1 line-clamp-3">{tagline}</p>

    <div class="flex flex-col gap-2 mt-auto">
      <a
        href={detailHref}
        class="text-center px-4 py-2.5 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-sm font-semibold rounded transition-colors"
      >
        View Specifications
      </a>
      <a
        href={`https://wa.me/${site.whatsapp}?text=${waMsg}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-center px-4 py-2 border border-[#25D366] text-[#1a6e38] hover:bg-[#25D366]/10 text-sm font-medium rounded transition-colors"
      >
        Enquire on WhatsApp
      </a>
    </div>
  </div>
</article>
