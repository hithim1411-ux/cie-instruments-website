---
interface Props {
  type?: 'tip' | 'warning' | 'info' | 'formula';
  title?: string;
}
const { type = 'tip', title } = Astro.props;

const styles = {
  tip: {
    wrap: 'bg-emerald-50 border-l-4 border-emerald-500',
    icon: `<svg class="w-5 h-5 text-emerald-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    heading: 'text-emerald-800',
    body: 'text-emerald-900',
  },
  warning: {
    wrap: 'bg-amber-50 border-l-4 border-amber-500',
    icon: `<svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>`,
    heading: 'text-amber-800',
    body: 'text-amber-900',
  },
  info: {
    wrap: 'bg-blue-50 border-l-4 border-blue-500',
    icon: `<svg class="w-5 h-5 text-blue-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>`,
    heading: 'text-blue-800',
    body: 'text-blue-900',
  },
  formula: {
    wrap: 'bg-[#0D1B2A] border-l-4 border-[#E0252E]',
    icon: `<svg class="w-5 h-5 text-[#E0252E] shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.745 3A23.933 23.933 0 003 12c0 3.183.62 6.22 1.745 9M19.5 3c.967 2.78 1.5 5.77 1.5 9s-.533 6.22-1.5 9M8.25 8.885l1.444-.89a.75.75 0 011.105.402l2.402 7.206a.75.75 0 001.104.401l1.445-.889m-8.25.75l.213.09a1.687 1.687 0 002.062-.617l4.45-6.676a1.688 1.688 0 012.062-.618l.213.09"/></svg>`,
    heading: 'text-white',
    body: 'text-gray-200',
  },
};

const s = styles[type];
---

<div class={`rounded-xl p-5 my-8 ${s.wrap}`}>
  <div class="flex gap-3 items-start">
    <Fragment set:html={s.icon} />
    <div>
      {title && <p class={`font-bold text-sm mb-1 ${s.heading}`}>{title}</p>}
      <div class={`text-sm leading-relaxed ${s.body} [&>p]:mb-2 [&>p:last-child]:mb-0`}>
        <slot />
      </div>
    </div>
  </div>
</div>
