---
import site from '../data/site.json';
import categories from '../data/categories.json';
import { u } from '../utils/url';

const topCategories = categories.slice(0, 6);

const genericMailto = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent('Quote Request — CIE Instruments')}&body=${encodeURIComponent('Hello CIE team,\n\nI would like to request a quote for: [PRODUCT / MODEL].\n\nRequired rated voltage / resistance range:\nQuantity:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.')}`;
---

<footer class="bg-[#0D1B2A] text-[#b0bec5]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

    <!-- Brand column -->
    <div class="lg:col-span-1">
      <a href={u('/')} class="inline-block mb-4" aria-label="CIE Home">
        <img src={u('/logo/cie-logo-light.png')} alt="CIE Instruments" width="1577" height="997" class="h-14 w-auto" />
      </a>
      <p class="text-sm leading-relaxed mb-4">
        Cambridge Instruments &amp; Engg. Co. — instruments for accuracy and reliability,
        manufactured in Howrah since 1963.
      </p>
      <p class="text-xs text-[#94a3b8] mt-1">Est. 1963 · Made in India</p>
    </div>

    <!-- Products column -->
    <div>
      <h3 class="text-white text-sm font-semibold uppercase tracking-widest mb-4 font-mono">Products</h3>
      <ul class="space-y-2 text-sm">
        {topCategories.map(cat => (
          <li>
            <a href={u(`/products/${cat.id}/`)} class="hover:text-white transition-colors">{cat.shortName}</a>
          </li>
        ))}
        <li>
          <a href={u('/products/')} class="text-[#E0252E] hover:text-[#D72631] transition-colors font-medium">
            View all products →
          </a>
        </li>
      </ul>
    </div>

    <!-- Company column -->
    <div>
      <h3 class="text-white text-sm font-semibold uppercase tracking-widest mb-4 font-mono">Company</h3>
      <ul class="space-y-2 text-sm">
        <li><a href={u('/about/')} class="hover:text-white transition-colors">About Us</a></li>
        <li><a href={u('/industries/')} class="hover:text-white transition-colors">Industries Served</a></li>
        <li><a href={u('/faq/')} class="hover:text-white transition-colors">FAQs</a></li>
        <li><a href={u('/contact/')} class="hover:text-white transition-colors">Contact Us</a></li>
        <li><a href={genericMailto} class="hover:text-white transition-colors">Request a Quote</a></li>
      </ul>
    </div>

    <!-- Contact column -->
    <div>
      <h3 class="text-white text-sm font-semibold uppercase tracking-widest mb-4 font-mono">Contact</h3>
      <address class="not-italic text-sm space-y-4">
        {site.addresses.map(addr => (
          <div>
            <p class="text-white text-xs font-mono uppercase tracking-wider mb-1">{addr.type}</p>
            {addr.lines.map(line => <p>{line}</p>)}
          </div>
        ))}
        <div class="space-y-1 pt-1">
          {site.phones.map(p => (
            <p>
              <span class="text-xs text-[#94a3b8]">{p.label}: </span>
              <a href={`tel:${p.number.replace(/\s/g,'')}`} class="hover:text-white transition-colors">{p.number}</a>
            </p>
          ))}
          <p>
            <a href={`mailto:${site.email}`} class="hover:text-white transition-colors">{site.email}</a>
          </p>
        </div>
      </address>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-[#64748B]">
      <p>© {new Date().getFullYear()} Cambridge Instruments &amp; Engg. Co. All rights reserved.</p>
    </div>
  </div>
</footer>
