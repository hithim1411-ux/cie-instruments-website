---
import site from '../data/site.json';
interface Props {
  productName?: string;
}
const { productName = '' } = Astro.props;
const waMsg = productName
  ? encodeURIComponent(`Hi, I'd like a quote for: ${productName}`)
  : encodeURIComponent("Hi, I'd like to enquire about CIE instruments.");
---

<div class="bg-white rounded-lg border border-[#E8ECF2] p-6 sm:p-8">
  <h2 class="text-xl font-bold text-[#0D2547] mb-1">Request a Quote</h2>
  <p class="text-sm text-[#64748B] mb-6">
    Fill in the form and we'll respond within one business day — or reach us directly on WhatsApp for faster turnaround.
  </p>

  <!--
    FORM ENDPOINT: Replace the action URL below with your Formspree endpoint.
    Sign up at https://formspree.io, create a form, and paste the endpoint here.
    e.g. action="https://formspree.io/f/abcdefgh"
    Alternatively, to use mailto fallback, set action="mailto:cieinstruments@gmail.com"
    and add enctype="text/plain" (no file uploads then).
  -->
  <form
    action={site.formEndpoint}
    method="POST"
    class="space-y-4"
    id="enquiry-form"
  >
    <!-- Honeypot anti-spam -->
    <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
    <input type="hidden" name="_subject" value={`CIE Enquiry${productName ? `: ${productName}` : ''}`} />
    <input type="hidden" name="_next" value="https://cieinstruments.in/contact?sent=1" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="name" class="block text-sm font-medium text-[#1B3A5B] mb-1">Full Name <span class="text-[#E0252E]">*</span></label>
        <input
          type="text" id="name" name="name" required autocomplete="name"
          class="w-full px-3 py-2.5 border border-[#E8ECF2] rounded text-sm focus:outline-none focus:ring-2 focus:ring-[#1B3A5B]/30 focus:border-[#1B3A5B]"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="company" class="block text-sm font-medium text-[#1B3A5B] mb-1">Company / Organisation</label>
        <input
          type="text" id="company" name="company" autocomplete="organization"
          class="w-full px-3 py-2.5 border border-[#E8ECF2] rounded text-sm focus:outline-none focus:ring-2 focus:ring-[#1B3A5B]/30 focus:border-[#1B3A5B]"
          placeholder="Your company"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="email" class="block text-sm font-medium text-[#1B3A5B] mb-1">Email Address <span class="text-[#E0252E]">*</span></label>
        <input
          type="email" id="email" name="email" required autocomplete="email"
          class="w-full px-3 py-2.5 border border-[#E8ECF2] rounded text-sm focus:outline-none focus:ring-2 focus:ring-[#1B3A5B]/30 focus:border-[#1B3A5B]"
          placeholder="you@company.com"
        />
      </div>
      <div>
        <label for="phone" class="block text-sm font-medium text-[#1B3A5B] mb-1">Phone Number</label>
        <input
          type="tel" id="phone" name="phone" autocomplete="tel"
          class="w-full px-3 py-2.5 border border-[#E8ECF2] rounded text-sm focus:outline-none focus:ring-2 focus:ring-[#1B3A5B]/30 focus:border-[#1B3A5B]"
          placeholder="+91 ..."
        />
      </div>
    </div>

    <div>
      <label for="product" class="block text-sm font-medium text-[#1B3A5B] mb-1">Product Interest</label>
      <input
        type="text" id="product" name="product"
        value={productName}
        class="w-full px-3 py-2.5 border border-[#E8ECF2] rounded text-sm focus:outline-none focus:ring-2 focus:ring-[#1B3A5B]/30 focus:border-[#1B3A5B]"
        placeholder="e.g. CIE/444, RTS-33, or describe your requirement"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-[#1B3A5B] mb-1">Message / Requirement <span class="text-[#E0252E]">*</span></label>
      <textarea
        id="message" name="message" required rows="4"
        class="w-full px-3 py-2.5 border border-[#E8ECF2] rounded text-sm focus:outline-none focus:ring-2 focus:ring-[#1B3A5B]/30 focus:border-[#1B3A5B] resize-y"
        placeholder="Please describe your requirement, quantity, and any special specifications..."
      ></textarea>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 pt-2">
      <button
        type="submit"
        class="flex-1 px-6 py-3 bg-[#E0252E] hover:bg-[#D72631] text-white font-bold rounded transition-colors text-sm"
      >
        Send Enquiry
      </button>
      <a
        href={`https://wa.me/${site.whatsapp}?text=${waMsg}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 flex items-center justify-center gap-2 px-6 py-3 border-2 border-[#25D366] text-[#1a6e38] font-semibold rounded hover:bg-[#25D366]/10 transition-colors text-sm"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Enquire on WhatsApp
      </a>
    </div>
  </form>
</div>
