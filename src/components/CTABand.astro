---
import { u } from '../utils/url';

interface Props {
  heading?: string;
  body?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const genericMailto = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent('Quote Request — CIE Instruments')}&body=${encodeURIComponent('Hello CIE team,\n\nI would like to request a quote for: [PRODUCT / MODEL].\n\nRequired rated voltage / resistance range:\nQuantity:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.')}`;

const {
  heading = "Ready to specify? We'll respond the same day.",
  body = 'Send your requirement by email or WhatsApp — we respond within one business day.',
  primaryLabel = 'Request a Quote',
  primaryHref = genericMailto,
  secondaryLabel = 'View Products',
  secondaryHref = u('/products'),
} = Astro.props;
---

<section class="bg-[#E0252E] text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-14 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold mb-3">{heading}</h2>
    <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">{body}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={primaryHref}
        class="px-8 py-3.5 bg-white text-[#E0252E] font-bold rounded hover:bg-[#F5F7FA] transition-colors text-sm"
      >
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="px-8 py-3.5 border-2 border-white text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
