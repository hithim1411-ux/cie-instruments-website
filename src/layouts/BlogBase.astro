---
import '../styles/global.css';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { u } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Technical articles on electrical measurement instruments, testing methodology, and the physics behind every reading — from CIE Instruments, established 1963.',
  ogImage = u('/logo/cie-logo.png'),
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://cieinstruments.in');
const currentPath = Astro.url.pathname;
const onInsights = currentPath.startsWith(u('/blog'));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="canonical" href={canonicalURL.toString()} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, 'https://cieinstruments.in').toString()} />
  <meta property="og:type" content="article" />

  <link rel="icon" type="image/png" href={u('/logo/cie-logo.png')} />
</head>

<body class="bg-white text-[#1a202c] antialiased">

  <!-- ══════════════════════════════════════════════
       EDITORIAL HEADER — distinct from main site
  ═══════════════════════════════════════════════ -->
  <header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
    <!-- Thin red top accent -->
    <div class="h-[3px] bg-[#E0252E] w-full"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">

        <!-- Left: CIE logo + Insights wordmark -->
        <a href={u('/blog/')} class="flex items-center gap-3 group" aria-label="CIE Insights">
          <img
            src={u('/logo/cie-logo.png')}
            alt="CIE®"
            width="28"
            height="28"
            class="object-contain"
          />
          <div class="w-px h-5 bg-gray-300"></div>
          <span class="text-[11px] font-mono font-bold uppercase tracking-[0.22em] text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors">
            Insights
          </span>
        </a>

        <!-- Right: editorial nav -->
        <nav class="flex items-center gap-1 sm:gap-2" aria-label="Insights navigation">
          <a href={u('/blog/')}
             class={`hidden sm:block text-xs font-medium px-3 py-1.5 rounded transition-colors ${onInsights && currentPath === u('/blog/') ? 'text-[#0D1B2A] bg-gray-100' : 'text-[#64748b] hover:text-[#0D1B2A] hover:bg-gray-50'}`}>
            All Articles
          </a>
          <a href={u('/products/')}
             class="hidden md:block text-xs font-medium px-3 py-1.5 rounded text-[#64748b] hover:text-[#0D1B2A] hover:bg-gray-50 transition-colors">
            Products
          </a>
          <a href={u('/contact/')}
             class="hidden md:block text-xs font-medium px-3 py-1.5 rounded text-[#64748b] hover:text-[#0D1B2A] hover:bg-gray-50 transition-colors">
            Contact
          </a>
          <div class="w-px h-4 bg-gray-200 mx-1 hidden md:block"></div>
          <a href={u('/')}
             class="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded border border-gray-200 text-[#64748b] hover:border-[#0D1B2A] hover:text-[#0D1B2A] transition-colors">
            <span>cieinstruments.in</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </nav>
      </div>
    </div>
  </header>

  <!-- Page content -->
  <main>
    <slot />
  </main>

  <!-- ══════════════════════════════════════════════
       EDITORIAL FOOTER — minimal, distinct
  ═══════════════════════════════════════════════ -->
  <footer class="bg-[#F5F7FA] border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">

        <!-- Left: brand -->
        <div class="flex items-center gap-4">
          <img src={u('/logo/cie-logo.png')} alt="CIE Instruments" width="36" height="36" class="object-contain" />
          <div>
            <p class="text-sm font-bold text-[#0D1B2A]">Cambridge Instruments &amp; Engg. Co.</p>
            <p class="text-xs text-[#64748b]">Instruments for Accuracy and Reliability · Est. 1963</p>
          </div>
        </div>

        <!-- Right: minimal links -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-[#64748b]">
          <a href={u('/blog/')} class="hover:text-[#0D1B2A] transition-colors">All Insights</a>
          <a href={u('/products/')} class="hover:text-[#0D1B2A] transition-colors">Products</a>
          <a href={u('/about/')} class="hover:text-[#0D1B2A] transition-colors">About</a>
          <a href={u('/contact/')} class="hover:text-[#0D1B2A] transition-colors">Contact</a>
          <span class="text-gray-300">·</span>
          <span>© {new Date().getFullYear()} Cambridge Instruments &amp; Engg. Co.</span>
        </div>
      </div>
    </div>
  </footer>

  <WhatsAppButton />
</body>
</html>
