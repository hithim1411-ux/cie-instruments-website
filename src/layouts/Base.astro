---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Search from '../components/Search.astro';
import { u } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  rawTitle?: boolean;
  preloadImage?: string;
  keywords?: string;
}

const {
  title,
  description = 'Cambridge Instruments & Engg. Co. (CIE) — manufacturer and supplier of electrical test and measurement instruments since 1963. Insulation testers, earth testers, relay test sets, oil BDV testers. Kolkata, Howrah, West Bengal. Pan-India supply.',
  ogImage = u('/logo/cie-logo.png'),
  noindex = false,
  rawTitle = false,
  preloadImage,
  keywords,
} = Astro.props;

const baseKeywords = [
  // Brand & company name variants (including common misspellings)
  'Cambridge Instruments', 'Cambridge Intruments', 'Cambridge Instruments and Engg Co',
  'Cambridge Instruments & Engg Co', 'Cambridge Instruments Engineering',
  'Cambridge Instruments Kolkata', 'Cambridge Instruments Howrah',
  'CIE Instruments', 'CIE', 'CIE India', 'cieinstruments', 'cieinstruments.com',
  'cieinstrument.com', 'cieinstruments.in', 'cie instruments india',
  // Core products — CIE manufactured
  'insulation tester supplier Kolkata', 'insulation tester supplier India',
  'insulation tester Howrah', 'insulation tester West Bengal',
  'megger supplier India', 'megger supplier Kolkata', 'megohmmeter India',
  'earth tester supplier India', 'earth tester supplier Kolkata',
  'earth resistance tester India', 'ground resistance tester India',
  'relay test set supplier India', 'relay test set Kolkata',
  'oil BDV tester supplier', 'oil dielectric strength tester India',
  'transformer oil test set India', 'oil breakdown voltage tester',
  'HV test set supplier India', 'high voltage test set India',
  'micro ohm meter India', 'micro-ohm meter supplier Kolkata',
  'contact resistance meter India', 'Kelvin bridge meter India',
  'phase sequence indicator India', 'phase rotation indicator supplier',
  'hand driven insulation tester', 'motor operated insulation tester',
  'digital insulation tester India', 'multirange insulation tester',
  'compact insulation tester India', '5kV insulation tester India',
  // CIE model numbers
  'CIE 444', 'CIE444', 'CIE 333', 'CIE 222', 'CIE 555', 'CIE 111',
  'CIE model', 'CIE insulation tester model',
  // T&M general + Vartech
  'test and measurement instruments supplier India',
  'test and measuring instruments India', 't&m instruments India',
  'electrical test equipment supplier Kolkata', 'electrical test equipment India',
  'electrical instruments supplier West Bengal',
  'industrial test equipment supplier', 'test measurement instruments Howrah',
  'electrical measuring instruments supplier', 'electrical measurement instruments India',
  'digital multimeter India', 'digital multimeters India', 'multimeter supplier India',
  'clamp meter India', 'clamp meters India', 'clamp meter supplier India',
  'true RMS clamp meter India', 'AC DC clamp meter India',
  'oscilloscope India', 'oscilloscopes India', 'digital storage oscilloscope India',
  'DSO supplier India', 'oscilloscope supplier Kolkata',
  'function generator India', 'signal generator India',
  'function generator supplier India', 'arbitrary function generator India',
  'LCR meter India', 'LCR meter supplier India', 'capacitance meter India',
  'impedance meter India', 'LC meter India',
  'DC electronic load India', 'programmable DC load India', 'electronic load supplier',
  'sound level meter India', 'decibel meter India', 'noise meter India',
  'anemometer India', 'wind speed meter India', 'air velocity meter India',
  'lux meter India', 'light meter India', 'illuminance meter India',
  'thermometer India', 'temperature meter India', 'digital thermometer India',
  'calibrator India', 'process calibrator India', 'signal calibrator India',
  'vartech multimeters India', 'vartech clamp meters', 'vartech oscilloscopes',
  'vartech function generators', 'vartech LCR meters', 'vartech DC loads',
  'Vartech instruments India', 'Vartech authorised dealer India',
  // Physics / lab / education angle
  'physics lab instruments India', 'physics instruments supplier India',
  'lab test equipment India', 'educational instruments supplier India',
  'electrical lab equipment India', 'engineering instruments India',
  // Location
  'test equipment supplier Kolkata', 'test equipment supplier West Bengal',
  'instrument supplier Howrah', 'electrical supplier Kolkata',
].join(', ');
const fullKeywords = keywords ? `${keywords}, ${baseKeywords}` : baseKeywords;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = rawTitle
  ? title
  : title === 'Home'
    ? 'Cambridge Instruments & Engg. Co. (CIE) — Test & Measurement Instruments Supplier | Kolkata, Howrah, India'
    : `${title} | Cambridge Instruments & Engg. Co. (CIE) — Kolkata, Howrah`;

const ogImageURL = new URL(ogImage, Astro.site).toString();
const canonicalStr = canonicalURL.toString();

// BreadcrumbList schema
const slugLabels: Record<string, string> = {
  products: 'Products', blog: 'Insights', contact: 'Contact',
  'authorised-dealership': 'Authorised Dealership', about: 'About Us',
  faq: 'FAQs', industries: 'Industries', quality: 'Quality',
  'insulation-testers-hand': 'Insulation Testers (Hand-Driven)',
  'multirange-insulation-hand': 'Multirange Insulation Testers',
  'motor-operated-insulation': 'Motor-Operated Insulation Testers',
  'multirange-motorised-insulation': 'Multirange Motorised Insulation',
  'compact-insulation-testers': 'Compact Insulation Testers',
  'earth-tester': 'Earth Testers', 'digital-insulation-testers': 'Digital Insulation Testers',
  'digital-earth-micro-ohm': 'Micro-Ohm Meters', 'clamp-meters': 'Clamp Meters',
  multimeters: 'Digital Multimeters', 'hv-phase-sequence': 'HV Test Sets',
  'phase-sequence-indicators': 'Phase Sequence Indicators',
  'oil-test-sets': 'Oil BDV Test Sets', 'relay-test-sets': 'Relay Test Sets',
  oscilloscopes: 'Oscilloscopes', 'function-generators': 'Function Generators',
  'lcr-meters': 'LCR & Cap Meters', 'dc-loads': 'DC Electronic Loads',
};
const pathParts = Astro.url.pathname.replace(/^\/|\/$/g, '').split('/').filter(Boolean);
const breadcrumbSchema = pathParts.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cieinstruments.in/' },
    ...pathParts.map((seg, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: slugLabels[seg] ?? seg.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
      item: `https://cieinstruments.in/${pathParts.slice(0, i + 1).join('/')}/`,
    })),
  ],
}) : null;

// Organisation + WebSite structured data (site-wide)
const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'LocalBusiness'],
      '@id': 'https://cieinstruments.in/#organization',
      name: 'Cambridge Instruments & Engg. Co.',
      alternateName: [
        'CIE Instruments',
        'CIE',
        'Cambridge Instruments',
        'Cambridge Intruments',
        'Cambridge Instruments and Engg Co',
        'Cambridge Instruments & Engg. Co.',
        'Cambridge Instruments and Engineering Co',
        'Cambridge Instruments Howrah',
        'Cambridge Instruments Kolkata',
        'cieinstruments',
        'cieinstruments.com',
        'cieinstrument.com',
        'CIE India',
        'Cambridge Inst',
      ],
      url: 'https://cieinstruments.in/',
      logo: {
        '@type': 'ImageObject',
        url: 'https://cieinstruments.in/logo/cie-logo.png',
        width: 200,
        height: 200,
      },
      image: 'https://cieinstruments.in/logo/cie-logo.png',
      foundingDate: '1963',
      telephone: '+913326388346',
      email: 'cieinstruments@gmail.com',
      priceRange: 'Contact for quote',
      description: 'Manufacturer of precision electrical test and measurement instruments — insulation testers, earth testers, relay test sets, oil BDV testers — since 1963. Made in Howrah, India.',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Howrah',
        addressLocality: 'Howrah',
        addressRegion: 'West Bengal',
        postalCode: '711101',
        addressCountry: 'IN',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 22.5958,
        longitude: 88.2636,
      },
      areaServed: [
        { '@type': 'Country', name: 'India' },
        { '@type': 'City', name: 'Kolkata' },
        { '@type': 'City', name: 'Howrah' },
        { '@type': 'City', name: 'Bengaluru' },
        { '@type': 'City', name: 'Chennai' },
        { '@type': 'City', name: 'Hyderabad' },
        { '@type': 'City', name: 'Mumbai' },
        { '@type': 'City', name: 'Delhi' },
        { '@type': 'City', name: 'Pune' },
        { '@type': 'City', name: 'Ahmedabad' },
        { '@type': 'City', name: 'Bhubaneswar' },
        { '@type': 'City', name: 'Raipur' },
        { '@type': 'City', name: 'Ranchi' },
        { '@type': 'City', name: 'Patna' },
        { '@type': 'City', name: 'Lucknow' },
      ],
      serviceArea: {
        '@type': 'Country',
        name: 'India',
      },
      contactPoint: [
        {
          '@type': 'ContactPoint',
          telephone: '+919830091260',
          email: 'cieinstruments@gmail.com',
          contactType: 'sales',
          areaServed: 'IN',
          availableLanguage: 'en',
        },
        {
          '@type': 'ContactPoint',
          telephone: '+919830092117',
          contactType: 'customer service',
          areaServed: 'IN',
          availableLanguage: 'en',
        },
      ],
      knowsAbout: [
        'Insulation Testers', 'Megger', 'Megohmmeter', 'Insulation Resistance Tester',
        'Hand Driven Insulation Tester', 'Motor Operated Insulation Tester',
        'Digital Insulation Tester', 'Multirange Insulation Tester',
        'Compact Insulation Tester', '5kV Insulation Tester', '10kV Insulation Tester',
        'Earth Resistance Testers', 'Earth Testers', 'Ground Resistance Meter',
        'Relay Test Sets', 'Protection Relay Testing',
        'Oil BDV Test Sets', 'Transformer Oil Test Sets', 'Oil Dielectric Strength Tester',
        'Oil Breakdown Voltage Tester',
        'Digital Multimeters', 'Clamp Meters', 'True RMS Multimeters',
        'AC DC Clamp Meters', 'Current Clamp Meters',
        'Vartech Instruments', 'Vartech Authorised Dealer',
        'Oscilloscopes', 'Digital Storage Oscilloscopes', 'DSO',
        'Function Generators', 'Signal Generators', 'Arbitrary Function Generators',
        'LCR Meters', 'Capacitance Meters', 'Impedance Meters',
        'DC Electronic Loads', 'Programmable DC Loads',
        'Sound Level Meters', 'Decibel Meters', 'Noise Meters',
        'Anemometers', 'Wind Speed Meters', 'Air Velocity Meters',
        'Lux Meters', 'Light Meters', 'Illuminance Meters',
        'Thermometers', 'Temperature Meters', 'Digital Thermometers',
        'Calibrators', 'Process Calibrators', 'Signal Calibrators',
        'Micro-Ohm Meters', 'Contact Resistance Meters',
        'HV Test Sets', 'High Voltage Test Equipment',
        'Phase Sequence Indicators', 'Phase Rotation Indicators',
        'Test and Measurement', 'T&M Instruments', 'Test and Measuring Instruments',
        'Electrical Safety Testing', 'Power Quality Measurement',
        'Panel Testing', 'Motor Winding Testing', 'Cable Testing', 'Substation Testing',
        'Electrical Test Equipment', 'Test and Measurement Instruments',
        'Industrial Test Equipment', 'Electrical Instruments',
        'Physics Lab Instruments', 'Electrical Lab Equipment',
        'CIE 444', 'CIE444', 'CIE model instruments',
      ],
      sameAs: [
        'https://cieinstruments.in/',
        'https://www.cieinstruments.in/',
        'https://cieinstruments.com/',
        'https://cieinstrument.com/',
        'https://maps.app.goo.gl/cieinstruments',
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'CIE Test & Measurement Instruments',
        itemListElement: [
          { '@type': 'Offer', itemOffered: { name: 'Insulation Testers', description: 'Hand-driven, motorised, and digital insulation testers from 100 V to 10 kV' } },
          { '@type': 'Offer', itemOffered: { name: 'Earth Resistance Testers', description: 'Analog and digital earth testers for 3-terminal and 4-terminal measurement' } },
          { '@type': 'Offer', itemOffered: { name: 'Relay Test Sets', description: 'Single-phase and three-phase relay test sets for protection relay commissioning' } },
          { '@type': 'Offer', itemOffered: { name: 'Transformer Oil BDV Test Sets', description: '50 kV to 120 kV oil dielectric strength testers' } },
          { '@type': 'Offer', itemOffered: { name: 'HV Test Sets', description: 'AC high voltage test sets up to 5 kV for cable and equipment testing' } },
          { '@type': 'Offer', itemOffered: { name: 'Clamp Meters & Multimeters', description: 'True-RMS clamp meters and digital multimeters for electrical measurement' } },
          { '@type': 'Offer', itemOffered: { name: 'Micro-Ohm Meters', description: '4-terminal Kelvin method micro-ohm meters for contact resistance measurement' } },
          { '@type': 'Offer', itemOffered: { name: 'Phase Sequence Indicators', description: 'Phase sequence indicators for 3-phase supply rotation verification' } },
        ],
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://cieinstruments.in/#website',
      url: 'https://cieinstruments.in/',
      name: 'CIE Instruments',
      publisher: { '@id': 'https://cieinstruments.in/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://cieinstruments.in/products/?category={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={fullKeywords} />
  <link rel="canonical" href={canonicalStr} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Geo / local SEO -->
  <meta name="geo.region" content="IN-WB" />
  <meta name="geo.placename" content="Howrah, West Bengal, India" />
  <meta name="geo.position" content="22.5958;88.2636" />
  <meta name="ICBM" content="22.5958, 88.2636" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalStr} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="CIE Instruments" />
  <meta property="og:locale" content="en_IN" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Structured data: Organisation + WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  {preloadImage && (
    <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
  )}

  <link rel="icon" type="image/png" href={u('/logo/cie-logo.png')} />
  <link rel="apple-touch-icon" href={u('/logo/cie-logo.png')} />

  <!-- BreadcrumbList schema (computed in frontmatter) -->
  {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}

  <!-- Slot for per-page structured data / additional head tags -->
  <slot name="head" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <WhatsAppButton />
  <Search />
</body>
</html>
