---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { u } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  rawTitle?: boolean; // when true, use title as-is without appending brand suffix
}

const {
  title,
  description = 'Cambridge Instruments & Engg. Co. (CIE) — manufacturer of electrical test and measurement instruments since 1963. Insulation testers, earth testers, relay test sets, oil BDV testers and more. Made in India.',
  ogImage = u('/logo/cie-logo.png'),
  noindex = false,
  rawTitle = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = rawTitle
  ? title
  : title === 'Home'
    ? 'Cambridge Instruments & Engg. Co. (CIE) — Instruments for Accuracy and Reliability | Howrah, India'
    : `${title} | Cambridge Instruments & Engg. Co. (CIE) — Howrah`;

const ogImageURL = new URL(ogImage, Astro.site).toString();
const canonicalStr = canonicalURL.toString();

// Organisation + WebSite structured data (site-wide)
const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'LocalBusiness'],
      '@id': 'https://cieinstruments.in/#organization',
      name: 'Cambridge Instruments & Engg. Co.',
      alternateName: [
        'CIE Instruments',
        'CIE',
        'Cambridge Instruments',
        'Cambridge Instruments and Engg Co',
        'Cambridge Instruments and Engineering Co',
        'Cambridge Instruments Howrah',
        'Cambridge Instruments Kolkata',
      ],
      url: 'https://cieinstruments.in/',
      logo: {
        '@type': 'ImageObject',
        url: 'https://cieinstruments.in/logo/cie-logo.png',
        width: 200,
        height: 200,
      },
      image: 'https://cieinstruments.in/logo/cie-logo.png',
      foundingDate: '1963',
      telephone: '+913326388346',
      email: 'cieinstruments@gmail.com',
      priceRange: 'Contact for quote',
      description: 'Manufacturer of precision electrical test and measurement instruments — insulation testers, earth testers, relay test sets, oil BDV testers — since 1963. Made in Howrah, India.',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Howrah',
        addressLocality: 'Howrah',
        addressRegion: 'West Bengal',
        postalCode: '711101',
        addressCountry: 'IN',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 22.5958,
        longitude: 88.2636,
      },
      areaServed: {
        '@type': 'Country',
        name: 'India',
      },
      contactPoint: {
        '@type': 'ContactPoint',
        email: 'cieinstruments@gmail.com',
        contactType: 'customer service',
        areaServed: 'IN',
        availableLanguage: 'en',
      },
      knowsAbout: [
        'Insulation Testers',
        'Earth Resistance Testers',
        'Relay Test Sets',
        'Oil BDV Test Sets',
        'Digital Multimeters',
        'Clamp Meters',
        'Micro-Ohm Meters',
        'Electrical Test Equipment',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://cieinstruments.in/#website',
      url: 'https://cieinstruments.in/',
      name: 'CIE Instruments',
      publisher: { '@id': 'https://cieinstruments.in/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://cieinstruments.in/products/?category={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalStr} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Geo / local SEO -->
  <meta name="geo.region" content="IN-WB" />
  <meta name="geo.placename" content="Howrah, West Bengal, India" />
  <meta name="geo.position" content="22.5958;88.2636" />
  <meta name="ICBM" content="22.5958, 88.2636" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalStr} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="CIE Instruments" />
  <meta property="og:locale" content="en_IN" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Structured data: Organisation + WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- Google Fonts: preconnect first, then load async (non-render-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" /></noscript>

  <link rel="icon" type="image/png" href={u('/logo/cie-logo.png')} />
  <link rel="apple-touch-icon" href={u('/logo/cie-logo.png')} />

  <!-- Slot for per-page structured data / additional head tags -->
  <slot name="head" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <WhatsAppButton />
</body>
</html>
