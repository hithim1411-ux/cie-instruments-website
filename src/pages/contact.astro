---
import Base from '../layouts/Base.astro';
import EyebrowLabel from '../components/EyebrowLabel.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import site from '../data/site.json';

const productParam = Astro.url.searchParams?.get('product') ?? '';
const sent = Astro.url.searchParams?.get('sent') === '1';
---

<Base
  title="Contact & Get a Quote"
  description="Contact Cambridge Instruments & Engg. Co. — enquire about insulation testers, relay test sets, oil BDV testers, and more. Works: Howrah. Office: Kolkata."
>
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'Contact' }]} />
      <EyebrowLabel text="Contact · Get a Quote" class="mt-4 mb-3" />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">Contact Us</h1>
      <p class="mt-2 text-[#64748B] max-w-2xl">
        Enquire about any instrument in the CIE range. We respond within one business day.
        WhatsApp is the fastest channel for a quick query.
      </p>
    </div>
  </div>

  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Contact details -->
        <div class="space-y-8">
          <!-- WhatsApp highlight -->
          <div class="bg-[#F5F7FA] rounded-xl border border-[#E8ECF2] p-6">
            <h2 class="font-bold text-[#0D2547] mb-3">Fastest: WhatsApp</h2>
            <p class="text-sm text-[#64748B] mb-4">Send your requirement directly. We respond promptly.</p>
            <a
              href={`https://wa.me/${site.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full px-5 py-3 rounded font-semibold text-sm transition-colors text-white"
              style="background-color: #25D366;"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chat on WhatsApp
            </a>
          </div>

          <!-- Addresses -->
          {site.addresses.map(addr => (
            <div>
              <h3 class="text-xs font-mono font-semibold text-[#E0252E] uppercase tracking-widest mb-2">{addr.type}</h3>
              <address class="not-italic text-sm text-[#64748B] leading-relaxed">
                {addr.lines.map(line => <span class="block">{line}</span>)}
              </address>
            </div>
          ))}

          <!-- Phone -->
          <div>
            <h3 class="text-xs font-mono font-semibold text-[#E0252E] uppercase tracking-widest mb-2">Phone</h3>
            {site.phones.map(p => (
              <p class="text-sm text-[#64748B]">
                <span class="text-[#b0bec5] text-xs">{p.label}: </span>
                <a href={`tel:${p.number.replace(/\s/g,'')}`} class="hover:text-[#1B3A5B] transition-colors">{p.number}</a>
              </p>
            ))}
          </div>

          <!-- Email -->
          <div>
            <h3 class="text-xs font-mono font-semibold text-[#E0252E] uppercase tracking-widest mb-2">Email</h3>
            <a href={`mailto:${site.email}`} class="text-sm text-[#64748B] hover:text-[#1B3A5B] transition-colors">{site.email}</a>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-2">
          {sent && (
            <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-sm text-green-800 font-medium">
              Thank you — your enquiry has been sent. We will respond within one business day.
            </div>
          )}
          <EnquiryForm productName={productParam} />
        </div>
      </div>
    </div>
  </section>
</Base>
