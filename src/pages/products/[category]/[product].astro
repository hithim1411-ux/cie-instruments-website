---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import EyebrowLabel from '../../../components/EyebrowLabel.astro';
import SpecTable from '../../../components/SpecTable.astro';
import CTABand from '../../../components/CTABand.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import categories from '../../../data/categories.json';
import products from '../../../data/products.json';
import site from '../../../data/site.json';

export async function getStaticPaths() {
  return products.map(p => {
    const category = categories.find(c => c.id === p.categoryId)!;
    return {
      params: { category: p.categoryId, product: p.id },
      props: { product: p, category },
    };
  });
}

const { product, category } = Astro.props;

const waMsg = encodeURIComponent(`Hi, I'd like to enquire about the ${product.model} — ${product.name}. Please send me a quote.`);

const isVartech = (product as any).brand === 'vartech';

// Support images array (multiple images) or fall back to single image / default
const productImages: string[] = (() => {
  const imgs = (product as any).images as string[] | undefined;
  if (imgs && imgs.length > 0) {
    return imgs.map(img => isVartech ? u(`/images/${img}`) : u(`/images/products/${img}`));
  }
  if (product.image) {
    return [isVartech ? u(`/images/${product.image}`) : u(`/images/products/${product.image}`)];
  }
  return [u(`/images/products/${product.id}.webp`)];
})();
const productImageSrc = productImages[0];

// Build product-specific mailto
const quoteSubject = `Quote Request — ${product.model}`;
const quoteBody    = `Hello CIE team,\n\nI would like to request a quote for: ${product.model} — ${product.name}.\n\nRequired rated voltage / resistance range:\nQuantity:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.`;
const quoteMailto  = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent(quoteSubject)}&body=${encodeURIComponent(quoteBody)}`;

// Product structured data for Google
const productImageAbsolute = `https://cieinstruments.in/images/products/${product.image ?? product.id + '.webp'}`;
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${product.model} — ${product.name}`,
  description: product.tagline,
  image: productImageAbsolute,
  brand: {
    '@type': 'Brand',
    name: 'CIE',
  },
  manufacturer: {
    '@type': 'Organization',
    '@id': 'https://cieinstruments.in/#organization',
    name: 'Cambridge Instruments & Engg. Co.',
  },
  model: product.model,
  countryOfOrigin: 'IN',
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: `https://cieinstruments.in/products/${product.categoryId}/${product.id}/`,
    seller: { '@id': 'https://cieinstruments.in/#organization' },
  },
  ...(product.specs && product.specs.length > 0 && {
    additionalProperty: product.specs.map((s: { label: string; value: string }) => ({
      '@type': 'PropertyValue',
      name: s.label,
      value: s.value,
    })),
  }),
};

const autoTitle = `${product.model} — ${product.name}`;
const autoDesc  = `${product.model} ${product.name} — ${product.tagline} Manufactured by Cambridge Instruments & Engg. Co., Howrah, India. 12-month warranty.`;
const pageTitle       = (product as any).metaTitle ?? autoTitle;
const pageDescription = (product as any).metaDesc  ?? autoDesc;
const useRawTitle     = !!(product as any).metaTitle;
---

<Base
  title={pageTitle}
  description={pageDescription}
  rawTitle={useRawTitle}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <!-- Page header -->
  <div class={isVartech ? 'bg-emerald-50 border-b border-emerald-200 py-10' : 'bg-[#F5F7FA] border-b border-[#E8ECF2] py-10'}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[
        { label: 'Products', href: '/products' },
        { label: category.name, href: `/products/${category.id}` },
        { label: product.model },
      ]} />
      {isVartech ? (
        <div class="mt-4 mb-3 flex items-center gap-3">
          <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech" width="90" class="object-contain" />
          <span class="px-2.5 py-1 bg-emerald-600 text-white text-xs font-bold rounded-full">CIE Authorised Dealer</span>
        </div>
      ) : (
        <EyebrowLabel text={category.eyebrow} class="mt-4 mb-3" />
      )}
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">
        <span class="model-code text-xl block mb-1">{product.model}</span>
        {product.name}
      </h1>
      <p class="mt-3 text-[#64748B] max-w-2xl">{product.tagline}</p>
    </div>
  </div>

  <!-- Main content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- ── Left sidebar: image + CTAs + trust ── -->
      <div class="lg:col-span-1">

        <!-- Product image / gallery -->
        {!product.hideImage && (
          <div>
            <div class="bg-[#F5F7FA] border border-[#E8ECF2] rounded-xl overflow-hidden mb-3">
              <img
                id="gallery-main"
                src={productImageSrc}
                alt={`${product.model} — ${product.name}`}
                width="600"
                height="600"
                class="w-full object-contain h-64 lg:h-72 p-4"
                loading="eager"
                onerror="this.style.opacity='0.15'"
              />
            </div>
            {productImages.length > 1 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {productImages.map((src, i) => (
                  <button
                    type="button"
                    data-src={src}
                    data-alt={`${product.model} — image ${i + 1}`}
                    class:list={['gallery-thumb w-16 h-16 rounded-lg border-2 overflow-hidden bg-[#F5F7FA] transition-all', i === 0 ? 'border-[#1B3A5B]' : 'border-[#E8ECF2] hover:border-[#1B3A5B]/50']}
                    aria-label={`View image ${i + 1}`}
                  >
                    <img src={src} alt="" aria-hidden="true" width="64" height="64" class="w-full h-full object-contain p-1" loading="lazy" />
                  </button>
                ))}
              </div>
            )}
          </div>
        )}

        <!-- CTAs -->
        <div class="space-y-3">
          <a
            href={quoteMailto}
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-[#E0252E] hover:bg-[#D72631] text-white font-bold rounded transition-colors text-sm"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Request a Quote
          </a>
          <a
            href={`https://wa.me/${site.whatsapp}?text=${waMsg}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-[#25D366] text-[#1a6e38] hover:bg-[#25D366]/10 font-semibold rounded transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enquire on WhatsApp
          </a>
        </div>

        <!-- Trust signals -->
        <div class="mt-6 bg-[#F5F7FA] rounded-lg p-4 border border-[#E8ECF2]">
          <p class="text-xs font-mono font-bold text-[#0D2547] uppercase tracking-widest mb-3">CIE® Guarantee</p>
          <ul class="space-y-2">
            {['CIE® Registered Trade Mark', 'Calibrated Before Despatch', '12-Month Warranty', 'Made in India', 'Custom Ranges Available'].map(f => (
              <li class="flex items-center gap-2 text-xs text-[#475569]">
                <span class="w-1.5 h-1.5 rounded-full bg-[#E0252E] shrink-0"></span>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- ── Right: full product info ── -->
      <div class="lg:col-span-2 space-y-10">

        <!-- 1. Description -->
        <div>
          <h2 class="text-xl font-bold text-[#0D2547] mb-3">About This Instrument</h2>
          <p class="text-[#64748B] leading-relaxed">{product.description}</p>
        </div>

        <!-- 1b. Key Features (optional) -->
        {product.features && (product.features as string[]).length > 0 && (
          <div>
            <h2 class="text-xl font-bold text-[#0D2547] mb-4">Key Features</h2>
            <ul class="space-y-2">
              {(product.features as string[]).map((f: string) => (
                <li class="flex items-start gap-3 text-sm text-[#64748B]">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#1B3A5B] shrink-0"></span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- 2. Technical Specifications -->
        <div>
          <h2 class="text-xl font-bold text-[#0D2547] mb-4">Technical Specifications</h2>
          <SpecTable specs={product.specs} />

          <!-- Build-to-order notice -->
          {product.buildToOrder && product.orderNote && (
            <div class="mt-5 flex gap-3 bg-[#FFF8E7] border border-[#E0252E]/30 rounded-lg p-4">
              <span class="shrink-0 text-[#E0252E] mt-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold text-[#E0252E] uppercase tracking-wide mb-0.5">Build to Order</p>
                <p class="text-sm text-[#1B3A5B]">{product.orderNote}</p>
              </div>
            </div>
          )}

          <!-- Ordering combination / capability tables -->
          {product.specTables && (product.specTables as any[]).map((table: any) => (
            <div class="mt-6">
              {table.heading && (
                <h3 class="text-sm font-bold text-[#0D2547] uppercase tracking-wide mb-3">{table.heading}</h3>
              )}
              <div class="overflow-x-auto rounded border border-[#E8ECF2]">
                <table class="spec-table w-full text-left border-collapse">
                  <thead>
                    <tr>
                      {(table.columns as string[]).map((col: string) => (
                        <th>{col}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {(table.rows as any[]).map((row: any) => (
                      <tr>
                        {(table.columns as string[]).map((_: string, i: number) => (
                          <td class:list={[
                            row[`col${i}`] === 'N.A.' && 'text-[#94a3b8] italic',
                            row[`col${i}`] === '✓'    && 'text-[#16a34a] font-bold text-center',
                          ]}>
                            {row[`col${i}`]}
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              {table.note && (
                <p class="mt-2 text-xs text-[#64748B] italic">{table.note}</p>
              )}
            </div>
          ))}

          <!-- Additional ordering options -->
          {product.options && (product.options as string[]).length > 0 && (
            <div class="mt-5 bg-[#F5F7FA] rounded-lg border border-[#E8ECF2] p-4">
              <p class="text-xs font-bold text-[#0D2547] uppercase tracking-wide mb-2">Additional Options</p>
              <ul class="space-y-1.5">
                {(product.options as string[]).map((opt: string) => (
                  <li class="flex items-start gap-2 text-sm text-[#64748B]">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#E0252E] shrink-0"></span>
                    {opt}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- 3. What's Included (kit / accessories) -->
        {product.includedWith && (product.includedWith as string[]).length > 0 && (
          <div>
            <h2 class="text-xl font-bold text-[#0D2547] mb-4">What's Included</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {(product.includedWith as string[]).map((item: string) => (
                <li class="flex items-start gap-2.5 text-sm text-[#64748B] bg-[#F5F7FA] border border-[#E8ECF2] rounded-lg px-4 py-2.5">
                  <span class="mt-1 w-1.5 h-1.5 rounded-full bg-[#1B3A5B] shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- 4. Applications -->
        {product.applications && product.applications.length > 0 && (
          <div>
            <h2 class="text-xl font-bold text-[#0D2547] mb-4">Key Applications</h2>
            <ul class="space-y-2">
              {product.applications.map((app: string) => (
                <li class="flex items-start gap-3 text-sm text-[#64748B]">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#E0252E] shrink-0"></span>
                  {app}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- 5. Warranty & after-sales -->
        <div class="bg-[#F5F7FA] border-l-4 border-[#1B3A5B] rounded-r-lg p-5">
          <p class="text-sm text-[#1B3A5B] font-semibold mb-1">12-Month Warranty · Direct After-Sales Support</p>
          <p class="text-sm text-[#64748B]">
            Every CIE® instrument carries a 12-month warranty against manufacturing defects.
            After-sales support is handled directly by CIE — not a distributor network.
            Non-standard ranges or custom specifications can be manufactured to your requirement.
          </p>
        </div>

      </div>
    </div>
  </div>

  <script>
  {
    const mainImg = document.getElementById('gallery-main') as HTMLImageElement | null;
    const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');
    thumbs.forEach(btn => {
      btn.addEventListener('click', () => {
        if (!mainImg) return;
        mainImg.src = btn.dataset.src ?? '';
        mainImg.alt = btn.dataset.alt ?? '';
        thumbs.forEach(t => t.classList.replace('border-[#1B3A5B]', 'border-[#E8ECF2]'));
        btn.classList.replace('border-[#E8ECF2]', 'border-[#1B3A5B]');
      });
    });
  }
  </script>

  <CTABand
    heading={`Interested in the ${product.model}? Get a quote by email.`}
    body="Email us with your model, quantity, and specification — we respond within one business day."
    primaryLabel="Request a Quote"
    primaryHref={quoteMailto}
    secondaryLabel="Back to Products"
    secondaryHref={u(`/products/${category.id}/`)}
  />
</Base>
