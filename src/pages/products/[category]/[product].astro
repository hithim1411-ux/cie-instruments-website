---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import EyebrowLabel from '../../../components/EyebrowLabel.astro';
import SpecTable from '../../../components/SpecTable.astro';
import CTABand from '../../../components/CTABand.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import categories from '../../../data/categories.json';
import products from '../../../data/products.json';
import site from '../../../data/site.json';

export async function getStaticPaths() {
  return products.map(p => {
    const category = categories.find(c => c.id === p.categoryId)!;
    return {
      params: { category: p.categoryId, product: p.id },
      props: { product: p, category },
    };
  });
}

const { product, category } = Astro.props;

const waMsg = encodeURIComponent(`Hi, I'd like to enquire about the ${product.model} — ${product.name}. Please send me a quote.`);
const productImageSrc = product.image
  ? u(`/images/products/${product.image}`)
  : u(`/images/products/${product.id}.jpg`);
---

<Base
  title={`${product.model} — ${product.name}`}
  description={`${product.model} ${product.name} — ${product.tagline} CIE instruments, Howrah.`}
>
  <!-- Header -->
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[
        { label: 'Products', href: '/products' },
        { label: category.name, href: `/products/${category.id}` },
        { label: product.model },
      ]} />
      <EyebrowLabel text={category.eyebrow} class="mt-4 mb-3" />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">
        <span class="model-code text-xl block mb-1">{product.model}</span>
        {product.name}
      </h1>
      <p class="mt-3 text-[#64748B] max-w-2xl">{product.tagline}</p>
    </div>
  </div>

  <!-- Main content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Left: image + CTAs -->
      <div class="lg:col-span-1">
        <!-- Product image (hidden for products with hideImage flag) -->
        {!product.hideImage && (
          <div class="bg-[#F5F7FA] border border-[#E8ECF2] rounded-xl h-64 lg:h-80 flex items-center justify-center mb-6 overflow-hidden">
            <img
              src={productImageSrc}
              alt={`${product.model} — ${product.name}`}
              class="object-contain max-h-full max-w-full p-4"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
            />
            <div class="hidden flex-col items-center justify-center text-[#b0bec5] gap-2">
              <svg class="w-16 h-16 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/>
                <path d="M3 9l4-4 4 4 4-4 4 4" stroke-width="1.5"/>
              </svg>
              <span class="text-xs font-mono uppercase tracking-widest opacity-40">Image coming soon</span>
            </div>
          </div>
        )}

        <!-- CTAs -->
        <div class="space-y-3">
          <a
            href={u(`/contact?product=${encodeURIComponent(product.model)}`)}
            class="w-full flex items-center justify-center px-6 py-3.5 bg-[#E0252E] hover:bg-[#D72631] text-white font-bold rounded transition-colors text-sm"
          >
            Request a Quote
          </a>
          <a
            href={`https://wa.me/${site.whatsapp}?text=${waMsg}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-[#25D366] text-[#1a6e38] hover:bg-[#25D366]/10 font-semibold rounded transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enquire on WhatsApp
          </a>
          {product.datasheet ? (
            <a
              href={product.datasheet}
              download
              class="w-full flex items-center justify-center gap-2 px-6 py-3 border border-[#E8ECF2] text-[#64748B] hover:text-[#1B3A5B] hover:border-[#1B3A5B] rounded transition-colors text-sm"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
              </svg>
              Download Datasheet (PDF)
            </a>
          ) : (
            <p class="text-xs text-center text-[#b0bec5] font-mono">Datasheet available on request</p>
          )}
        </div>

        <!-- Trust signals -->
        <div class="mt-6 bg-[#F5F7FA] rounded-lg p-4 border border-[#E8ECF2]">
          <ul class="space-y-2">
            {['CIE® Registered Mark', 'Calibrated Before Despatch', '12-Month Warranty', 'Made in India', 'Custom Ranges Available'].map(f => (
              <li class="flex items-center gap-2 text-xs text-[#64748B]">
                <span class="w-1.5 h-1.5 rounded-full bg-[#E0252E] shrink-0"></span>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Right: description, specs, applications -->
      <div class="lg:col-span-2 space-y-10">

        <!-- Description -->
        <div>
          <h2 class="text-xl font-bold text-[#0D2547] mb-4">About This Instrument</h2>
          <p class="text-[#64748B] leading-relaxed">{product.description}</p>
        </div>

        <!-- Specifications -->
        <div>
          <h2 class="text-xl font-bold text-[#0D2547] mb-4">Technical Specifications</h2>
          <SpecTable specs={product.specs} />

          <!-- Build-to-order note (shown before ordering tables) -->
          {product.buildToOrder && product.orderNote && (
            <div class="mt-5 flex gap-3 bg-[#FFF8E7] border border-[#E0252E]/30 rounded-lg p-4">
              <span class="shrink-0 text-[#E0252E] mt-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold text-[#E0252E] uppercase tracking-wide mb-0.5">Build to Order</p>
                <p class="text-sm text-[#1B3A5B]">{product.orderNote}</p>
              </div>
            </div>
          )}

          <!-- Spec tables (ordering combinations / capability tables) -->
          {product.specTables && (product.specTables as any[]).map((table: any) => (
            <div class="mt-6">
              {table.heading && (
                <h3 class="text-sm font-bold text-[#0D2547] uppercase tracking-wide mb-3">{table.heading}</h3>
              )}
              <div class="overflow-x-auto rounded border border-[#E8ECF2]">
                <table class="spec-table w-full text-left border-collapse">
                  <thead>
                    <tr>
                      {(table.columns as string[]).map((col: string) => (
                        <th>{col}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {(table.rows as any[]).map((row: any) => (
                      <tr>
                        {(table.columns as string[]).map((_: string, i: number) => (
                          <td class:list={[
                            row[`col${i}`] === 'N.A.' && 'text-[#94a3b8] italic',
                            row[`col${i}`] === '✓' && 'text-[#16a34a] font-bold text-center',
                          ]}>
                            {row[`col${i}`]}
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              {table.note && (
                <p class="mt-2 text-xs text-[#64748B] italic">{table.note}</p>
              )}
            </div>
          ))}

          <!-- Additional ordering options (e.g. CIE/444, CIE/666) -->
          {product.options && (product.options as string[]).length > 0 && (
            <div class="mt-5 bg-[#F5F7FA] rounded-lg border border-[#E8ECF2] p-4">
              <p class="text-xs font-bold text-[#0D2547] uppercase tracking-wide mb-2">Additional Options</p>
              <ul class="space-y-1.5">
                {(product.options as string[]).map((opt: string) => (
                  <li class="flex items-start gap-2 text-sm text-[#64748B]">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#E0252E] shrink-0"></span>
                    {opt}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Applications -->
        {product.applications && product.applications.length > 0 && (
          <div>
            <h2 class="text-xl font-bold text-[#0D2547] mb-4">Key Applications</h2>
            <ul class="space-y-2">
              {product.applications.map((app: string) => (
                <li class="flex items-start gap-3 text-sm text-[#64748B]">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#E0252E] shrink-0"></span>
                  {app}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Warranty / note -->
        <div class="bg-[#F5F7FA] border-l-4 border-[#1B3A5B] rounded-r-lg p-5">
          <p class="text-sm text-[#1B3A5B] font-semibold mb-1">12-Month Warranty</p>
          <p class="text-sm text-[#64748B]">
            This instrument is covered by CIE's standard 12-month warranty against manufacturing defects.
            Non-standard ranges or custom specifications can be manufactured to your requirement — please contact us.
          </p>
        </div>
      </div>
    </div>
  </div>

  <CTABand
    heading={`Interested in the ${product.model}? Request a quote today.`}
    primaryLabel="Request a Quote"
    primaryHref={u(`/contact?product=${encodeURIComponent(product.model)}`)}
    secondaryLabel="Back to Products"
    secondaryHref={u(`/products/${category.id}`)}
  />
</Base>
