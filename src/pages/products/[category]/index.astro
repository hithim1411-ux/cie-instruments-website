---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import EyebrowLabel from '../../../components/EyebrowLabel.astro';
import ProductCard from '../../../components/ProductCard.astro';
import CTABand from '../../../components/CTABand.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import categories from '../../../data/categories.json';
import products from '../../../data/products.json';
import vartechMultimeters from '../../../data/vartech-multimeters.json';
import vartechClampMeters from '../../../data/vartech-clamp-meters.json';
import vartechOscilloscopes from '../../../data/vartech-oscilloscopes.json';
import vartechFunctionGenerators from '../../../data/vartech-function-generators.json';
import vartechLcrMeters from '../../../data/vartech-lcr-meters.json';
import vartechDcLoads from '../../../data/vartech-dc-loads.json';
import vartechSoundLevelMeters from '../../../data/vartech-sound-level-meters.json';
import vartechAnemometers from '../../../data/vartech-anemometers.json';
import vartechCalibrators from '../../../data/vartech-calibrators.json';
import vartechLuxMeters from '../../../data/vartech-lux-meters.json';
import vartechThermometers from '../../../data/vartech-thermometers.json';
import vartechDcPowerSupplies from '../../../data/vartech-dc-power-supplies.json';
import site from '../../../data/site.json';

const vartechDataMap: Record<string, any[]> = {
  'vartech-multimeters':          vartechMultimeters,
  'vartech-clamp-meters':         vartechClampMeters,
  'vartech-oscilloscopes':        vartechOscilloscopes,
  'vartech-function-generators':  vartechFunctionGenerators,
  'vartech-lcr-meters':           vartechLcrMeters,
  'vartech-dc-loads':             vartechDcLoads,
  'vartech-sound-level-meters':   vartechSoundLevelMeters,
  'vartech-anemometers':          vartechAnemometers,
  'vartech-calibrators':          vartechCalibrators,
  'vartech-lux-meters':           vartechLuxMeters,
  'vartech-thermometers':         vartechThermometers,
  'vartech-dc-power-supplies':   vartechDcPowerSupplies,
};

export async function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const catProducts = products.filter(p => p.categoryId === category.id);

const vartechEquivalents = (category as any).vartechEquivalents as
  { categoryId: string; label: string; slug: string }[] | undefined;

// Build Vartech sections for combined-brand pages
const vartechSections = (vartechEquivalents ?? []).map(eq => ({
  label: eq.label,
  slug:  eq.slug,
  items: vartechDataMap[eq.categoryId] ?? [],
}));

// For pure Vartech brand pages (oscilloscopes, function-generators, etc.) — load products directly
const isVartechBrand  = (category as any).brand === 'vartech';
const brandSlug       = category.id.replace('vartech-', '');
const vartechItems    = isVartechBrand ? (vartechDataMap[category.id] ?? []) : [];

const pageTitle       = (category as any).metaTitle  ?? `${category.name} | CIE Instruments`;
const pageDescription = (category as any).metaDesc   ?? `${category.name} — ${category.description} CIE instruments, manufactured in Howrah since 1963.`;
const seoContent      = (category as any).seoContent as string[] | undefined;
const isCombined      = vartechSections.length > 0;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: category.name,
  description: category.description,
  url: `https://cieinstruments.in/products/${category.id}/`,
  numberOfItems: isCombined
    ? catProducts.length + vartechSections.reduce((s: number, sec: any) => s + sec.items.length, 0)
    : isVartechBrand
      ? vartechItems.length
      : catProducts.length,
  itemListElement: [
    ...(isCombined || !isVartechBrand ? catProducts.map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://cieinstruments.in/products/${p.categoryId}/${p.id}/`,
      name: `${p.model} — ${p.name}`,
    })) : []),
    ...(isCombined
      ? vartechSections.flatMap((sec: any, si: number) =>
          sec.items.map((p: any, pi: number) => ({
            '@type': 'ListItem',
            position: catProducts.length + (si * 100) + pi + 1,
            url: `https://cieinstruments.in/authorised-dealership/${sec.slug}/${p.id}/`,
            name: `Vartech ${p.model} — ${p.name}`,
          }))
        )
      : isVartechBrand
        ? vartechItems.map((p: any, i: number) => ({
            '@type': 'ListItem',
            position: i + 1,
            url: `https://cieinstruments.in/authorised-dealership/${brandSlug}/${p.id}/`,
            name: `Vartech ${p.model} — ${p.name}`,
          }))
        : []),
  ],
};

const categoryFaqs = (category as any).faq as { q: string; a: string }[] | undefined;
const faqSchema = categoryFaqs && categoryFaqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: categoryFaqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const catKeywords = [category.name, ...(categoryFaqs?.map(f => f.q) ?? [])].join(', ');
---

<Base title={pageTitle} description={pageDescription} rawTitle={(category as any).metaTitle != null} keywords={catKeywords}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  {faqSchema && <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <!-- Page header -->
  <div class={(category as any).brand === 'vartech' ? 'bg-emerald-50 border-b border-emerald-200 py-10' : 'bg-[#F5F7FA] border-b border-[#E8ECF2] py-10'}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'Products', href: '/products' }, { label: category.name }]} />

      {(category as any).brand === 'vartech' ? (
        <div class="mt-4 mb-3 flex items-center gap-3">
          <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech" width="90" class="object-contain" />
          <span class="px-2.5 py-1 bg-emerald-600 text-white text-xs font-bold rounded-full">Authorised Dealer</span>
        </div>
      ) : (
        <EyebrowLabel text={category.eyebrow} class="mt-4 mb-3" />
      )}

      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">{category.name}</h1>
      <p class="mt-3 text-[#64748B] max-w-2xl leading-relaxed">{category.description}</p>

      {isCombined && (
        <div class="mt-4 flex items-center gap-2 flex-wrap">
          <span class="text-xs text-[#64748B]">Available from:</span>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-[#0D2547] text-white text-xs font-bold rounded-full">
            <img src={u('/logo/cie-logo-light.png')} alt="CIE" class="h-3 w-auto" /> CIE — Manufactured
          </span>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-600 text-white text-xs font-bold rounded-full">
            <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech" class="h-3 w-auto" /> Vartech — Authorised Dealer
          </span>
        </div>
      )}
    </div>
  </div>

  {isCombined ? (
    /* ── COMBINED BRAND PAGE ────────────────────────────────────────────────── */
    <div>
      <!-- CIE section -->
      <section class="bg-white py-12 lg:py-16 border-b border-[#E8ECF2]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-4 mb-8">
            <img src={u('/logo/cie-logo.png')} alt="CIE®" width="32" height="32" class="object-contain" />
            <div>
              <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-[#E0252E] mb-0.5">Cambridge Instruments & Engg. Co.</div>
              <h2 class="text-lg font-bold text-[#0D1B2A]">CIE Manufactured — {catProducts.length} {catProducts.length === 1 ? 'instrument' : 'instruments'}</h2>
            </div>
          </div>
          <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-2 -mx-4 px-4 sm:mx-0 sm:px-0 sm:pb-0 sm:overflow-visible sm:grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 sm:gap-5"
            style="scrollbar-width:none; -ms-overflow-style:none;">
            {catProducts.map(p => (
              <div class="shrink-0 snap-start w-[75vw] sm:w-auto">
                <ProductCard model={p.model} name={p.name} tagline={p.tagline}
                  categoryId={p.categoryId} id={p.id} featured={p.featured}
                  image={p.image} hideImage={p.hideImage} />
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Vartech sections -->
      {vartechSections.map((sec, si) => {
        const isLast = si === vartechSections.length - 1;
        return (
          <section class={`py-12 lg:py-16 ${isLast ? '' : 'border-b border-emerald-100'}`}
            style="background: linear-gradient(to bottom, #f0fdf4, #fff);">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <div class="flex items-center justify-between mb-8 gap-4 flex-wrap">
                <div class="flex items-center gap-4">
                  <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech®" width="90" height="32" class="object-contain" />
                  <div>
                    <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-emerald-600 mb-0.5">Authorised Dealer</div>
                    <h2 class="text-lg font-bold text-[#0D1B2A]">Vartech {sec.label} — {sec.items.length} models</h2>
                  </div>
                </div>
                <a href={u(`/authorised-dealership/${sec.slug}/`)}
                  class="text-xs font-semibold text-emerald-600 hover:text-emerald-800 transition-colors shrink-0">
                  Browse full {sec.label} range →
                </a>
              </div>

              <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-2 -mx-4 px-4 sm:mx-0 sm:px-0 sm:pb-0 sm:overflow-visible sm:grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 sm:gap-5"
                style="scrollbar-width:none; -ms-overflow-style:none;">
                {sec.items.map((p: any) => {
                  const waMsg = encodeURIComponent(`Hi, I'd like to enquire about the Vartech ${p.model} — ${p.name}`);
                  const imgSlug = p.images?.[0] ?? `${p.id}.webp`;
                  return (
                    <div class="shrink-0 snap-start w-[75vw] sm:w-auto">
                      <article class="bg-white rounded-lg border-2 border-emerald-100 overflow-hidden flex flex-col hover:shadow-md hover:border-emerald-400 transition-all duration-200">
                        <div class="bg-[#F5F7FA] border-b border-emerald-100 h-44 flex items-center justify-center relative">
                          <img
                            src={u(`/images/vartech/${sec.slug}/${imgSlug}`)}
                            alt={`${p.model} — ${p.name}`}
                            width="300" height="300"
                            class="object-contain h-36 w-auto"
                            loading="lazy"
                            onerror="this.style.display='none'"
                          />
                          <span class="absolute top-2 left-2 text-[9px] font-mono font-bold uppercase tracking-widest text-emerald-700 bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 rounded">
                            Vartech®
                          </span>
                        </div>
                        <div class="p-4 flex flex-col flex-1">
                          <p class="text-[11px] font-mono text-emerald-600 mb-0.5">{p.model}</p>
                          <h3 class="font-bold text-[#0D2547] text-sm leading-snug mb-2">{p.name}</h3>
                          <p class="text-xs text-[#64748B] mb-4 flex-1 line-clamp-3">{p.tagline ?? p.description}</p>
                          <div class="flex flex-col gap-2 mt-auto">
                            <a href={u(`/authorised-dealership/${sec.slug}/${p.id}/`)}
                              class="text-center px-3 py-2 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-xs font-semibold rounded transition-colors">
                              View Specifications
                            </a>
                            <a href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent(`Hi, I'd like to enquire about the Vartech ${p.model} — ${p.name}`)}`}
                              target="_blank" rel="noopener noreferrer"
                              class="text-center px-3 py-2 border border-[#25D366] text-[#1a6e38] hover:bg-[#25D366]/10 text-xs font-medium rounded transition-colors">
                              Enquire on WhatsApp
                            </a>
                          </div>
                        </div>
                      </article>
                    </div>
                  );
                })}
              </div>
            </div>
          </section>
        );
      })}
    </div>
  ) : (
    /* ── SINGLE BRAND PAGE ───────────────────────────────────────────────────── */
    <section class={`py-12 lg:py-16 ${isVartechBrand ? '' : 'bg-white'}`}
      style={isVartechBrand ? 'background: linear-gradient(to bottom, #f0fdf4, #fff)' : ''}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {isVartechBrand ? (
          <div class="flex items-center justify-between mb-8 gap-4 flex-wrap">
            <div class="flex items-center gap-4">
              <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech®" width="90" height="32" class="object-contain" />
              <h2 class="text-lg font-bold text-[#0D1B2A]">{vartechItems.length} models</h2>
            </div>
            <a href={u('/products/')} class="text-sm text-[#64748B] hover:text-[#1B3A5B] transition-colors">← All products</a>
          </div>
        ) : (
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-lg font-bold text-[#0D2547]">{catProducts.length} {catProducts.length === 1 ? 'instrument' : 'instruments'} in this category</h2>
            <a href={u('/products/')} class="text-sm text-[#64748B] hover:text-[#1B3A5B] transition-colors">← All products</a>
          </div>
        )}

        {isVartechBrand ? (
          <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-2 -mx-4 px-4 sm:mx-0 sm:px-0 sm:pb-0 sm:overflow-visible sm:grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 sm:gap-5"
            style="scrollbar-width:none; -ms-overflow-style:none;">
            {vartechItems.map((p: any) => {
              const imgFile = p.images?.[0] ?? `${p.id}.webp`;
              return (
                <div class="shrink-0 snap-start w-[75vw] sm:w-auto">
                  <article class="bg-white rounded-lg border-2 border-emerald-100 overflow-hidden flex flex-col hover:shadow-md hover:border-emerald-400 transition-all duration-200">
                    <div class="bg-[#F5F7FA] border-b border-emerald-100 h-44 flex items-center justify-center relative">
                      <img src={u(`/images/vartech/${brandSlug}/${imgFile}`)}
                        alt={`${p.model} — ${p.name}`} width="300" height="300"
                        class="object-contain h-36 w-auto" loading="lazy"
                        onerror="this.style.display='none'" />
                      <span class="absolute top-2 left-2 text-[9px] font-mono font-bold uppercase tracking-widest text-emerald-700 bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 rounded">
                        Vartech®
                      </span>
                    </div>
                    <div class="p-4 flex flex-col flex-1">
                      <p class="text-[11px] font-mono text-emerald-600 mb-0.5">{p.model}</p>
                      <h3 class="font-bold text-[#0D2547] text-sm leading-snug mb-2">{p.name}</h3>
                      <p class="text-xs text-[#64748B] mb-4 flex-1 line-clamp-3">{p.tagline ?? p.description}</p>
                      <div class="flex flex-col gap-2 mt-auto">
                        <a href={u(`/authorised-dealership/${brandSlug}/${p.id}/`)}
                          class="text-center px-3 py-2 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-xs font-semibold rounded transition-colors">
                          View Specifications
                        </a>
                        <a href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent(`Hi, I'd like to enquire about the Vartech ${p.model} — ${p.name}`)}`}
                          target="_blank" rel="noopener noreferrer"
                          class="text-center px-3 py-2 border border-[#25D366] text-[#1a6e38] hover:bg-[#25D366]/10 text-xs font-medium rounded transition-colors">
                          Enquire on WhatsApp
                        </a>
                      </div>
                    </div>
                  </article>
                </div>
              );
            })}
          </div>
        ) : (
          <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-2 -mx-4 px-4 sm:mx-0 sm:px-0 sm:pb-0 sm:overflow-visible sm:grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 sm:gap-5"
            style="scrollbar-width:none; -ms-overflow-style:none;">
            {catProducts.map(p => (
              <div class="shrink-0 snap-start w-[75vw] sm:w-auto">
                <ProductCard model={p.model} name={p.name} tagline={p.tagline}
                  categoryId={p.categoryId} id={p.id} featured={p.featured}
                  image={p.image} hideImage={p.hideImage} />
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {categoryFaqs && categoryFaqs.length > 0 && (
    <section class="bg-white py-10 lg:py-14 border-t border-[#E8ECF2]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-[#0D2547] mb-6">Frequently Asked Questions</h2>
        <div class="space-y-5">
          {categoryFaqs.map(faq => (
            <details class="group border border-[#E8ECF2] rounded-lg overflow-hidden">
              <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer font-semibold text-[#0D2547] text-sm list-none hover:bg-[#F5F7FA] transition-colors">
                {faq.q}
                <svg class="w-4 h-4 shrink-0 text-[#64748B] group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-5 pb-5 pt-1 text-sm text-[#64748B] leading-relaxed border-t border-[#E8ECF2]">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SEO content block -->
  {seoContent && seoContent.length > 0 && (
    <section class="bg-[#F5F7FA] py-12 lg:py-16 border-t border-[#E8ECF2]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-[#0D2547] mb-6">About {category.name}</h2>
        <div class="space-y-4">
          {seoContent.map((para: string) => (
            <p class="text-sm text-[#64748B] leading-relaxed">{para}</p>
          ))}
        </div>
        <div class="mt-8 pt-6 border-t border-[#E8ECF2]">
          <p class="text-xs text-[#94a3b8]">
            Cambridge Instruments &amp; Engg. Co. (CIE) — manufacturer of precision electrical test and measurement instruments in Howrah, West Bengal, India, established 1963.
            Pan-India supply: Kolkata · Howrah · Bhubaneswar · Cuttack · Bangalore · Chennai · Hyderabad · Mumbai · Pune · Delhi · Ahmedabad · Lucknow · Chandigarh · Ranchi · Raipur · Visakhapatnam · Nagpur.
          </p>
        </div>
      </div>
    </section>
  )}

  <CTABand />
</Base>
