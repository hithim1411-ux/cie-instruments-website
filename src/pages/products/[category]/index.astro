---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import EyebrowLabel from '../../../components/EyebrowLabel.astro';
import ProductCard from '../../../components/ProductCard.astro';
import CTABand from '../../../components/CTABand.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import categories from '../../../data/categories.json';
import products from '../../../data/products.json';

export async function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const catProducts = products.filter(p => p.categoryId === category.id);

const pageTitle       = (category as any).metaTitle  ?? `${category.name} | CIE Instruments`;
const pageDescription = (category as any).metaDesc   ?? `${category.name} — ${category.description} CIE instruments, manufactured in Howrah since 1963.`;
const seoContent      = (category as any).seoContent as string[] | undefined;
---

<Base title={pageTitle} description={pageDescription} rawTitle={(category as any).metaTitle != null}>
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'Products', href: '/products' }, { label: category.name }]} />
      <EyebrowLabel text={category.eyebrow} class="mt-4 mb-3" />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">{category.name}</h1>
      <p class="mt-3 text-[#64748B] max-w-2xl leading-relaxed">{category.description}</p>
    </div>
  </div>

  <!-- Products grid -->
  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-lg font-bold text-[#0D2547]">{catProducts.length} {catProducts.length === 1 ? 'instrument' : 'instruments'} in this category</h2>
        <a href={u('/products/')} class="text-sm text-[#64748B] hover:text-[#1B3A5B] transition-colors">← All products</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {catProducts.map(p => (
          <ProductCard
            model={p.model}
            name={p.name}
            tagline={p.tagline}
            categoryId={p.categoryId}
            id={p.id}
            featured={p.featured}
            image={p.image}
            hideImage={p.hideImage}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- SEO content block -->
  {seoContent && seoContent.length > 0 && (
    <section class="bg-[#F5F7FA] py-12 lg:py-16 border-t border-[#E8ECF2]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-[#0D2547] mb-6">About {category.name}</h2>
        <div class="space-y-4">
          {seoContent.map((para: string) => (
            <p class="text-sm text-[#64748B] leading-relaxed">{para}</p>
          ))}
        </div>
        <div class="mt-8 pt-6 border-t border-[#E8ECF2]">
          <p class="text-xs text-[#94a3b8]">
            Cambridge Instruments &amp; Engg. Co. (CIE) — also known as Cambridge Instruments and Engineering Co. — is a manufacturer of precision electrical test and measurement instruments in Howrah, West Bengal, India, established 1963.
            Pan-India supply: Kolkata · Howrah · Bhubaneswar · Cuttack · Bangalore · Chennai · Hyderabad · Mumbai · Pune · Delhi · Ahmedabad · Lucknow · Chandigarh · Ranchi · Raipur · Visakhapatnam · Nagpur.
          </p>
        </div>
      </div>
    </section>
  )}

  <CTABand />
</Base>
