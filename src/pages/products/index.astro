---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import EyebrowLabel from '../../components/EyebrowLabel.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import CTABand from '../../components/CTABand.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import categories from '../../data/categories.json';
import products from '../../data/products.json';

const cieCategories = categories.filter((c: any) => !c.brand || c.brand === 'cie');
const vartechCategories = categories.filter((c: any) => c.brand === 'vartech');

const cieProducts = products.filter((p: any) => !p.brand || p.brand === 'cie');
const vartechProducts = products.filter((p: any) => p.brand === 'vartech');
---

<Base
  title="Products — CIE Instruments & Vartech | Test & Measurement, Howrah India"
  description="Complete product catalogue — CIE manufactured instruments (insulation testers, earth testers, relay test sets, oil BDV testers) and Vartech authorised dealership (oscilloscopes, function generators, LCR meters, DC loads). Howrah, Kolkata, India."
>
  <!-- Page header -->
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'Products' }]} />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547] mt-4">Products &amp; Instruments</h1>
      <p class="mt-2 text-[#64748B] max-w-2xl">
        CIE manufactured instruments since 1963 — and the complete Vartech range as authorised dealer. Contact us for pricing and availability.
      </p>
    </div>
  </div>

  <!-- ── CIE Brand Section ── -->
  <section class="bg-white py-12 lg:py-16 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- CIE brand header -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div class="flex items-center gap-4">
          <img src={u('/logo/cie-logo.png')} alt="CIE®" width="36" height="36" class="object-contain" />
          <div>
            <div class="text-[11px] font-mono uppercase tracking-[0.18em] text-[#E0252E] mb-0.5">Cambridge Instruments &amp; Engg. Co.</div>
            <h2 class="text-xl font-bold text-[#0D1B2A]">CIE Manufactured Instruments</h2>
          </div>
        </div>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-[#0D1B2A] text-white text-xs font-bold rounded-full">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Manufactured in Howrah since 1963
        </span>
      </div>

      <!-- CIE category grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 mb-4">
        {cieCategories.map(cat => {
          const count = products.filter((p: any) => p.categoryId === cat.id).length;
          return (
            <a href={u(`/products/${cat.id}/`)}
              class="group flex flex-col p-5 rounded-xl border border-gray-200 bg-white hover:border-[#1B3A5B] hover:shadow-md transition-all duration-200">
              <div class="flex items-start justify-between mb-3">
                <span class="text-2xl">{cat.icon}</span>
                <span class="text-[10px] font-mono text-gray-400">{count} {count === 1 ? 'model' : 'models'}</span>
              </div>
              <h3 class="font-bold text-[#0D1B2A] text-sm leading-snug group-hover:text-[#1B3A5B] transition-colors mb-1">{cat.shortName}</h3>
              <p class="text-xs text-gray-500 leading-relaxed flex-1">{cat.description.slice(0, 80)}…</p>
              <div class="mt-3 text-xs font-semibold text-[#1B3A5B] group-hover:underline">View range →</div>
            </a>
          );
        })}
      </div>
      <p class="text-xs text-[#94a3b8]">{cieProducts.length} CIE instruments across {cieCategories.length} categories</p>
    </div>
  </section>

  <!-- ── Vartech Brand Section ── -->
  <section class="py-12 lg:py-16" style="background: linear-gradient(to bottom, #f8f9fa, #fff);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Vartech brand header -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div class="flex items-center gap-4">
          <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech®" width="100" height="36" class="object-contain" />
          <div>
            <div class="text-[11px] font-mono uppercase tracking-[0.18em] text-[#E0252E] mb-0.5">Authorised Dealer</div>
            <h2 class="text-xl font-bold text-[#0D1B2A]">Vartech Instruments</h2>
          </div>
        </div>
        <div class="flex flex-col sm:items-end gap-1">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-600 text-white text-xs font-bold rounded-full">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            CIE Authorised Dealer
          </span>
          <a href={u('/authorised-dealership/')} class="text-xs text-[#E0252E] hover:underline">View dealership details →</a>
        </div>
      </div>

      <!-- Vartech category grid — distinct teal/dark teal colour scheme -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-4">
        {vartechCategories.map(cat => {
          const count = products.filter((p: any) => p.categoryId === cat.id).length;
          return (
            <a href={u(`/products/${cat.id}/`)}
              class="group flex flex-col p-5 rounded-xl border-2 border-emerald-100 bg-white hover:border-emerald-500 hover:shadow-md transition-all duration-200">
              <div class="flex items-start justify-between mb-3">
                <span class="text-2xl">{cat.icon}</span>
                <span class="text-[10px] font-mono text-gray-400">{count} {count === 1 ? 'model' : 'models'}</span>
              </div>
              <div class="text-[10px] font-mono uppercase tracking-widest text-emerald-600 mb-1">Vartech®</div>
              <h3 class="font-bold text-[#0D1B2A] text-sm leading-snug group-hover:text-emerald-700 transition-colors mb-1">{cat.shortName}</h3>
              <p class="text-xs text-gray-500 leading-relaxed flex-1">{cat.description.slice(0, 80)}…</p>
              <div class="mt-3 text-xs font-semibold text-emerald-600 group-hover:underline">View range →</div>
            </a>
          );
        })}
      </div>
      <p class="text-xs text-[#94a3b8]">{vartechProducts.length} Vartech instruments across {vartechCategories.length} categories · Also see <a href={u('/authorised-dealership/')} class="text-[#E0252E] hover:underline">Authorised Dealership</a> for multimeters and clamp meters</p>
    </div>
  </section>

  <CTABand />
</Base>
