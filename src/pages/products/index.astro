---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import CTABand from '../../components/CTABand.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import categories from '../../data/categories.json';
import products from '../../data/products.json';
import site from '../../data/site.json';
import vartechMultimeters from '../../data/vartech-multimeters.json';
import vartechClampMeters from '../../data/vartech-clamp-meters.json';
import vartechOscilloscopes from '../../data/vartech-oscilloscopes.json';
import vartechFunctionGenerators from '../../data/vartech-function-generators.json';
import vartechLcrMeters from '../../data/vartech-lcr-meters.json';
import vartechDcLoads from '../../data/vartech-dc-loads.json';
import vartechSoundLevelMeters from '../../data/vartech-sound-level-meters.json';
import vartechAnemometers from '../../data/vartech-anemometers.json';
import vartechCalibrators from '../../data/vartech-calibrators.json';
import vartechLuxMeters from '../../data/vartech-lux-meters.json';
import vartechThermometers from '../../data/vartech-thermometers.json';
import vartechDcPowerSupplies from '../../data/vartech-dc-power-supplies.json';

const cieCategories = categories.filter((c: any) => !c.brand || c.brand === 'cie');
const cieProducts = products.filter((p: any) => !p.brand || p.brand === 'cie');

const vartechCategories = [
  {
    label: 'Multimeters',
    href: u('/authorised-dealership/multimeters/'),
    icon: '🔌',
    count: vartechMultimeters.length,
    description: 'True RMS digital multimeters — pocket-friendly to bench-top, 2000 to 30000 counts.',
  },
  {
    label: 'Clamp Meters',
    href: u('/authorised-dealership/clamp-meters/'),
    icon: '🔧',
    count: vartechClampMeters.length,
    description: 'Digital clamp meters — 1000 A AC, True RMS, mA leakage testers and smart compact models.',
  },
  {
    label: 'Oscilloscopes',
    href: u('/authorised-dealership/oscilloscopes/'),
    icon: '📡',
    count: vartechOscilloscopes.length,
    description: 'Analog CROs (20–30 MHz) and digital storage oscilloscopes (80–150 MHz, 1 GS/s, 7" TFT).',
  },
  {
    label: 'Function Generators',
    href: u('/authorised-dealership/function-generators/'),
    icon: '〜',
    count: vartechFunctionGenerators.length,
    description: 'DDS function generators — 6 MHz to 80 MHz, dual channel, arbitrary waveforms, USB.',
  },
  {
    label: 'LCR & Cap Meters',
    href: u('/authorised-dealership/lcr-meters/'),
    icon: '🔵',
    count: vartechLcrMeters.length,
    description: 'Portable LC meters, handheld LCR multimeters and bench-top LCR-D-Q instruments.',
  },
  {
    label: 'DC Electronic Loads',
    href: u('/authorised-dealership/dc-loads/'),
    icon: '⚡',
    count: vartechDcLoads.length,
    description: '600 W programmable DC loads with CC/CV/CR/CP modes for battery and power supply testing.',
  },
  {
    label: 'Sound Level Meters',
    href: u('/authorised-dealership/sound-level-meters/'),
    icon: '🔊',
    count: vartechSoundLevelMeters.length,
    description: '30–130 dBA digital sound level meters — A-weighting, 1/2-inch condenser microphone, Fast/Slow.',
  },
  {
    label: 'Anemometers',
    href: u('/authorised-dealership/anemometers/'),
    icon: '💨',
    count: vartechAnemometers.length,
    description: 'Digital anemometers — 0–45 m/s air speed with temperature, wind chill and bar graph.',
  },
  {
    label: 'Calibrators',
    href: u('/authorised-dealership/calibrators/'),
    icon: '🎛️',
    count: vartechCalibrators.length,
    description: 'mV, mA, temperature and process calibrators — source & measure T/C, RTD and loop current.',
  },
  {
    label: 'Lux Meters',
    href: u('/authorised-dealership/lux-meters/'),
    icon: '💡',
    count: vartechLuxMeters.length,
    description: 'Digital lux meters — 0.1 to 200,000 Lux, flexible sensor, Lux/FC select.',
  },
  {
    label: 'Thermometers',
    href: u('/authorised-dealership/thermometers/'),
    icon: '🌡️',
    count: vartechThermometers.length,
    description: 'K-type industrial thermometers (-150 °C to 1300 °C) and compact thermo-hygrometers with clock.',
  },
  {
    label: 'DC Power Supplies',
    href: u('/authorised-dealership/dc-power-supplies/'),
    icon: '🔋',
    count: vartechDcPowerSupplies.length,
    description: 'Linear, SMPS and programmable DC supplies — 30 V to 200 V, up to 40 A, with PC interface.',
  },
];

const totalVartechProducts = vartechMultimeters.length + vartechClampMeters.length + vartechOscilloscopes.length + vartechFunctionGenerators.length + vartechLcrMeters.length + vartechDcLoads.length + vartechSoundLevelMeters.length + vartechAnemometers.length + vartechCalibrators.length + vartechLuxMeters.length + vartechThermometers.length + vartechDcPowerSupplies.length;
---

<Base
  title="Products — CIE Instruments & Vartech | Test & Measurement, Howrah India"
  description="Complete product catalogue — CIE manufactured instruments (insulation testers, earth testers, relay test sets, oil BDV testers) and Vartech authorised dealership (oscilloscopes, function generators, LCR meters, DC loads). Howrah, Kolkata, India."
  keywords="CIE instruments catalogue, vartech instruments India, test measurement instruments Howrah, digital multimeters India, oscilloscopes India, insulation tester catalogue, clamp meters India, electrical test instruments supplier"
>
  <!-- Page header -->
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'Products' }]} />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547] mt-4">Products</h1>
      <p class="mt-2 text-[#64748B] max-w-2xl">
        CIE manufactured instruments since 1963 — and the complete Vartech range as authorised dealer. Contact us for pricing and availability.
      </p>
    </div>
  </div>

  <!-- ── CIE Brand Section ── -->
  <section class="bg-white py-12 lg:py-16 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- CIE brand header -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
        <div class="flex items-center gap-4">
          <img src={u('/logo/cie-logo.png')} alt="CIE®" width="36" height="36" class="object-contain" />
          <div>
            <div class="text-[11px] font-mono uppercase tracking-[0.18em] text-[#E0252E] mb-0.5">Cambridge Instruments &amp; Engg. Co.</div>
            <h2 class="text-xl font-bold text-[#0D1B2A]">CIE Manufactured Instruments</h2>
          </div>
        </div>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-[#0D1B2A] text-white text-xs font-bold rounded-full self-start sm:self-auto">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Manufactured in Howrah since 1963
        </span>
      </div>

      <!-- Category filter pills -->
      <div class="flex flex-wrap gap-2 mb-8" id="cie-filters">
        <button
          data-filter="all"
          class="filter-pill active px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors"
        >
          All ({cieProducts.length})
        </button>
        {cieCategories.map(cat => {
          const count = cieProducts.filter((p: any) => p.categoryId === cat.id).length;
          return (
            <button
              data-filter={cat.id}
              class="filter-pill px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors"
            >
              {cat.icon} {cat.shortName} ({count})
            </button>
          );
        })}
      </div>

      <!-- CIE product grid nav -->
      <div class="hidden sm:flex items-center gap-2 mb-4">
        <button id="cie-prev" aria-label="Previous products"
          class="w-9 h-9 rounded-full border border-[#E8ECF2] bg-white hover:border-[#1B3A5B] hover:bg-[#1B3A5B] hover:text-white text-[#1B3A5B] transition-all flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="cie-next" aria-label="Next products"
          class="w-9 h-9 rounded-full border border-[#E8ECF2] bg-white hover:border-[#1B3A5B] hover:bg-[#1B3A5B] hover:text-white text-[#1B3A5B] transition-all flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>

      <!-- CIE product grid -->
      <div class="product-slider product-slider--desktop-scroll gap-5 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8" id="cie-product-grid">
        {cieProducts.map((p: any) => {
          const waMsg = encodeURIComponent(`Hi, I'd like to enquire about the ${p.model} — ${p.name}`);
          return (
            <article
              data-category={p.categoryId}
              class="cie-product-card bg-white rounded-xl border border-[#E8ECF2] overflow-hidden flex flex-col hover:shadow-md hover:border-[#1B3A5B] transition-all duration-200"
            >
              <!-- Product image -->
              <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] h-40 flex items-center justify-center relative">
                <img
                  src={u(`/images/products/${p.id}.webp`)}
                  alt={`${p.model} — ${p.name}`}
                  width="300"
                  height="300"
                  class="object-contain h-32 w-auto"
                  loading="lazy"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                />
                <div class="hidden absolute inset-0 flex-col items-center justify-center gap-1 text-[#b0bec5]">
                  <svg class="w-10 h-10 opacity-25" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/>
                    <path d="M3 9l4-4 4 4 4-4 4 4" stroke-width="1.5"/>
                  </svg>
                  <span class="text-[10px] font-mono uppercase tracking-wider opacity-40">Image coming soon</span>
                </div>
              </div>

              <div class="p-4 flex flex-col flex-1">
                <p class="text-[11px] font-mono text-[#E0252E] mb-0.5">{p.model}</p>
                <h3 class="font-bold text-[#0D2547] text-sm leading-snug mb-2">{p.name}</h3>
                <p class="text-xs text-[#64748B] mb-4 flex-1 line-clamp-3">{p.tagline}</p>

                <div class="flex flex-col gap-2 mt-auto">
                  <a
                    href={u(`/products/${p.categoryId}/${p.id}`)}
                    class="text-center px-3 py-2 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-xs font-semibold rounded transition-colors"
                  >
                    View Specifications
                  </a>
                  <a
                    href={`https://wa.me/${site.whatsapp}?text=${waMsg}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-center px-3 py-2 border border-[#25D366] text-[#1a6e38] hover:bg-[#25D366]/10 text-xs font-medium rounded transition-colors"
                  >
                    Enquire on WhatsApp
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <p class="mt-4 text-xs text-[#94a3b8]">{cieProducts.length} CIE instruments across {cieCategories.length} categories</p>
    </div>
  </section>

  <!-- ── Vartech Brand Section ── -->
  <section class="py-12 lg:py-16" style="background: linear-gradient(to bottom, #f8f9fa, #fff);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Vartech brand header -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div class="flex items-center gap-4">
          <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech®" width="100" height="36" class="object-contain" />
          <div>
            <div class="text-[11px] font-mono uppercase tracking-[0.18em] text-[#E0252E] mb-0.5">Authorised Dealer</div>
            <h2 class="text-xl font-bold text-[#0D1B2A]">Vartech</h2>
          </div>
        </div>
        <div class="flex flex-col sm:items-end gap-1">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-600 text-white text-xs font-bold rounded-full">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            CIE Authorised Dealer
          </span>
          <a href={u('/authorised-dealership/')} class="text-xs text-[#E0252E] hover:underline">View dealership details →</a>
        </div>
      </div>

      <!-- Vartech category grid — all categories, linking to authorised dealership pages -->
      <div class="product-slider gap-5 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 mb-4">
        {vartechCategories.map(cat => (
          <a href={cat.href}
            class="group flex flex-col p-5 rounded-xl border-2 border-emerald-100 bg-white hover:border-emerald-500 hover:shadow-md transition-all duration-200">
            <div class="flex items-start justify-between mb-3">
              <span class="text-2xl">{cat.icon}</span>
              <span class="text-[10px] font-mono text-gray-400">{cat.count} models</span>
            </div>
            <div class="text-[10px] font-mono uppercase tracking-widest text-emerald-600 mb-1">Vartech®</div>
            <h3 class="font-bold text-[#0D1B2A] text-sm leading-snug group-hover:text-emerald-700 transition-colors mb-1">{cat.label}</h3>
            <p class="text-xs text-gray-500 leading-relaxed flex-1">{cat.description}</p>
            <div class="mt-3 text-xs font-semibold text-emerald-600 group-hover:underline">View range →</div>
          </a>
        ))}
      </div>
      <p class="text-xs text-[#94a3b8]">{totalVartechProducts} Vartech instruments across {vartechCategories.length} categories · <a href={u('/authorised-dealership/')} class="text-[#E0252E] hover:underline">View Authorised Dealership →</a></p>
    </div>
  </section>

  <CTABand />
</Base>

<style>
  .filter-pill {
    background: white;
    color: #64748b;
    border-color: #e2e8f0;
  }
  .filter-pill:hover {
    border-color: #1B3A5B;
    color: #1B3A5B;
  }
  .filter-pill.active {
    background: #1B3A5B;
    color: white;
    border-color: #1B3A5B;
  }
  .cie-product-card.hidden {
    display: none;
  }
</style>

<script>
  // ── CIE grid prev/next ──────────────────────────────────────────────────────
  {
    const track = document.getElementById('cie-product-grid');
    const prev  = document.getElementById('cie-prev') as HTMLButtonElement | null;
    const next  = document.getElementById('cie-next') as HTMLButtonElement | null;
    if (track) {
      let cachedW = 285;
      const updateW = () => {
        const first = track.querySelector('article');
        if (first) cachedW = first.offsetWidth + 20;
      };
      requestAnimationFrame(updateW);
      new ResizeObserver(updateW).observe(track);
      prev?.addEventListener('click', () => track.scrollBy({ left: -cachedW * 4, behavior: 'smooth' }));
      next?.addEventListener('click', () => track.scrollBy({ left:  cachedW * 4, behavior: 'smooth' }));
    }
  }

  // ── Category filter pills ───────────────────────────────────────────────────
  const filters = document.querySelectorAll<HTMLButtonElement>('#cie-filters .filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('#cie-product-grid .cie-product-card');

  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      filters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
