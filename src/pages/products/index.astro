---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import EyebrowLabel from '../../components/EyebrowLabel.astro';
import ProductCard from '../../components/ProductCard.astro';
import CTABand from '../../components/CTABand.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import categories from '../../data/categories.json';
import products from '../../data/products.json';

// Enrich categories with counts
const categoryCount = categories.map(cat => ({
  ...cat,
  count: products.filter(p => p.categoryId === cat.id).length,
}));
---

<Base
  title="Product Catalogue"
  description="Browse the complete CIE instruments product catalogue — insulation testers, earth testers, relay test sets, oil BDV testers, digital instruments and more. Manufactured in Howrah since 1963."
>
  <!-- Page header -->
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'Products' }]} />
      <EyebrowLabel text="CIE® Product Catalogue" class="mt-4 mb-3" />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">Test &amp; Measurement Instruments</h1>
      <p class="mt-2 text-[#64748B] max-w-2xl">
        Precision test &amp; measurement instruments from CIE and authorised brands.
        Contact us for pricing and availability.
      </p>
    </div>
  </div>

  <!-- Products with filter -->
  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Filter bar -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-8">
        <!-- Dropdown (mobile-friendly) -->
        <div class="relative">
          <label for="cat-filter" class="sr-only">Filter by category</label>
          <select id="cat-filter"
            class="appearance-none bg-white border border-[#E8ECF2] rounded-lg pl-4 pr-10 py-2.5 text-sm font-medium text-[#0D2547] focus:outline-none focus:ring-2 focus:ring-[#1B3A5B] cursor-pointer shadow-sm min-w-[220px]">
            <option value="all">All Categories ({products.length})</option>
            {categoryCount.map(cat => (
              <option value={cat.id}>{cat.name} ({cat.count})</option>
            ))}
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#64748B]"
            fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>

        <!-- Pill tabs (desktop) — hidden on small screens -->
        <div class="hidden lg:flex flex-wrap gap-2">
          <button data-filter="all"
            class="filter-pill px-3 py-1.5 rounded-full text-xs font-semibold border transition-all bg-[#1B3A5B] text-white border-[#1B3A5B]">
            All
          </button>
          {categoryCount.map(cat => (
            <button data-filter={cat.id}
              class="filter-pill px-3 py-1.5 rounded-full text-xs font-semibold border transition-all border-[#E8ECF2] text-[#64748B] hover:border-[#1B3A5B] hover:text-[#1B3A5B]">
              {cat.shortName}
            </button>
          ))}
        </div>

        <!-- Count badge -->
        <span id="product-count" class="ml-auto text-sm text-[#64748B] font-mono shrink-0">
          {products.length} instruments
        </span>
      </div>

      <!-- Product grid -->
      <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {products.map(p => (
          <div class="product-item" data-category={p.categoryId}>
            <ProductCard
              model={p.model}
              name={p.name}
              tagline={p.tagline}
              categoryId={p.categoryId}
              id={p.id}
              featured={p.featured}
              image={p.image}
              hideImage={p.hideImage}
            />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="no-results" class="hidden py-20 text-center">
        <p class="text-[#64748B] text-sm">No products found in this category.</p>
      </div>

    </div>
  </section>

  <CTABand />
</Base>

<script>
{
  const items    = document.querySelectorAll<HTMLElement>('.product-item');
  const pills    = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const dropdown = document.getElementById('cat-filter') as HTMLSelectElement | null;
  const countEl  = document.getElementById('product-count');
  const noRes    = document.getElementById('no-results');

  function applyFilter(value: string) {
    let visible = 0;
    items.forEach(item => {
      const match = value === 'all' || item.dataset.category === value;
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (countEl) countEl.textContent = `${visible} instrument${visible !== 1 ? 's' : ''}`;
    if (noRes)   noRes.classList.toggle('hidden', visible > 0);

    // Sync pills
    pills.forEach(p => {
      const active = p.dataset.filter === value;
      p.classList.toggle('bg-[#1B3A5B]', active);
      p.classList.toggle('text-white', active);
      p.classList.toggle('border-[#1B3A5B]', active);
      p.classList.toggle('border-[#E8ECF2]', !active);
      p.classList.toggle('text-[#64748B]', !active);
    });

    // Sync dropdown
    if (dropdown && dropdown.value !== value) dropdown.value = value;
  }

  // Pill clicks
  pills.forEach(pill => {
    pill.addEventListener('click', () => applyFilter(pill.dataset.filter || 'all'));
  });

  // Dropdown change
  dropdown?.addEventListener('change', () => applyFilter(dropdown.value));

  // Honour ?category= query param on load
  const param = new URLSearchParams(window.location.search).get('category');
  if (param) applyFilter(param);
}
</script>
