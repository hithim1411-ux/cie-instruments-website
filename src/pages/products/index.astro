---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import EyebrowLabel from '../../components/EyebrowLabel.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import ProductCard from '../../components/ProductCard.astro';
import CTABand from '../../components/CTABand.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import categories from '../../data/categories.json';
import products from '../../data/products.json';

const categoryCount = categories.map(cat => ({
  ...cat,
  count: products.filter(p => p.categoryId === cat.id).length,
}));
---

<Base
  title="Product Catalogue"
  description="Browse the complete CIE instruments product catalogue — insulation testers, earth testers, relay test sets, oil BDV testers, digital instruments and more. Manufactured in Howrah since 1963."
>
  <!-- Page header -->
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'Products' }]} />
      <EyebrowLabel text="CIE® Product Catalogue" class="mt-4 mb-3" />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">Test &amp; Measurement Instruments</h1>
      <p class="mt-2 text-[#64748B] max-w-2xl">
        Every instrument manufactured and calibrated at our Howrah works.
        No prices listed — contact us for a quote or enquire on WhatsApp.
      </p>
      <!-- Catalogue download -->
      <a
        href={u('/downloads/cie-product-catalogue.pdf')}
        download="CIE Short Form Product Catalogue.pdf"
        class="inline-flex items-center gap-2 mt-5 px-5 py-2.5 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-sm font-semibold rounded transition-colors"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Download Short Form Product Catalogue (PDF)
      </a>
    </div>
  </div>

  <!-- Category grid -->
  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-[#0D2547] mb-6">Browse by Category</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categoryCount.map(cat => (
          <CategoryCard
            id={cat.id}
            name={cat.name}
            description={cat.description}
            icon={cat.icon}
            count={cat.count}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- All products -->
  <section class="bg-[#F5F7FA] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-[#0D2547]">All Products</h2>
        <span class="text-sm text-[#64748B] font-mono">{products.length} instruments</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {products.map(p => (
          <ProductCard
            model={p.model}
            name={p.name}
            tagline={p.tagline}
            categoryId={p.categoryId}
            id={p.id}
            featured={p.featured}
            image={p.image}
            hideImage={p.hideImage}
          />
        ))}
      </div>
    </div>
  </section>

  <CTABand />
</Base>
