---
import Base from '../layouts/Base.astro';
import EyebrowLabel from '../components/EyebrowLabel.astro';
import CTABand from '../components/CTABand.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { u } from '../utils/url';

const faqs = [
  {
    q: 'Are you a manufacturer or a reseller?',
    a: 'We are both. Cambridge Instruments & Engineering Co. (CIE) manufactures a range of electrical test and measuring instruments from our facility in Howrah, West Bengal. We are also authorised dealers for selected leading brands, enabling us to offer a wider range of testing solutions.',
  },
  {
    q: 'What products are manufactured by CIE?',
    a: 'CIE manufactures insulation testers, earth resistance testers, digital earth testers, hand-driven testers, high voltage insulation testers, and other specialised testing instruments designed for industrial and electrical applications.',
  },
  {
    q: 'Which brands do you supply?',
    a: 'In addition to CIE products, we are authorised dealers for Var-Tech and UNI-T.',
  },
  {
    q: 'Are your instruments tested before dispatch?',
    a: 'Yes. Every CIE instrument undergoes quality inspection and calibration before dispatch to ensure dependable performance and accuracy.',
  },
  {
    q: 'Do your products come with a warranty?',
    a: 'Yes. CIE instruments carry a 12-month warranty against manufacturing defects from the date of supply. For warranty claims, contact us directly at cieinstruments@gmail.com.',
  },
  {
    q: 'Do you provide calibration and service support?',
    a: 'Yes. We provide calibration, servicing, and technical support directly from our Howrah works — not through a distributor network.',
  },
  {
    q: 'Can you manufacture custom ranges?',
    a: 'Yes. Any non-standard test voltage, insulation range, resistance range, or measurement range can be manufactured to your specific requirement. Contact us with your specification.',
  },
  {
    q: 'How do I select the right instrument?',
    a: 'Choosing the correct instrument depends on your application, operating voltage, testing requirements, and applicable standards. Our technical team can help you identify the most suitable solution.',
  },
  {
    q: 'Do you provide technical assistance before purchase?',
    a: 'Absolutely. We are happy to assist with product selection, technical specifications, and application requirements before you place an order.',
  },
  {
    q: 'Do you accept bulk and institutional orders?',
    a: 'Yes. We regularly supply instruments to utilities, contractors, government organisations, railways, educational institutions, OEMs, and distributors across India.',
  },
  {
    q: 'Do you ship across India?',
    a: 'Yes. We deliver products across India through trusted logistics partners.',
  },
  {
    q: 'Why choose CIE?',
    a: 'Over six decades of manufacturing experience, direct after-sales support, in-house calibration, and instruments trusted by PGCIL, WBSETCL, and Indian Railways across India.',
  },
  {
    q: 'Where are CIE instruments manufactured?',
    a: 'All CIE instruments are manufactured at our works in Howrah, West Bengal, India. Howrah has been an industrial manufacturing centre since the 19th century, and CIE has been manufacturing electrical test instruments here since 1963. Assembly, winding, calibration, and quality testing are all carried out at our Howrah facility.',
  },
  {
    q: 'Do you supply to customers outside West Bengal and Eastern India?',
    a: 'Yes. We supply instruments across India — to customers in Bangalore, Chennai, Hyderabad, Mumbai, Delhi, Pune, Ahmedabad, Lucknow, Bhubaneswar, Raipur, Ranchi, and all major cities and industrial centres. We ship through trusted logistics partners with appropriate packing for instrument protection in transit.',
  },
  {
    q: 'What is an insulation tester and when do I need one?',
    a: 'An insulation tester (also called a megger or megohmmeter) measures the resistance of electrical insulation in cables, motors, transformers, switchgear, and wiring. It applies a DC test voltage (typically 500 V, 1000 V, 2500 V, or 5000 V) and measures the resulting leakage current to calculate insulation resistance in megohms or gigohms. Insulation testing is required during electrical installation commissioning, routine preventive maintenance, and fault investigation.',
  },
  {
    q: 'What is an earth tester and why is it important?',
    a: 'An earth resistance tester measures the resistance of an earthing (grounding) system to the general mass of earth. Low earth resistance is critical for personnel safety (fault current must flow safely to earth), equipment protection, and lightning protection effectiveness. Earth resistance testing is mandatory under the Indian Electricity Rules and IS 3043 for all electrical installations — from domestic premises to substations.',
  },
  {
    q: 'What is a relay test set used for?',
    a: 'A relay test set is used to test protection relays — devices that monitor electrical parameters (current, voltage, frequency) and trip circuit breakers when a fault is detected. Testing verifies that each relay operates at the correct threshold and within the specified time. CIE manufactures single-phase relay test sets (for over-current and earth fault relays) and the RTS-33 three-phase relay test set (for distance, differential, and directional relays).',
  },
  {
    q: 'What is a transformer oil BDV test?',
    a: 'A dielectric strength or breakdown voltage (BDV) test measures the ability of transformer oil to withstand electrical stress without breaking down. It is performed by applying increasing AC voltage across electrodes immersed in the oil until breakdown occurs. The result (in kV) indicates the oil\'s condition — deteriorated or contaminated oil has lower BDV and must be processed or replaced before filling a transformer. CIE manufactures oil BDV test sets from 50 kV to 120 kV.',
  },
  {
    q: 'Are CIE instruments approved by any government or statutory body?',
    a: 'CIE instruments are manufactured to conform to relevant Indian Standards (ISS/IS) as applicable to each instrument type — including ISS: 2992-1987 for insulation testers and IS 10656 for digital insulation testers. CIE has been supplying instruments to government utilities, railways, and PSUs for over six decades.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="FAQs"
  description="Frequently asked questions about CIE instruments — warranty, calibration, custom ranges, ordering, and after-sales support. Manufactured in Howrah since 1963."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Page header -->
  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[{ label: 'FAQs' }]} />
      <EyebrowLabel text="Frequently Asked Questions" class="mt-4 mb-3" />
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">FAQs</h1>
      <p class="mt-2 text-[#64748B] max-w-2xl">
        Everything you need to know about CIE products, ordering, and support.
      </p>
    </div>
  </div>

  <!-- FAQ accordion -->
  <section class="bg-white py-14 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <dl class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="border border-[#E8ECF2] rounded-xl overflow-hidden bg-[#FAFBFC]">
            <dt>
              <button
                type="button"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
                id={`faq-btn-${i}`}
                class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-4 text-left text-[#0D2547] font-semibold text-sm sm:text-[15px] hover:bg-[#F5F7FA] transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#E0252E]"
              >
                <span>{faq.q}</span>
                <svg
                  class="faq-chevron w-4 h-4 shrink-0 text-[#E0252E] transition-transform duration-200"
                  fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </dt>
            <dd
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-btn-${i}`}
              class="faq-answer hidden px-6 pb-5 text-sm text-[#64748B] leading-relaxed border-t border-[#E8ECF2]"
            >
              <p class="pt-4">{faq.a}</p>
            </dd>
          </div>
        ))}
      </dl>

      <p class="mt-10 text-center text-sm text-[#64748B]">
        Have another question?{' '}
        <a href="mailto:cieinstruments@gmail.com" class="text-[#E0252E] hover:underline font-medium">
          Email us
        </a>{' '}and we'll respond within one business day.
      </p>
    </div>
  </section>

  <CTABand
    heading="Need help choosing the right instrument?"
    body="Talk to our technical team — we'll help you find the right solution for your application."
    primaryLabel="Contact Us"
    primaryHref={u('/contact/')}
    secondaryLabel="View Products"
    secondaryHref={u('/products/')}
  />
</Base>

<script>
document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    const answer = document.getElementById(btn.getAttribute('aria-controls')!);
    const chevron = btn.querySelector<SVGElement>('.faq-chevron');
    btn.setAttribute('aria-expanded', String(!expanded));
    answer?.classList.toggle('hidden', expanded);
    chevron?.classList.toggle('rotate-180', !expanded);
  });

  btn.addEventListener('keydown', (e) => {
    const list = Array.from(document.querySelectorAll<HTMLButtonElement>('.faq-btn'));
    const idx = list.indexOf(btn);
    if (e.key === 'ArrowDown') { e.preventDefault(); list[idx + 1]?.focus(); }
    if (e.key === 'ArrowUp')   { e.preventDefault(); list[idx - 1]?.focus(); }
    if (e.key === 'Home')      { e.preventDefault(); list[0]?.focus(); }
    if (e.key === 'End')       { e.preventDefault(); list[list.length - 1]?.focus(); }
  });
});
</script>
