---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CTABand from '../../../components/CTABand.astro';
import site from '../../../data/site.json';
import products from '../../../data/vartech-lcr-meters.json';

export async function getStaticPaths() {
  return products.map(p => ({ params: { product: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const waMsg = encodeURIComponent(`Hi, I'd like to enquire about the Vartech ${product.model} — ${product.name}. Please send me details and pricing.`);
const quoteMailto = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent(`Quote Request — Vartech ${product.model}`)}&body=${encodeURIComponent(`Hello CIE team,\n\nI would like to request a quote for:\nBrand: Vartech\nModel: ${product.model} — ${product.name}\n\nQuantity:\nApplication:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.`)}`;
const canonicalPath = `https://cieinstruments.in/authorised-dealership/lcr-meters/${product.id}/`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cieinstruments.in/' },
    { '@type': 'ListItem', position: 2, name: 'Authorised Dealership', item: 'https://cieinstruments.in/authorised-dealership/' },
    { '@type': 'ListItem', position: 3, name: 'Vartech LCR Meters', item: 'https://cieinstruments.in/authorised-dealership/lcr-meters/' },
    { '@type': 'ListItem', position: 4, name: product.model, item: canonicalPath },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `Vartech ${product.model} — ${product.name}`,
  description: product.description,
  brand: { '@type': 'Brand', name: 'Vartech' },
  model: product.model,
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: canonicalPath,
    seller: { '@type': 'Organization', name: 'Cambridge Instruments & Engg. Co.' },
  },
  ...(product.specs && product.specs.length > 0 && {
    additionalProperty: product.specs.map((s: { label: string; value: string }) => ({
      '@type': 'PropertyValue', name: s.label, value: s.value,
    })),
  }),
};
---

<Base
  title={`Vartech ${product.model} — ${product.name} | CIE Instruments`}
  description={`${product.model} ${product.name} — ${product.tagline} Available from CIE Instruments, authorised Vartech dealer in India.`}
  rawTitle
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[
        { label: 'Authorised Dealership', href: u('/authorised-dealership/') },
        { label: 'Vartech LCR Meters', href: u('/authorised-dealership/lcr-meters/') },
        { label: product.model },
      ]} />
      <p class="eyebrow mt-4 mb-3">— Vartech® LCR &amp; Capacitance Meters</p>
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">
        <span class="model-code text-xl block mb-1">{product.model}</span>
        {product.name}
      </h1>
      <p class="mt-3 text-[#64748B] max-w-2xl">{product.tagline}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <div class="lg:col-span-1">
        <div class="bg-[#F5F7FA] border border-[#E8ECF2] rounded-xl overflow-hidden mb-3">
          <img id="gallery-main"
            src={u(`/images/vartech/lcr-meters/${product.images[0]}`)}
            alt={`Vartech ${product.model} — ${product.name}`}
            width="600" height="600"
            class="w-full object-contain h-64 lg:h-72 p-4"
            loading="eager" onerror="this.style.opacity='0.2'" />
        </div>

        {product.images.length > 1 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {product.images.map((img: string, i: number) => (
              <button type="button"
                data-src={u(`/images/vartech/lcr-meters/${img}`)}
                data-alt={`Vartech ${product.model} — image ${i + 1}`}
                class:list={['gallery-thumb w-16 h-16 rounded-lg border-2 overflow-hidden bg-[#F5F7FA] transition-all', i === 0 ? 'border-[#1B3A5B]' : 'border-[#E8ECF2] hover:border-[#1B3A5B]/50']}
                aria-label={`View image ${i + 1}`}>
                <img src={u(`/images/vartech/lcr-meters/${img}`)} alt="" aria-hidden="true" width="64" height="64" class="w-full h-full object-contain p-1" loading="lazy" />
              </button>
            ))}
          </div>
        )}

        <div class="space-y-3">
          <a href={u(`/downloads/vartech/lcr-meters/${product.catalogue}`)} target="_blank" rel="noopener noreferrer"
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-[#1B3A5B] hover:bg-[#0D2547] text-white font-bold rounded transition-colors text-sm">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3"/>
            </svg>
            Download Catalogue (PDF)
          </a>
          <a href={quoteMailto}
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-[#E0252E] hover:bg-[#D72631] text-white font-bold rounded transition-colors text-sm">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Request a Quote
          </a>
          <a href={`https://wa.me/${site.whatsapp}?text=${waMsg}`} target="_blank" rel="noopener noreferrer"
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-[#25D366] text-[#1a6e38] hover:bg-[#25D366]/10 font-semibold rounded transition-colors text-sm">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enquire on WhatsApp
          </a>
        </div>

        <div class="mt-6 bg-[#F5F7FA] rounded-lg p-4 border border-[#E8ECF2]">
          <div class="flex items-center gap-2 mb-3">
            <img src={u('/images/vartech/vartech-logo.avif')} alt="Vartech logo" width="80" height="30" class="h-7 w-auto object-contain" loading="lazy" />
            <span class="text-xs font-mono font-bold text-[#E0252E] uppercase tracking-widest">Authorised Dealer</span>
          </div>
          <ul class="space-y-2">
            {['Genuine Vartech product', 'Expert technical support', 'Pan-India delivery', 'Competitive pricing'].map(f => (
              <li class="flex items-center gap-2 text-xs text-[#64748B]">
                <span class="w-1.5 h-1.5 rounded-full bg-[#1B3A5B] shrink-0"></span>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="lg:col-span-2 space-y-10">
        <div>
          <h2 class="text-xl font-bold text-[#0D2547] mb-3">About This Instrument</h2>
          <p class="text-[#64748B] leading-relaxed">{product.description}</p>
        </div>

        {product.features && (product.features as string[]).length > 0 && (
          <div>
            <h2 class="text-xl font-bold text-[#0D2547] mb-4">Key Features</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
              {(product.features as string[]).map((f: string) => (
                <li class="flex items-start gap-3 text-sm text-[#64748B]">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#1B3A5B] shrink-0"></span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        )}

        {product.specs && (product.specs as {label:string;value:string}[]).length > 0 && (
          <div>
            <h2 class="text-xl font-bold text-[#0D2547] mb-4">Technical Specifications</h2>
            <div class="border border-[#E8ECF2] rounded-lg overflow-hidden">
              <table class="w-full text-sm">
                <tbody>
                  {(product.specs as {label:string;value:string}[]).map((row, i) => (
                    <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#F5F7FA]'}>
                      <td class="py-2.5 px-4 font-semibold text-[#0D2547] w-2/5 align-top border-b border-[#E8ECF2]">{row.label}</td>
                      <td class="py-2.5 px-4 text-[#64748B] align-top border-b border-[#E8ECF2]">{row.value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="mt-3 text-xs text-[#94A3B8]">Specifications sourced from the official Vartech product catalogue. Download above for the full datasheet.</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <CTABand
    heading={`Interested in the Vartech ${product.model}? Get a quote today.`}
    body="Email us with your model, quantity and application — we respond within one business day."
    primaryLabel="Request a Quote"
    primaryHref={quoteMailto}
    secondaryLabel="← All Vartech LCR Meters"
    secondaryHref={u('/authorised-dealership/lcr-meters/')}
  />
</Base>

<script>
{
  const mainImg = document.getElementById('gallery-main') as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');
  thumbs.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!mainImg) return;
      mainImg.src = btn.dataset.src ?? '';
      mainImg.alt = btn.dataset.alt ?? '';
      thumbs.forEach(t => t.classList.replace('border-[#1B3A5B]', 'border-[#E8ECF2]'));
      btn.classList.replace('border-[#E8ECF2]', 'border-[#1B3A5B]');
    });
  });
}
</script>
