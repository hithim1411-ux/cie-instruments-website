---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CTABand from '../../../components/CTABand.astro';
import products from '../../../data/vartech-lux-meters.json';

const pageTitle = 'Vartech Digital Lux Meters — Authorised Dealer India | CIE Instruments';
const pageDesc =
  'Buy Vartech digital lux meters in India — V 6610 B (0–199999 Lux, 4-digit, backlit) and V 6610+ (0.1 to 200,000 Lux, flexible sensor, 3½-digit). CIE Instruments is an authorised Vartech dealer supplying engineers and labs across India from Howrah.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cieinstruments.in/' },
    { '@type': 'ListItem', position: 2, name: 'Authorised Dealership', item: 'https://cieinstruments.in/authorised-dealership/' },
    { '@type': 'ListItem', position: 3, name: 'Vartech Digital Lux Meters', item: 'https://cieinstruments.in/authorised-dealership/lux-meters/' },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Vartech Digital Lux Meters',
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: `${p.model} — ${p.name}`,
      description: p.description,
      brand: { '@type': 'Brand', name: 'Vartech' },
      offers: {
        '@type': 'Offer',
        seller: { '@type': 'Organization', name: 'Cambridge Instruments & Engg. Co.' },
        availability: 'https://schema.org/InStock',
        priceCurrency: 'INR',
        price: '0',
        priceSpecification: { '@type': 'PriceSpecification', description: 'Contact for price' },
      },
    },
  })),
};
---

<Base title={pageTitle} description={pageDesc} ogImage={u('/images/vartech/vartech-logo.avif')} rawTitle>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[
        { label: 'Authorised Dealership', href: u('/authorised-dealership/') },
        { label: 'Vartech Digital Lux Meters' },
      ]} />
      <p class="eyebrow mt-4 mb-3">— Vartech® Digital Lux Meters</p>
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">Vartech Digital Lux Meters</h1>
      <p class="mt-3 text-[#64748B] max-w-2xl leading-relaxed">
        As the authorised dealer for Vartech in India, CIE Instruments supplies Vartech digital lux meters — the V 6610 B (0–199999 Lux, 4-digit backlit LCD, Auto/Manual ranging) and the V 6610+ (0.1 to 200,000 Lux, 3½-digit auto-ranging with detachable flexible sensor) — for lighting surveys, industrial inspection and compliance testing.
      </p>
    </div>
  </div>

  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-lg font-bold text-[#0D2547]">{products.length} Vartech lux meter model{products.length !== 1 ? 's' : ''}</h2>
        <a href={u('/authorised-dealership/')} class="text-sm text-[#64748B] hover:text-[#1B3A5B] transition-colors">← Authorised Dealership</a>
      </div>

      <div class="product-slider gap-5">
        {products.map(p => (
          <article class="bg-white rounded-lg border border-[#E8ECF2] overflow-hidden flex flex-col transition-shadow duration-200 hover:shadow-md">
            <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] h-44 flex items-center justify-center relative">
              <img
                src={u(`/images/vartech/lux-meters/${p.images[0]}`)}
                alt={`${p.model} — ${p.name}`}
                width="400" height="400"
                class="object-contain h-36 w-auto"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
              />
              <div class="hidden absolute inset-0 flex-col items-center justify-center gap-2 text-[#b0bec5]">
                <svg class="w-12 h-12 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/>
                  <path d="M3 9l4-4 4 4 4-4 4 4" stroke-width="1.5"/>
                </svg>
                <span class="text-xs font-mono uppercase tracking-wider opacity-50">Image coming soon</span>
              </div>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <p class="model-code text-xs mb-1">{p.model}</p>
              <h3 class="font-bold text-[#0D2547] text-base mb-2 leading-snug">{p.name}</h3>
              <p class="text-sm text-[#64748B] mb-4 flex-1 line-clamp-3">{p.tagline}</p>
              <div class="flex flex-col gap-2 mt-auto">
                <a href={u(`/authorised-dealership/lux-meters/${p.id}/`)}
                  class="text-center px-4 py-2.5 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-sm font-semibold rounded transition-colors">
                  View Details & Specs
                </a>
                <a href={u(`/downloads/vartech/lux-meters/${p.catalogue}`)}
                  target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 text-center px-4 py-2 border border-[#1B3A5B] text-[#1B3A5B] hover:bg-[#1B3A5B]/5 text-sm font-medium rounded transition-colors">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3"/>
                  </svg>
                  Download Catalogue
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#F5F7FA] py-12 lg:py-16 border-t border-[#E8ECF2]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-[#0D2547] mb-6">About Vartech Digital Lux Meters</h2>
      <div class="space-y-4 text-sm text-[#64748B] leading-relaxed">
        <p>
          Digital lux meters are essential for workplace lighting assessments, building energy audits, stage and studio lighting design, greenhouse horticulture lighting optimisation and compliance with occupational lighting standards. The Vartech V 6610 B and V 6610+ cover the full practical illuminance range from 0.1 Lux (near-darkness) through to 200,000 Lux (full sunlight conditions).
        </p>
        <p>
          The V 6610+ features a detachable flexible sensor head on a coiled lead, allowing the sensor to be positioned precisely at the measurement point while the user reads the display from a comfortable position — invaluable for measuring illuminance in tight or awkward locations. Both models offer Lux/FC switching for users who work to both SI and imperial standards.
        </p>
        <p>
          CIE Instruments (Cambridge Instruments &amp; Engg. Co., Howrah) is an authorised Vartech dealer for India. We supply Vartech lux meters to lighting designers, electrical contractors, safety officers, research institutions and industrial facilities across India — including Kolkata, Howrah, Bhubaneswar, Delhi, Mumbai, Bengaluru, Hyderabad, Chennai, Ahmedabad, Pune, Lucknow and Chandigarh.
        </p>
        <p>
          For pricing and availability, <a href="/contact/" class="text-[#1B3A5B] hover:underline font-medium">contact our team</a> or enquire via WhatsApp.
        </p>
      </div>
      <div class="mt-8 pt-6 border-t border-[#E8ECF2]">
        <p class="text-xs text-[#94a3b8]">
          Cambridge Instruments &amp; Engg. Co. (CIE) — manufacturer of precision electrical test instruments in Howrah since 1963, and authorised dealer for Vartech.
        </p>
      </div>
    </div>
  </section>

  <CTABand />
</Base>
