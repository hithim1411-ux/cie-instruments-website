---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CTABand from '../../../components/CTABand.astro';
import products from '../../../data/vartech-calibrators.json';

const pageTitle = 'Vartech Calibrators — mV, mA, Temperature & Process | Authorised Dealer India | CIE Instruments';
const pageDesc =
  'Buy Vartech mV/mA/temperature/process calibrators in India — V 7220 R temperature calibrator, V 7221 B loop calibrator and MS 7221 V/mA calibrator with source and measure capability. CIE Instruments is an authorised Vartech dealer supplying across India from Howrah.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cieinstruments.in/' },
    { '@type': 'ListItem', position: 2, name: 'Authorised Dealership', item: 'https://cieinstruments.in/authorised-dealership/' },
    { '@type': 'ListItem', position: 3, name: 'Vartech Calibrators — mV, mA, Temperature & Process', item: 'https://cieinstruments.in/authorised-dealership/calibrators/' },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Vartech Calibrators — mV, mA, Temperature & Process',
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: `${p.model} — ${p.name}`,
      description: p.description,
      brand: { '@type': 'Brand', name: 'Vartech' },
      offers: {
        '@type': 'Offer',
        seller: { '@type': 'Organization', name: 'Cambridge Instruments & Engg. Co.' },
        availability: 'https://schema.org/InStock',
        priceCurrency: 'INR',
        price: '0',
        priceSpecification: { '@type': 'PriceSpecification', description: 'Contact for price' },
      },
    },
  })),
};
---

<Base title={pageTitle} description={pageDesc} ogImage={u('/images/vartech/vartech-logo.avif')} rawTitle>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[
        { label: 'Authorised Dealership', href: u('/authorised-dealership/') },
        { label: 'Vartech Calibrators — mV, mA, Temperature & Process' },
      ]} />
      <p class="eyebrow mt-4 mb-3">— Vartech® Calibrators</p>
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">Vartech Calibrators — mV, mA, Temperature & Process</h1>
      <p class="mt-3 text-[#64748B] max-w-2xl leading-relaxed">
        As the authorised dealer for Vartech in India, CIE Instruments supplies three Vartech process calibrators: the V 7220 R temperature calibrator (DCV, T/C, RTD source & measure), the V 7221 B loop calibrator (0–30 mA source, ±35 mA/35 V measure, sawtooth/triangle wave) and the MS 7221 V/mA calibrator (0–24 mA / 0–10 V with 24 V loop supply and 0.015% mA accuracy).
      </p>
    </div>
  </div>

  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-lg font-bold text-[#0D2547]">{products.length} Vartech calibrator model{products.length !== 1 ? 's' : ''}</h2>
        <a href={u('/authorised-dealership/')} class="text-sm text-[#64748B] hover:text-[#1B3A5B] transition-colors">← Authorised Dealership</a>
      </div>

      <div class="product-slider gap-5">
        {products.map(p => (
          <article class="bg-white rounded-lg border border-[#E8ECF2] overflow-hidden flex flex-col transition-shadow duration-200 hover:shadow-md">
            <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] h-44 flex items-center justify-center relative">
              <img
                src={u(`/images/vartech/calibrators/${p.images[0]}`)}
                alt={`${p.model} — ${p.name}`}
                width="400" height="400"
                class="object-contain h-36 w-auto"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
              />
              <div class="hidden absolute inset-0 flex-col items-center justify-center gap-2 text-[#b0bec5]">
                <svg class="w-12 h-12 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/>
                  <path d="M3 9l4-4 4 4 4-4 4 4" stroke-width="1.5"/>
                </svg>
                <span class="text-xs font-mono uppercase tracking-wider opacity-50">Image coming soon</span>
              </div>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <p class="model-code text-xs mb-1">{p.model}</p>
              <h3 class="font-bold text-[#0D2547] text-base mb-2 leading-snug">{p.name}</h3>
              <p class="text-sm text-[#64748B] mb-4 flex-1 line-clamp-3">{p.tagline}</p>
              <div class="flex flex-col gap-2 mt-auto">
                <a href={u(`/authorised-dealership/calibrators/${p.id}/`)}
                  class="text-center px-4 py-2.5 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-sm font-semibold rounded transition-colors">
                  View Details & Specs
                </a>
                <a href={u(`/downloads/vartech/calibrators/${p.catalogue}`)}
                  target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 text-center px-4 py-2 border border-[#1B3A5B] text-[#1B3A5B] hover:bg-[#1B3A5B]/5 text-sm font-medium rounded transition-colors">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3"/>
                  </svg>
                  Download Catalogue
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#F5F7FA] py-12 lg:py-16 border-t border-[#E8ECF2]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-[#0D2547] mb-6">About Vartech Calibrators — mV, mA, Temperature & Process</h2>
      <div class="space-y-4 text-sm text-[#64748B] leading-relaxed">
        <p>
          Process calibrators are indispensable tools for instrument engineers and calibration technicians working on industrial process control loops, temperature transmitters and field instruments. The Vartech calibrator range covers three essential applications: temperature/RTD/T/C calibration (V 7220 R), 4–20 mA loop calibration with waveform output (V 7221 B) and precision mA/voltage source-and-measure (MS 7221).
        </p>
        <p>
          The MS 7221 stands out for its very high loop current accuracy of 0.015% with 1 µA resolution and a built-in 24 V loop supply — enabling single-instrument calibration of 2-wire transmitters without a separate power source. The V 7221 B's sawtooth and triangle wave outputs are particularly useful for valve stroke testing and control loop checking.
        </p>
        <p>
          CIE Instruments (Cambridge Instruments &amp; Engg. Co., Howrah) is an authorised Vartech dealer for India. We supply Vartech calibrators to process plants, instrumentation maintenance teams, calibration laboratories and industrial facilities across India — including Kolkata, Howrah, Bhubaneswar, Delhi, Mumbai, Bengaluru, Hyderabad, Chennai, Ahmedabad, Pune, Lucknow and Chandigarh.
        </p>
        <p>
          For pricing and availability, <a href="/contact/" class="text-[#1B3A5B] hover:underline font-medium">contact our team</a> or enquire via WhatsApp.
        </p>
      </div>
      <div class="mt-8 pt-6 border-t border-[#E8ECF2]">
        <p class="text-xs text-[#94a3b8]">
          Cambridge Instruments &amp; Engg. Co. (CIE) — manufacturer of precision electrical test instruments in Howrah since 1963, and authorised dealer for Vartech.
        </p>
      </div>
    </div>
  </section>

  <CTABand />
</Base>
