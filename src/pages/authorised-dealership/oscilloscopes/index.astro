---
import Base from '../../../layouts/Base.astro';
import { u } from '../../../utils/url';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CTABand from '../../../components/CTABand.astro';
import products from '../../../data/vartech-oscilloscopes.json';

const pageTitle = 'Vartech Oscilloscopes — Authorised Dealer India | CIE Instruments';
const pageDesc =
  'Buy Vartech oscilloscopes in India — analog CROs from 20–30 MHz and digital storage oscilloscopes from 80–150 MHz with 1 GS/s, 7-inch TFT and USB. CIE Instruments is an authorised Vartech dealer supplying engineers and institutions across India from Howrah.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cieinstruments.in/' },
    { '@type': 'ListItem', position: 2, name: 'Authorised Dealership', item: 'https://cieinstruments.in/authorised-dealership/' },
    { '@type': 'ListItem', position: 3, name: 'Vartech Oscilloscopes', item: 'https://cieinstruments.in/authorised-dealership/oscilloscopes/' },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Vartech Oscilloscopes',
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: `${p.model} — ${p.name}`,
      description: p.description,
      brand: { '@type': 'Brand', name: 'Vartech' },
      offers: {
        '@type': 'Offer',
        seller: { '@type': 'Organization', name: 'Cambridge Instruments & Engg. Co.' },
        availability: 'https://schema.org/InStock',
        priceCurrency: 'INR',
        price: '0',
        priceSpecification: { '@type': 'PriceSpecification', description: 'Contact for price' },
      },
    },
  })),
};
---

<Base title={pageTitle} description={pageDesc} ogImage={u('/images/vartech/vartech-logo.avif')} rawTitle>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs crumbs={[
        { label: 'Authorised Dealership', href: u('/authorised-dealership/') },
        { label: 'Vartech Oscilloscopes' },
      ]} />
      <p class="eyebrow mt-4 mb-3">— Vartech® Oscilloscopes</p>
      <h1 class="text-3xl sm:text-4xl font-black text-[#0D2547]">Vartech Oscilloscopes</h1>
      <p class="mt-3 text-[#64748B] max-w-2xl leading-relaxed">
        As the authorised dealer for Vartech in India, CIE Instruments supplies the complete Vartech oscilloscope range — from classic 20 MHz and 30 MHz dual-channel analog CROs to high-performance 80–150 MHz digital storage oscilloscopes with 1 GS/s sampling, 7-inch TFT displays and USB interfaces.
      </p>
    </div>
  </div>

  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-lg font-bold text-[#0D2547]">{products.length} Vartech oscilloscope models</h2>
        <a href={u('/authorised-dealership/')} class="text-sm text-[#64748B] hover:text-[#1B3A5B] transition-colors">← Authorised Dealership</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {products.map(p => (
          <article class="bg-white rounded-lg border border-[#E8ECF2] overflow-hidden flex flex-col transition-shadow duration-200 hover:shadow-md">
            <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] h-44 flex items-center justify-center relative">
              <img
                src={u(`/images/vartech/oscilloscopes/${p.images[0]}`)}
                alt={`${p.model} — ${p.name}`}
                width="400" height="400"
                class="object-contain h-36 w-auto"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
              />
              <div class="hidden absolute inset-0 flex-col items-center justify-center gap-2 text-[#b0bec5]">
                <svg class="w-12 h-12 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/>
                  <path d="M3 9l4-4 4 4 4-4 4 4" stroke-width="1.5"/>
                </svg>
                <span class="text-xs font-mono uppercase tracking-wider opacity-50">Image coming soon</span>
              </div>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <p class="model-code text-xs mb-1">{p.model}</p>
              <h3 class="font-bold text-[#0D2547] text-base mb-2 leading-snug">{p.name}</h3>
              <p class="text-sm text-[#64748B] mb-4 flex-1 line-clamp-3">{p.tagline}</p>
              <div class="flex flex-col gap-2 mt-auto">
                <a href={u(`/authorised-dealership/oscilloscopes/${p.id}/`)}
                  class="text-center px-4 py-2.5 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-sm font-semibold rounded transition-colors">
                  View Details & Specs
                </a>
                <a href={u(`/downloads/vartech/oscilloscopes/${p.catalogue}`)}
                  target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 text-center px-4 py-2 border border-[#1B3A5B] text-[#1B3A5B] hover:bg-[#1B3A5B]/5 text-sm font-medium rounded transition-colors">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3"/>
                  </svg>
                  Download Catalogue
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#F5F7FA] py-12 lg:py-16 border-t border-[#E8ECF2]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-[#0D2547] mb-6">About Vartech Oscilloscopes</h2>
      <div class="space-y-4 text-sm text-[#64748B] leading-relaxed">
        <p>
          Vartech offers a comprehensive oscilloscope range for every budget and application — from the proven SS-5020B and SS-5030B analog CROs for routine waveform observation and service work, to the SS-5030BC with built-in component tester, and high-specification digital storage oscilloscopes (DSOs) covering 80 MHz (4-channel), 100 MHz and 150 MHz with 1 GS/s real-time sampling and 7-inch TFT colour displays.
        </p>
        <p>
          CIE Instruments (Cambridge Instruments &amp; Engg. Co., Howrah) is an authorised Vartech dealer and distributor for India. We supply Vartech oscilloscopes to electronics labs, engineering colleges, R&amp;D departments, production test facilities and service workshops across India — including Kolkata, Howrah, Bhubaneswar, Delhi, Mumbai, Bengaluru, Hyderabad, Chennai, Ahmedabad, Pune, Lucknow and Chandigarh.
        </p>
        <p>
          For pricing, availability or technical guidance on selecting the right Vartech oscilloscope, <a href="/contact/" class="text-[#1B3A5B] hover:underline font-medium">contact our team</a> or enquire via WhatsApp.
        </p>
      </div>
      <div class="mt-8 pt-6 border-t border-[#E8ECF2]">
        <p class="text-xs text-[#94a3b8]">
          Cambridge Instruments &amp; Engg. Co. (CIE) — manufacturer of precision electrical test instruments in Howrah since 1963, and authorised dealer for Vartech.
        </p>
      </div>
    </div>
  </section>

  <CTABand />
</Base>
