---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import posts from '../../data/blog.json';
import MultimeterGuide from '../../content/blog/what-is-a-multimeter.astro';
import ClampMeterGuide from '../../content/blog/how-to-use-a-clamp-meter.astro';
import OhmsLaw from '../../content/blog/ohms-law-explained.astro';
import ContinuityGuide from '../../content/blog/continuity-testing-guide.astro';
import ClampVsMultimeter from '../../content/blog/clamp-meter-vs-multimeter.astro';

export function getStaticPaths() {
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = posts.find(p => p.slug === slug)!;

const contentMap: Record<string, any> = {
  'what-is-a-multimeter': MultimeterGuide,
  'how-to-use-a-clamp-meter': ClampMeterGuide,
  'ohms-law-explained': OhmsLaw,
  'continuity-testing-guide': ContinuityGuide,
  'clamp-meter-vs-multimeter': ClampVsMultimeter,
};

const tocMap: Record<string, { id: string; label: string }[]> = {
  'what-is-a-multimeter': [
    { id: 'three-quantities', label: 'What It Measures' },
    { id: 'how-it-works', label: 'How It Works Inside' },
    { id: 'parts', label: 'Parts of a Multimeter' },
    { id: 'extra-functions', label: 'Extra Functions' },
    { id: 'autoranging', label: 'Auto vs Manual Range' },
    { id: 'how-to-use', label: 'How to Use One' },
    { id: 'safety', label: 'Safety Rules' },
  ],
  'how-to-use-a-clamp-meter': [
    { id: 'how-it-works', label: 'How It Works' },
    { id: 'parts', label: 'Parts Explained' },
    { id: 'measure-ac', label: 'Measuring AC Current' },
    { id: 'measure-dc', label: 'Measuring DC Current' },
    { id: 'probes', label: 'Using Probes' },
    { id: 'inrush', label: 'Inrush Current' },
    { id: 'mistakes', label: 'Common Mistakes' },
  ],
  'ohms-law-explained': [
    { id: 'what-is', label: "What Is Ohm's Law?" },
    { id: 'triangle', label: 'The OHM Triangle' },
    { id: 'physics', label: 'The Physics' },
    { id: 'testers', label: 'Inside Every Tester' },
    { id: 'power', label: "Watt's Law" },
    { id: 'examples', label: 'Practical Examples' },
    { id: 'limits', label: 'Limits of the Law' },
  ],
  'continuity-testing-guide': [
    { id: 'what-is', label: 'What Is Continuity?' },
    { id: 'how-it-works', label: 'How the Mode Works' },
    { id: 'what-it-finds', label: 'What It Can Find' },
    { id: 'how-to-test', label: 'Step-by-Step Tests' },
    { id: 'vs-resistance', label: 'Continuity vs Resistance' },
    { id: 'limits', label: 'Limitations' },
  ],
  'clamp-meter-vs-multimeter': [
    { id: 'core-difference', label: 'The Core Difference' },
    { id: 'comparison', label: 'Side-by-Side' },
    { id: 'choose-multimeter', label: 'When to Choose DMM' },
    { id: 'choose-clamp', label: 'When to Choose Clamp' },
    { id: 'can-clamp-replace', label: 'Can Clamp Replace DMM?' },
    { id: 'which-first', label: 'Which to Buy First?' },
  ],
};

const Content = contentMap[slug];
const toc = tocMap[slug] ?? [];
const otherPosts = posts.filter(p => p.slug !== slug).slice(0, 3);

const categoryColors: Record<string, string> = {
  'Guides':       'bg-violet-100 text-violet-700 border-violet-200',
  'How-To':       'bg-blue-100 text-blue-700 border-blue-200',
  'Physics':      'bg-amber-100 text-amber-700 border-amber-200',
  'Buying Guide': 'bg-emerald-100 text-emerald-700 border-emerald-200',
};
const catStyle = categoryColors[post.category] ?? 'bg-gray-100 text-gray-700 border-gray-200';
---

<Base
  title={`${post.title} | CIE Instruments`}
  description={post.description}
>
  <!-- Hero -->
  <div class="bg-gradient-to-br from-[#0D1B2A] via-[#1B3A5B] to-[#0D1B2A] border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
      <!-- Breadcrumb -->
      <nav class="mb-7" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-xs text-[#94a3b8] font-mono">
          <li><a href={u('/')} class="hover:text-white transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-white/30">›</li>
          <li><a href={u('/blog/')} class="hover:text-white transition-colors">Blog</a></li>
          <li aria-hidden="true" class="text-white/30">›</li>
          <li class="text-white/60 truncate max-w-[200px]">{post.category}</li>
        </ol>
      </nav>

      <span class={`inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border mb-5 ${catStyle}`}>
        {post.category}
      </span>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight max-w-3xl mb-6">
        {post.title}
      </h1>

      <p class="text-[#94a3b8] text-lg max-w-2xl mb-8 leading-relaxed">{post.description}</p>

      <div class="flex flex-wrap items-center gap-4 text-sm text-[#64748b]">
        <!-- Author chip -->
        <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-3 py-1.5">
          <div class="w-6 h-6 rounded-full bg-[#E0252E] flex items-center justify-center text-white text-[10px] font-bold">CIE</div>
          <span class="text-[#94a3b8] text-xs font-medium">CIE Instruments</span>
        </div>
        <!-- Date -->
        <div class="flex items-center gap-1.5 text-[#94a3b8] text-xs">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5"/></svg>
          <time datetime={post.publishDate}>
            {new Date(post.publishDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>
        <!-- Read time -->
        <div class="flex items-center gap-1.5 text-[#94a3b8] text-xs">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {post.readTime}
        </div>
      </div>
    </div>
  </div>

  <!-- Body: prose + sidebar -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="flex gap-12 items-start">

      <!-- ── Article content ── -->
      <article class="min-w-0 flex-1 blog-content">
        <Content />

        <!-- Bottom CTA -->
        <div class="mt-16 rounded-2xl overflow-hidden">
          <div class="bg-gradient-to-br from-[#0D1B2A] to-[#1B3A5B] p-8 text-center">
            <p class="text-xs font-mono uppercase tracking-widest text-[#E0252E] mb-2">Need an instrument?</p>
            <h2 class="text-2xl font-bold text-white mb-3">Shop CIE's Range of Testers</h2>
            <p class="text-[#94a3b8] text-sm mb-7 max-w-md mx-auto">Multimeters, clamp meters, insulation testers and more — manufactured in Howrah, India since 1963.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href={u('/products/')} class="px-6 py-3 bg-[#E0252E] hover:bg-[#D72631] text-white text-sm font-semibold rounded-lg transition-colors">
                Browse Products
              </a>
              <a href={u('/contact/')} class="px-6 py-3 border border-white/20 hover:border-white/50 text-white text-sm font-semibold rounded-lg transition-colors">
                Contact Us
              </a>
            </div>
          </div>
        </div>
      </article>

      <!-- ── Sidebar ── -->
      <aside class="hidden lg:block w-72 shrink-0">
        <div class="sticky top-24 space-y-6">

          <!-- TOC -->
          {toc.length > 0 && (
            <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5">
              <p class="text-xs font-mono uppercase tracking-widest text-[#64748b] mb-4">In this article</p>
              <nav>
                <ul class="space-y-1" id="toc-list">
                  {toc.map(item => (
                    <li>
                      <a
                        href={`#${item.id}`}
                        data-toc
                        class="flex items-center gap-2 text-sm text-gray-600 hover:text-[#E0252E] py-1 px-2 rounded-lg hover:bg-red-50 transition-colors group"
                      >
                        <span class="w-1 h-1 rounded-full bg-gray-300 group-hover:bg-[#E0252E] transition-colors shrink-0"></span>
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          <!-- Products CTA card -->
          <div class="bg-[#0D1B2A] rounded-2xl p-5 text-center">
            <div class="w-10 h-10 rounded-full bg-[#E0252E]/20 border border-[#E0252E]/30 flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-[#E0252E]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
              </svg>
            </div>
            <p class="text-white font-bold text-sm mb-1">CIE Instruments</p>
            <p class="text-[#94a3b8] text-xs mb-4">Making precision test instruments since 1963</p>
            <a href={u('/products/')} class="block w-full py-2 bg-[#E0252E] hover:bg-[#D72631] text-white text-xs font-semibold rounded-lg transition-colors">
              View Products →
            </a>
          </div>

          <!-- Related posts -->
          {otherPosts.length > 0 && (
            <div class="border border-gray-200 rounded-2xl p-5">
              <p class="text-xs font-mono uppercase tracking-widest text-[#64748b] mb-4">More Articles</p>
              <div class="space-y-3">
                {otherPosts.map(p => (
                  <a href={u(`/blog/${p.slug}/`)} class="block group">
                    <p class="text-xs text-[#E0252E] font-mono uppercase tracking-widest mb-0.5">{p.category}</p>
                    <p class="text-sm font-semibold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors leading-snug">{p.title}</p>
                    <p class="text-xs text-gray-400 mt-0.5">{p.readTime}</p>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>

  <!-- Mobile: related posts -->
  {otherPosts.length > 0 && (
    <section class="lg:hidden bg-gray-50 border-t border-gray-200 py-10">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-lg font-bold text-[#0D1B2A] mb-5">More from the blog</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {otherPosts.slice(0, 2).map(p => (
            <a href={u(`/blog/${p.slug}/`)} class="bg-white border border-gray-200 rounded-xl p-4 group">
              <p class="text-xs text-[#E0252E] font-mono uppercase tracking-widest mb-1">{p.category}</p>
              <p class="text-sm font-bold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors leading-snug">{p.title}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style is:global>
/* ── Blog article typography ── */
.blog-content h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #0D1B2A;
  margin-top: 2.75rem;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid #E8ECF2;
  scroll-margin-top: 6rem;
}
.blog-content h3 {
  font-size: 1.15rem;
  font-weight: 700;
  color: #1B3A5B;
  margin-top: 2rem;
  margin-bottom: 0.6rem;
  scroll-margin-top: 6rem;
}
.blog-content p {
  color: #374151;
  line-height: 1.8;
  margin-bottom: 1.1rem;
  font-size: 1.025rem;
}
.blog-content ul, .blog-content ol {
  margin: 1rem 0 1.4rem 1.2rem;
  color: #374151;
  font-size: 1.025rem;
}
.blog-content ul { list-style: none; padding: 0; }
.blog-content ul li {
  padding-left: 1.5rem;
  position: relative;
  margin-bottom: 0.5rem;
  line-height: 1.7;
}
.blog-content ul li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.6rem;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #E0252E;
}
.blog-content ol { list-style: none; counter-reset: ol-counter; padding: 0; }
.blog-content ol li {
  counter-increment: ol-counter;
  padding-left: 2rem;
  position: relative;
  margin-bottom: 0.6rem;
  line-height: 1.7;
}
.blog-content ol li::before {
  content: counter(ol-counter);
  position: absolute;
  left: 0;
  top: 0.05rem;
  width: 1.4rem;
  height: 1.4rem;
  border-radius: 50%;
  background: #0D1B2A;
  color: white;
  font-size: 0.72rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.blog-content strong { color: #0D1B2A; font-weight: 700; }
.blog-content em { color: #1B3A5B; }
.blog-content a { color: #E0252E; text-decoration: none; font-weight: 500; }
.blog-content a:hover { text-decoration: underline; }
.blog-content code {
  background: #FEF2F2;
  color: #E0252E;
  padding: 0.15em 0.4em;
  border-radius: 4px;
  font-size: 0.88em;
  font-family: 'IBM Plex Mono', monospace;
}

/* TOC active state */
.toc-active {
  color: #E0252E !important;
  background: #FEF2F2 !important;
  font-weight: 600;
}
.toc-active span { background: #E0252E !important; }
</style>

<script>
// Highlight active TOC item on scroll
const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc]');
const headings = Array.from(document.querySelectorAll<HTMLElement>('.blog-content h2, .blog-content h3'));

function setActive() {
  const scrollY = window.scrollY + 120;
  let active = headings[0];
  for (const h of headings) {
    if (h.offsetTop <= scrollY) active = h;
  }
  tocLinks.forEach(link => {
    link.classList.remove('toc-active');
    if (active && link.getAttribute('href') === `#${active.id}`) {
      link.classList.add('toc-active');
    }
  });
}

window.addEventListener('scroll', setActive, { passive: true });
setActive();
</script>
