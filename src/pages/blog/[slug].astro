---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import posts from '../../data/blog.json';
import MultimeterGuide from '../../content/blog/what-is-a-multimeter.astro';
import ClampMeterGuide from '../../content/blog/how-to-use-a-clamp-meter.astro';
import OhmsLaw from '../../content/blog/ohms-law-explained.astro';
import ContinuityGuide from '../../content/blog/continuity-testing-guide.astro';
import ClampVsMultimeter from '../../content/blog/clamp-meter-vs-multimeter.astro';

export function getStaticPaths() {
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = posts.find(p => p.slug === slug)!;

const contentMap: Record<string, any> = {
  'what-is-a-multimeter': MultimeterGuide,
  'how-to-use-a-clamp-meter': ClampMeterGuide,
  'ohms-law-explained': OhmsLaw,
  'continuity-testing-guide': ContinuityGuide,
  'clamp-meter-vs-multimeter': ClampVsMultimeter,
};

const tocMap: Record<string, { id: string; label: string }[]> = {
  'what-is-a-multimeter': [
    { id: 'three-quantities', label: 'What It Measures' },
    { id: 'how-it-works', label: 'How It Works Inside' },
    { id: 'parts', label: 'Parts of a Multimeter' },
    { id: 'extra-functions', label: 'Extra Functions' },
    { id: 'autoranging', label: 'Auto vs Manual Range' },
    { id: 'how-to-use', label: 'How to Use One' },
    { id: 'safety', label: 'Safety Rules' },
  ],
  'how-to-use-a-clamp-meter': [
    { id: 'how-it-works', label: 'How It Works' },
    { id: 'parts', label: 'Parts Explained' },
    { id: 'measure-ac', label: 'Measuring AC Current' },
    { id: 'measure-dc', label: 'Measuring DC Current' },
    { id: 'probes', label: 'Using Probes' },
    { id: 'inrush', label: 'Inrush Current' },
    { id: 'mistakes', label: 'Common Mistakes' },
  ],
  'ohms-law-explained': [
    { id: 'what-is', label: "What Is Ohm's Law?" },
    { id: 'triangle', label: 'The OHM Triangle' },
    { id: 'physics', label: 'The Physics' },
    { id: 'testers', label: 'Inside Every Tester' },
    { id: 'power', label: "Watt's Law" },
    { id: 'examples', label: 'Practical Examples' },
    { id: 'limits', label: 'Limits of the Law' },
  ],
  'continuity-testing-guide': [
    { id: 'what-is', label: 'What Is Continuity?' },
    { id: 'how-it-works', label: 'How the Mode Works' },
    { id: 'what-it-finds', label: 'What It Can Find' },
    { id: 'how-to-test', label: 'Step-by-Step Tests' },
    { id: 'vs-resistance', label: 'Continuity vs Resistance' },
    { id: 'limits', label: 'Limitations' },
  ],
  'clamp-meter-vs-multimeter': [
    { id: 'core-difference', label: 'The Core Difference' },
    { id: 'comparison', label: 'Side-by-Side' },
    { id: 'choose-multimeter', label: 'When to Choose DMM' },
    { id: 'choose-clamp', label: 'When to Choose Clamp' },
    { id: 'can-clamp-replace', label: 'Can Clamp Replace DMM?' },
    { id: 'which-first', label: 'Which to Buy First?' },
  ],
};

const Content = contentMap[slug];
const toc = tocMap[slug] ?? [];
const otherPosts = posts.filter(p => p.slug !== slug).slice(0, 3);

const categoryColors: Record<string, string> = {
  'Guides':       'text-violet-600 bg-violet-50 border-violet-200',
  'How-To':       'text-blue-600 bg-blue-50 border-blue-200',
  'Physics':      'text-amber-700 bg-amber-50 border-amber-200',
  'Buying Guide': 'text-emerald-700 bg-emerald-50 border-emerald-200',
};
const catStyle = categoryColors[post.category] ?? 'text-gray-600 bg-gray-50 border-gray-200';
---

<Base
  title={`${post.title} | CIE Instruments`}
  description={post.description}
>

  <!-- ── Article Header — gray bg, clearly framed ── -->
  <div class="bg-[#F5F7FA] border-b-2 border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-10">

      <!-- Breadcrumb -->
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-xs text-gray-400 font-mono">
          <li><a href={u('/')} class="hover:text-[#0D1B2A] transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-gray-300">›</li>
          <li><a href={u('/blog/')} class="hover:text-[#0D1B2A] transition-colors">Insights</a></li>
          <li aria-hidden="true" class="text-gray-300">›</li>
          <li class="text-gray-500 truncate max-w-[180px]">{post.category}</li>
        </ol>
      </nav>

      <span class={`inline-block text-[11px] font-bold uppercase tracking-widest px-2.5 py-1 rounded border mb-5 ${catStyle}`}>
        {post.category}
      </span>

      <h1 class="text-3xl sm:text-4xl lg:text-[2.6rem] font-bold text-[#0D1B2A] leading-tight tracking-tight max-w-3xl mb-4">
        {post.title}
      </h1>

      <p class="text-[#64748b] text-base max-w-2xl mb-7 leading-relaxed">{post.description}</p>

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400">
        <div class="flex items-center gap-2">
          <img src={u('/logo/cie-logo.png')} alt="CIE Instruments" width="20" height="20" class="object-contain shrink-0" />
          <span class="text-gray-600 font-medium text-sm">CIE Instruments</span>
        </div>
        <span class="text-gray-300">·</span>
        <time datetime={post.publishDate} class="font-mono text-xs text-gray-500">
          {new Date(post.publishDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
        </time>
        <span class="text-gray-300">·</span>
        <span class="font-mono text-xs text-gray-500">{post.readTime}</span>
      </div>
    </div>
  </div>

  <!-- ── Article body — white bg, starts here ── -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="flex gap-14 items-start">

      <!-- Article content -->
      <article class="min-w-0 flex-1 blog-content">
        <Content />
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:block w-64 shrink-0">
        <div class="sticky top-24 space-y-6">

          <!-- TOC -->
          {toc.length > 0 && (
            <div class="border border-gray-200 rounded-xl p-5">
              <p class="text-[10px] font-mono uppercase tracking-[0.16em] text-[#94a3b8] mb-4">In this article</p>
              <nav>
                <ul class="space-y-0.5" id="toc-list">
                  {toc.map(item => (
                    <li>
                      <a
                        href={`#${item.id}`}
                        data-toc
                        class="flex items-center gap-2.5 text-sm text-[#64748b] hover:text-[#0D1B2A] py-1.5 px-2 rounded-lg hover:bg-gray-50 transition-colors group"
                      >
                        <span class="w-1 h-1 rounded-full bg-gray-300 group-hover:bg-[#E0252E] transition-colors shrink-0"></span>
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          <!-- CIE brand card -->
          <div class="border border-gray-200 rounded-xl p-5">
            <img
              src={u('/logo/cie-logo.png')}
              alt="CIE Instruments"
              width="48"
              height="48"
              class="mb-4 object-contain"
            />
            <p class="font-bold text-[#0D1B2A] text-sm mb-1">Cambridge Instruments &amp; Engg. Co.</p>
            <p class="text-xs text-[#64748b] mb-4 leading-relaxed">Precision test and measurement instruments since 1963.</p>
            <a href={u('/products/')} class="block w-full py-2.5 bg-[#0D1B2A] hover:bg-[#1B3A5B] text-white text-xs font-semibold rounded text-center transition-colors">
              Browse Products
            </a>
          </div>

          <!-- More articles -->
          {otherPosts.length > 0 && (
            <div class="border border-gray-200 rounded-xl p-5">
              <p class="text-[10px] font-mono uppercase tracking-[0.16em] text-[#94a3b8] mb-4">More Articles</p>
              <div class="space-y-4">
                {otherPosts.map(p => (
                  <a href={u(`/blog/${p.slug}/`)} class="block group">
                    <p class="text-[10px] font-mono uppercase tracking-widest text-[#E0252E] mb-0.5">{p.category}</p>
                    <p class="text-sm font-semibold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors leading-snug">{p.title}</p>
                    <p class="text-xs text-gray-400 mt-0.5">{p.readTime}</p>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>

  <!-- ── Bottom CTA — red card, same as blog index, separates from footer ── -->
  <section class="bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="rounded-2xl bg-[#E0252E] overflow-hidden">
        <div class="flex flex-col md:flex-row md:items-center gap-8 px-10 py-10">
          <div class="flex-1">
            <div class="text-red-200 text-[11px] font-mono uppercase tracking-[0.18em] mb-3">Cambridge Instruments &amp; Engg. Co. · Est. 1963</div>
            <div class="text-white font-bold text-2xl md:text-3xl leading-snug mb-3">Looking for an instrument,<br/>not just an answer?</div>
            <div class="text-red-100 text-sm leading-relaxed max-w-md">Multimeters, clamp meters, insulation testers, earth testers — manufactured in Howrah, India. Pan-India supply.</div>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 shrink-0">
            <a href={u('/products/')} style="color: #E0252E;" class="px-7 py-3 bg-white hover:bg-gray-50 text-sm font-bold rounded-lg transition-colors text-center no-underline">
              Browse Products
            </a>
            <a href={u('/contact/')} style="color: white;" class="px-7 py-3 border-2 border-white/40 hover:border-white text-sm font-semibold rounded-lg transition-colors text-center no-underline">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile: more articles -->
  {otherPosts.length > 0 && (
    <section class="lg:hidden border-t border-gray-100 bg-gray-50 py-10">
      <div class="max-w-6xl mx-auto px-4">
        <p class="text-[10px] font-mono uppercase tracking-[0.16em] text-[#94a3b8] mb-5">More Articles</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {otherPosts.slice(0, 2).map(p => (
            <a href={u(`/blog/${p.slug}/`)} class="bg-white border border-gray-200 rounded-xl p-5 group hover:border-[#0D1B2A] transition-colors">
              <p class="text-[10px] font-mono uppercase tracking-widest text-[#E0252E] mb-1.5">{p.category}</p>
              <p class="text-sm font-bold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors leading-snug">{p.title}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style is:global>
/* ── Blog article typography ── */
.blog-content h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #0D1B2A;
  margin-top: 2.75rem;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid #E8ECF2;
  scroll-margin-top: 6rem;
  letter-spacing: -0.01em;
}
.blog-content h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: #1B3A5B;
  margin-top: 2rem;
  margin-bottom: 0.6rem;
  scroll-margin-top: 6rem;
}
.blog-content > p,
.blog-content > h2 + p,
.blog-content > h3 + p {
  color: #374151;
  line-height: 1.85;
  margin-bottom: 1.1rem;
  font-size: 1.025rem;
}
/* Standalone p that isn't a direct child of a section heading chain */
.blog-content p {
  color: #374151;
  line-height: 1.85;
  margin-bottom: 1.1rem;
  font-size: 1.025rem;
}
/* .ci: only p tags inside inherit color — divs keep their explicit Tailwind classes */
.blog-content .ci p {
  color: inherit !important;
  line-height: inherit;
  font-size: inherit;
  margin-bottom: 0;
}
.blog-content ul, .blog-content ol {
  margin: 0.75rem 0 1.25rem 0;
  color: #374151;
  font-size: 1rem;
  padding: 0;
}
.blog-content ul { list-style: none; }
.blog-content ul li {
  padding-left: 1.4rem;
  position: relative;
  margin-bottom: 0.5rem;
  line-height: 1.75;
}
.blog-content ul li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.65rem;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #E0252E;
}
.blog-content ol { list-style: none; counter-reset: ol-counter; }
.blog-content ol li {
  counter-increment: ol-counter;
  padding-left: 2rem;
  position: relative;
  margin-bottom: 0.6rem;
  line-height: 1.75;
}
.blog-content ol li::before {
  content: counter(ol-counter);
  position: absolute;
  left: 0;
  top: 0.1rem;
  width: 1.3rem;
  height: 1.3rem;
  border-radius: 50%;
  background: #0D1B2A;
  color: white;
  font-size: 0.7rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.blog-content strong { color: #0D1B2A; font-weight: 700; }
.blog-content em { color: #1B3A5B; }
.blog-content a { color: #E0252E; text-decoration: none; font-weight: 500; }
.blog-content a:hover { text-decoration: underline; }
.blog-content code {
  background: #FEF2F2;
  color: #C0192B;
  padding: 0.15em 0.4em;
  border-radius: 3px;
  font-size: 0.87em;
  font-family: 'IBM Plex Mono', monospace;
}

/* TOC active */
.toc-active {
  color: #0D1B2A !important;
  background: #F8F9FA !important;
  font-weight: 600;
}
.toc-active span { background: #E0252E !important; }
</style>

<script>
const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc]');
const headings = Array.from(document.querySelectorAll<HTMLElement>('.blog-content h2, .blog-content h3'));

function setActive() {
  const scrollY = window.scrollY + 130;
  let active = headings[0];
  for (const h of headings) {
    if (h.offsetTop <= scrollY) active = h;
  }
  tocLinks.forEach(link => {
    link.classList.remove('toc-active');
    if (active && link.getAttribute('href') === `#${active.id}`) link.classList.add('toc-active');
  });
}
window.addEventListener('scroll', setActive, { passive: true });
setActive();
</script>
