---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import posts from '../../data/blog.json';
import MultimeterGuide from '../../content/blog/what-is-a-multimeter.astro';
import ClampMeterGuide from '../../content/blog/how-to-use-a-clamp-meter.astro';
import OhmsLaw from '../../content/blog/ohms-law-explained.astro';
import ContinuityGuide from '../../content/blog/continuity-testing-guide.astro';
import ClampVsMultimeter from '../../content/blog/clamp-meter-vs-multimeter.astro';

export function getStaticPaths() {
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = posts.find(p => p.slug === slug)!;

const contentMap: Record<string, any> = {
  'what-is-a-multimeter': MultimeterGuide,
  'how-to-use-a-clamp-meter': ClampMeterGuide,
  'ohms-law-explained': OhmsLaw,
  'continuity-testing-guide': ContinuityGuide,
  'clamp-meter-vs-multimeter': ClampVsMultimeter,
};

const Content = contentMap[slug];

const otherPosts = posts.filter(p => p.slug !== slug).slice(0, 3);
---

<Base
  title={`${post.title} | CIE Instruments`}
  description={post.description}
>

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 py-3" aria-label="Breadcrumb">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-xs text-gray-500 font-mono">
        <li><a href={u('/')} class="hover:text-[#E0252E] transition-colors">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href={u('/blog/')} class="hover:text-[#E0252E] transition-colors">Blog</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-gray-700 truncate max-w-[200px]">{post.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Article header -->
  <header class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <div class="mb-4">
      <span class="inline-block text-xs font-semibold font-mono uppercase tracking-widest text-[#E0252E] bg-red-50 border border-red-100 rounded-full px-3 py-1">
        {post.category}
      </span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-[#0D1B2A] leading-tight mb-4">{post.title}</h1>
    <div class="flex items-center gap-3 text-sm text-gray-500">
      <span>CIE Instruments</span>
      <span>·</span>
      <time datetime={post.publishDate}>
        {new Date(post.publishDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
      </time>
      <span>·</span>
      <span>{post.readTime}</span>
    </div>
  </header>

  <!-- Article body -->
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="prose prose-lg prose-slate max-w-none
      prose-headings:text-[#0D1B2A] prose-headings:font-bold
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-gray-700 prose-p:leading-relaxed
      prose-li:text-gray-700
      prose-strong:text-[#0D1B2A]
      prose-a:text-[#E0252E] prose-a:no-underline hover:prose-a:underline
      prose-blockquote:border-l-[#E0252E] prose-blockquote:bg-red-50 prose-blockquote:rounded-r-lg prose-blockquote:py-1
      prose-table:text-sm
      prose-th:bg-[#0D1B2A] prose-th:text-white prose-th:font-semibold
      prose-tr:border-gray-200
      prose-code:text-[#E0252E] prose-code:bg-red-50 prose-code:rounded prose-code:px-1">
      <Content />
    </div>

    <!-- CTA inline -->
    <div class="mt-14 p-7 bg-[#0D1B2A] rounded-2xl text-center">
      <p class="text-xs font-mono uppercase tracking-widest text-[#E0252E] mb-2">Need an instrument?</p>
      <h2 class="text-xl font-bold text-white mb-2">Shop CIE's range of testers</h2>
      <p class="text-[#94a3b8] text-sm mb-6">Multimeters, clamp meters, and more — made in Howrah since 1963.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={u('/products/')} class="px-6 py-2.5 bg-[#E0252E] hover:bg-[#D72631] text-white text-sm font-semibold rounded-lg transition-colors">
          Browse Products
        </a>
        <a href={u('/contact/')} class="px-6 py-2.5 border border-white/20 hover:border-white/40 text-white text-sm font-semibold rounded-lg transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </article>

  <!-- Related posts -->
  {otherPosts.length > 0 && (
    <section class="bg-gray-50 border-t border-gray-200 py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-[#0D1B2A] mb-8">More from the blog</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {otherPosts.map(p => (
            <a href={u(`/blog/${p.slug}/`)} class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md transition-shadow group">
              <span class="text-xs font-mono uppercase text-[#E0252E] tracking-widest">{p.category}</span>
              <h3 class="mt-2 text-base font-bold text-[#0D1B2A] leading-snug group-hover:text-[#E0252E] transition-colors">{p.title}</h3>
              <p class="mt-2 text-xs text-gray-500">{p.readTime}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>
