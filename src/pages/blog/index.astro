---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import posts from '../../data/blog.json';

const sorted = [...posts].sort((a, b) => b.publishDate.localeCompare(a.publishDate));

const categoryColors: Record<string, string> = {
  'Guides':       'text-violet-600 bg-violet-50 border-violet-100',
  'How-To':       'text-blue-600 bg-blue-50 border-blue-100',
  'Physics':      'text-amber-700 bg-amber-50 border-amber-100',
  'Buying Guide': 'text-emerald-700 bg-emerald-50 border-emerald-100',
};
---

<Base
  title="Knowledge Base — Electrical Testing Guides | CIE Instruments"
  description="Technical guides on multimeters, clamp meters, insulation testing, and the physics of electrical measurement — from CIE Instruments, established 1963."
>

  <!-- ── Hero ── -->
  <section class="border-b border-gray-100 bg-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-mono uppercase tracking-[0.18em] text-[#E0252E] mb-5">Knowledge Base</p>
      <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl font-bold text-[#0D1B2A] leading-tight tracking-tight mb-5">
          Electrical Testing<br/>Explained.
        </h1>
        <p class="text-lg text-[#64748b] leading-relaxed">
          Technical articles on measurement instruments, testing methodology, and the physics behind the reading — written for engineers and electricians who need the full picture.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Article grid ── -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">

    <!-- Featured (first article) — full-width editorial card -->
    <a
      href={u(`/blog/${sorted[0].slug}/`)}
      class="group block border border-gray-200 rounded-xl overflow-hidden mb-10 hover:border-[#0D1B2A] transition-colors duration-200"
    >
      <div class="flex flex-col md:flex-row">
        <!-- Left: dark accent strip -->
        <div class="md:w-2 shrink-0 bg-[#E0252E]"></div>
        <!-- Content -->
        <div class="p-8 md:p-10 flex flex-col justify-between flex-1 gap-6">
          <div>
            <span class={`inline-block text-[11px] font-bold uppercase tracking-widest px-2.5 py-1 rounded border mb-5 ${categoryColors[sorted[0].category] ?? 'text-gray-600 bg-gray-50 border-gray-200'}`}>
              {sorted[0].category}
            </span>
            <h2 class="text-2xl md:text-3xl font-bold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors leading-snug mb-4">
              {sorted[0].title}
            </h2>
            <p class="text-[#64748b] leading-relaxed max-w-2xl">{sorted[0].excerpt}</p>
          </div>
          <div class="flex items-center justify-between border-t border-gray-100 pt-5">
            <div class="flex items-center gap-4 text-xs text-gray-400 font-mono">
              <time datetime={sorted[0].publishDate}>
                {new Date(sorted[0].publishDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })}
              </time>
              <span>·</span>
              <span>{sorted[0].readTime}</span>
            </div>
            <span class="text-sm font-semibold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors">
              Read article →
            </span>
          </div>
        </div>
      </div>
    </a>

    <!-- Remaining articles grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6">
      {sorted.slice(1).map(post => (
        <a
          href={u(`/blog/${post.slug}/`)}
          class="group border border-gray-200 rounded-xl p-7 hover:border-[#0D1B2A] transition-colors duration-200 flex flex-col"
        >
          <span class={`inline-block self-start text-[11px] font-bold uppercase tracking-widest px-2.5 py-1 rounded border mb-4 ${categoryColors[post.category] ?? 'text-gray-600 bg-gray-50 border-gray-200'}`}>
            {post.category}
          </span>
          <h2 class="text-lg font-bold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors leading-snug mb-3 flex-1">
            {post.title}
          </h2>
          <p class="text-sm text-[#64748b] leading-relaxed mb-5 line-clamp-2">{post.excerpt}</p>
          <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <div class="flex items-center gap-3 text-xs text-gray-400 font-mono">
              <time datetime={post.publishDate}>
                {new Date(post.publishDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })}
              </time>
              <span>·</span>
              <span>{post.readTime}</span>
            </div>
            <span class="text-xs font-semibold text-[#E0252E]">Read →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Topic index ── -->
  <section class="border-t border-gray-100 py-12 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-mono uppercase tracking-[0.18em] text-[#64748b] mb-5">Topics</p>
      <div class="flex flex-wrap gap-2">
        {[
          'Multimeters','Clamp Meters','Ohm\'s Law','Continuity Testing',
          'Resistance Measurement','AC & DC Current','Electromagnetic Induction',
          'Electrical Safety','Instrument Selection','Insulation Testing',
        ].map(t => (
          <span class="px-3.5 py-1.5 bg-white border border-gray-200 rounded text-sm text-[#374151] font-medium hover:border-[#0D1B2A] transition-colors cursor-default">
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Footer CTA ── -->
  <section class="border-t border-gray-200 bg-[#0D1B2A] py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <div>
        <img src={u('/logo/cie-logo-light.png')} alt="CIE Instruments" class="h-10 w-auto mb-5" />
        <p class="text-white font-semibold text-lg mb-2">Looking for instruments, not just answers?</p>
        <p class="text-[#94a3b8] text-sm max-w-md leading-relaxed">Browse CIE's complete range of multimeters, clamp meters, and insulation testers — manufactured in Howrah, India.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <a href={u('/products/')} class="px-7 py-3 bg-[#E0252E] hover:bg-[#D72631] text-white text-sm font-semibold rounded transition-colors text-center">
          Browse Products
        </a>
        <a href={u('/contact/')} class="px-7 py-3 border border-white/20 hover:border-white/40 text-white text-sm font-semibold rounded transition-colors text-center">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Base>
