---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import posts from '../../data/blog.json';

const sorted = [...posts].sort((a, b) => b.publishDate.localeCompare(a.publishDate));
---

<Base
  title="Blog — Electrical Testing Guides | CIE Instruments"
  description="Expert guides on multimeters, clamp meters, Ohm's Law, continuity testing, and the physics behind electrical measurement instruments."
>

  <!-- Hero -->
  <section class="bg-[#0D1B2A] border-b border-white/10 py-14 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-mono uppercase tracking-widest text-[#E0252E] mb-3">Knowledge Hub</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
        Electrical Testing Guides
      </h1>
      <p class="text-[#94a3b8] text-lg max-w-2xl mx-auto">
        Plain-language articles on how testers work, the physics behind the readings, and which instrument to use — from India's trusted instrument maker since 1963.
      </p>
    </div>
  </section>

  <!-- Post grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {sorted.map(post => (
        <article class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col group">
          <!-- Category chip -->
          <div class="px-6 pt-6">
            <span class="inline-block text-xs font-semibold font-mono uppercase tracking-widest text-[#E0252E] bg-red-50 border border-red-100 rounded-full px-3 py-1">
              {post.category}
            </span>
          </div>

          <div class="px-6 pt-4 pb-6 flex flex-col flex-1">
            <h2 class="text-lg font-bold text-[#0D1B2A] leading-snug mb-3 group-hover:text-[#E0252E] transition-colors">
              <a href={u(`/blog/${post.slug}/`)}>{post.title}</a>
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed flex-1 mb-5">{post.excerpt}</p>

            <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-100">
              <div class="flex items-center gap-2 text-xs text-gray-400">
                <time datetime={post.publishDate}>
                  {new Date(post.publishDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
                <span>·</span>
                <span>{post.readTime}</span>
              </div>
              <a
                href={u(`/blog/${post.slug}/`)}
                class="text-xs font-semibold text-[#E0252E] hover:underline"
              >
                Read →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#0D1B2A] border-t border-white/10 py-14">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Need a specific instrument?</h2>
      <p class="text-[#94a3b8] mb-7">Browse our range of multimeters, clamp meters, and testing equipment — manufactured in Howrah since 1963.</p>
      <a href={u('/products/')} class="inline-block px-7 py-3 bg-[#E0252E] hover:bg-[#D72631] text-white text-sm font-semibold rounded-lg transition-colors">
        Browse Products
      </a>
    </div>
  </section>
</Base>
