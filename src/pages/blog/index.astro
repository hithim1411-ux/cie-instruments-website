---
import Base from '../../layouts/Base.astro';
import { u } from '../../utils/url';
import posts from '../../data/blog.json';

const sorted = [...posts].sort((a, b) => b.publishDate.localeCompare(a.publishDate));

const catBar: Record<string, string> = {
  'Guides':       'bg-violet-500',
  'How-To':       'bg-blue-500',
  'Physics':      'bg-amber-500',
  'Buying Guide': 'bg-emerald-500',
};
const catChip: Record<string, string> = {
  'Guides':       'text-violet-700 bg-violet-50 border-violet-200',
  'How-To':       'text-blue-700 bg-blue-50 border-blue-200',
  'Physics':      'text-amber-700 bg-amber-50 border-amber-200',
  'Buying Guide': 'text-emerald-700 bg-emerald-50 border-emerald-200',
};
---

<Base
  title="Insights — Technical Resources | CIE Instruments"
  description="Technical guides, measurement principles, and instrument selection resources from CIE Instruments — established 1963."
>

  <!-- ════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-18">
      <div class="flex items-center gap-3 mb-5">
        <span class="w-8 h-0.5 bg-[#E0252E]"></span>
        <p class="text-[11px] font-mono uppercase tracking-[0.18em] text-[#E0252E]">Insights</p>
      </div>
      <h1 class="text-5xl sm:text-6xl font-bold text-[#0D1B2A] leading-none tracking-tight mb-5">
        Engineering<br/>Knowledge.
      </h1>
      <p class="text-[#64748b] text-base leading-relaxed max-w-xl">
        Technical articles on measurement instruments, testing methodology, and the physics behind every reading — written for engineers and electricians.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       FEATURED — dark navy
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-[#0D1B2A]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <p class="text-[10px] font-mono uppercase tracking-[0.18em] text-[#94a3b8] mb-8">Latest Article</p>
      <a href={u(`/blog/${sorted[0].slug}/`)} class="group block">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
          <div class="max-w-2xl">
            <span class={`inline-block text-[11px] font-bold uppercase tracking-widest px-2.5 py-1 rounded border mb-6 ${catChip[sorted[0].category] ?? 'text-gray-300 bg-white/10 border-white/20'}`}>
              {sorted[0].category}
            </span>
            <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-5 group-hover:text-[#E0252E] transition-colors">
              {sorted[0].title}
            </h2>
            <p class="text-[#94a3b8] text-base leading-relaxed">{sorted[0].excerpt}</p>
          </div>
          <div class="shrink-0 flex flex-col items-start lg:items-end gap-4">
            <div class="text-[#64748b] font-mono text-xs">
              <time datetime={sorted[0].publishDate}>
                {new Date(sorted[0].publishDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })}
              </time>
              <span class="mx-2">·</span>
              <span>{sorted[0].readTime}</span>
            </div>
            <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#E0252E] group-hover:bg-[#D72631] text-white text-sm font-semibold rounded transition-colors">
              Read Article
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       PODCAST — Spotify embed
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="flex flex-col lg:flex-row lg:items-center gap-10">

        <!-- Left: text -->
        <div class="lg:w-80 shrink-0">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-8 h-0.5 bg-[#1DB954]"></span>
            <p class="text-[11px] font-mono uppercase tracking-[0.18em] text-[#1DB954]">Podcast</p>
          </div>
          <h2 class="text-2xl sm:text-3xl font-bold text-[#0D1B2A] leading-snug mb-4">
            We're on<br/>Spotify.
          </h2>
          <p class="text-[#64748b] text-sm leading-relaxed mb-6">
            Deep-dives on measurement instruments, testing methodology, and electrical engineering — for engineers and electricians who want more than just a manual.
          </p>
          <a
            href="https://open.spotify.com/show/033DkaSuC0aDSc2X2TApyV"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 px-5 py-2.5 bg-[#1DB954] hover:bg-[#17a349] text-white text-sm font-semibold rounded-full transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            Follow on Spotify
          </a>
        </div>

        <!-- Right: embed -->
        <div class="flex-1 min-w-0">
          <iframe
            src="https://open.spotify.com/embed/show/033DkaSuC0aDSc2X2TApyV?utm_source=generator"
            width="100%"
            height="352"
            frameborder="0"
            allowfullscreen=""
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            class="rounded-xl w-full"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       ARTICLE GRID
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <p class="text-[10px] font-mono uppercase tracking-[0.18em] text-[#94a3b8] mb-8">All Articles</p>
      <div class="grid sm:grid-cols-2 gap-5">
        {sorted.slice(1).map(post => (
          <a
            href={u(`/blog/${post.slug}/`)}
            class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col"
          >
            <div class={`h-1 w-full ${catBar[post.category] ?? 'bg-gray-300'}`}></div>
            <div class="p-7 flex flex-col flex-1">
              <span class={`inline-block self-start text-[11px] font-bold uppercase tracking-widest px-2.5 py-1 rounded border mb-4 ${catChip[post.category] ?? 'text-gray-600 bg-gray-50 border-gray-200'}`}>
                {post.category}
              </span>
              <h2 class="text-lg font-bold text-[#0D1B2A] group-hover:text-[#E0252E] transition-colors leading-snug mb-3 flex-1">
                {post.title}
              </h2>
              <p class="text-sm text-[#64748b] leading-relaxed mb-6 line-clamp-2">{post.excerpt}</p>
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <div class="flex items-center gap-3 text-xs text-gray-400 font-mono">
                  <time datetime={post.publishDate}>
                    {new Date(post.publishDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })}
                  </time>
                  <span>·</span>
                  <span>{post.readTime}</span>
                </div>
                <span class="text-xs font-semibold text-[#E0252E] flex items-center gap-1">
                  Read
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       CTA
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-white border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="rounded-xl bg-[#E0252E] overflow-hidden">
        <div class="flex flex-col md:flex-row md:items-center gap-8 px-10 py-10">
          <div class="flex-1">
            <p class="text-red-200 text-[11px] font-mono uppercase tracking-[0.18em] mb-3">Cambridge Instruments &amp; Engg. Co. · Est. 1963</p>
            <p class="text-white font-bold text-2xl md:text-3xl leading-snug mb-3">Looking for an instrument,<br/>not just an answer?</p>
            <p class="text-red-100 text-sm leading-relaxed max-w-md">Multimeters, clamp meters, insulation testers, earth testers — manufactured in Howrah, India. Pan-India supply.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 shrink-0">
            <a href={u('/products/')} class="px-7 py-3 bg-white hover:bg-gray-50 text-[#E0252E] text-sm font-bold rounded transition-colors text-center">
              Browse Products
            </a>
            <a href={u('/contact/')} class="px-7 py-3 border-2 border-white/40 hover:border-white text-white text-sm font-semibold rounded transition-colors text-center">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>
