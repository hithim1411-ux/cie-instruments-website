    const next  = document.getElementById('feat-next') as HTMLButtonElement | null;
    if (track) {
      let cachedW = 286;
      const updateW = () => {
        const first = track.querySelector('article');
        if (first) cachedW = first.offsetWidth + 24;
      };
      requestAnimationFrame(updateW);
      new ResizeObserver(updateW).observe(track);
      prev?.addEventListener('click', () => track.scrollBy({ left: -cachedW * 4, behavior: 'smooth' }));
      next?.addEventListener('click', () => track.scrollBy({ left:  cachedW * 4, behavior: 'smooth' }));
