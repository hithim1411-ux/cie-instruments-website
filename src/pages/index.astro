---
import Base from '../layouts/Base.astro';
import { u } from '../utils/url';
import EyebrowLabel from '../components/EyebrowLabel.astro';
import CTABand from '../components/CTABand.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ProductCard from '../components/ProductCard.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';

const categoryCount = categories.map(cat => ({
  ...cat,
  count: products.filter(p => p.categoryId === cat.id).length,
}));

const featured = products.filter(p => p.featured);

const genericMailto = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent('Quote Request — CIE Instruments')}&body=${encodeURIComponent('Hello CIE team,\n\nI would like to request a quote for: [PRODUCT / MODEL].\n\nRequired rated voltage / resistance range:\nQuantity:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.')}`;
const rts33Mailto  = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent('Quote Request — RTS-33')}&body=${encodeURIComponent('Hello CIE team,\n\nI would like to request a quote for: RTS-33 — Three-Phase Relay Test Set.\n\nRequired rated voltage / resistance range:\nQuantity:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.')}`;


const trustPoints = [
  {
    icon: '📅',
    label: '60+ Years of Service',
    body: "Established 1963. Generations of engineers at India's utilities and railways have relied on the CIE® mark.",
  },
  {
    icon: '🇮🇳',
    label: 'Made in India',
    body: 'Designed and manufactured in Howrah, West Bengal, under the registered CIE® trade mark.',
  },
  {
    icon: '🛡️',
    label: '12-Month Warranty',
    body: 'Every instrument carries a 12-month warranty against manufacturing defects, backed by direct after-sales support.',
  },
  {
    icon: '🔧',
    label: 'Custom Ranges to Order',
    body: 'Non-standard voltage, resistance, or measurement ranges? We manufacture to your specific requirement.',
  },
  {
    icon: '⚡',
    label: 'Trusted by Power Utilities',
    body: 'Preferred by PGCIL, DVC, WBSETCL, Indian Railways, and EPC contractors across India.',
  },
  {
    icon: '🔬',
    label: 'Calibrated Before Despatch',
    body: 'Every instrument is calibrated against reference standards at our facility and a calibration record is maintained.',
  },
];

const industries = [
  { name: 'Power Utilities', desc: 'PGCIL, DVC, state electricity boards, generation companies', icon: '⚡' },
  { name: 'Indian Railways', desc: 'Traction, signalling, and rolling stock testing requirements', icon: '🚂' },
  { name: 'Substation Commissioning', desc: 'EPC contractors and commissioning engineers', icon: '🏗️' },
  { name: 'Industry & Manufacturing', desc: 'Motors, cables, panels, transformers in heavy industry', icon: '🏭' },
  { name: 'Test Laboratories', desc: 'NABL labs, calibration centres, R&D facilities', icon: '🔬' },
  { name: 'EPC Contractors', desc: 'Project commissioning and acceptance testing', icon: '📋' },
];
---

<Base
  title="Home"
  description="CIE — Cambridge Instruments & Engg. Co., Howrah. Manufacturer of insulation testers, relay test sets, oil BDV testers, earth testers and more since 1963. Made in India."
>

  <!-- HERO -->
  <section class="blueprint-bg text-white relative overflow-hidden min-h-[88vh] flex items-center">
    <!-- Left red accent bar -->
    <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#E0252E]"></div>
    <!-- Top-right radial glow -->
    <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full opacity-10 pointer-events-none"
      style="background: radial-gradient(circle at top right, #E0252E 0%, transparent 70%);">
    </div>
    <!-- Bottom-left subtle glow -->
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full opacity-5 pointer-events-none"
      style="background: radial-gradient(circle at bottom left, #1B3A5B 0%, transparent 70%);">
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <!-- Left: copy -->
        <div>
          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-[#E0252E] animate-pulse"></span>
            <span class="text-xs font-mono text-[#b0bec5] tracking-widest uppercase">Howrah, India · CIE® Registered Trade Mark</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.08] mb-6 text-white">
            Instruments<br />
            for <span class="text-[#E0252E]">Accuracy</span><br />
            and Reliability.
          </h1>

          <p class="text-base sm:text-lg text-[#b0bec5] mb-8 max-w-xl leading-relaxed">
            Cambridge Instruments &amp; Engg. Co. is an Indian manufacturer of electrical &amp; electronic
            test and measurement instruments — serving utilities, railways, and industry
            since <span class="font-semibold text-white">1963</span>, under the registered
            <span class="font-mono font-semibold text-white">CIE®</span> mark.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-10">
            <a
              href={genericMailto}
              class="inline-flex items-center justify-center px-7 py-3.5 bg-[#E0252E] hover:bg-[#D72631] text-white font-bold rounded-lg text-sm transition-all hover:shadow-lg hover:shadow-red-900/30"
            >
              Request a Quote
            </a>
            <a
              href={u('/products/')}
              class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/20 hover:border-white/50 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-lg text-sm transition-all"
            >
              View Product Catalogue
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

          <!-- Stats row -->
          <div class="flex gap-10 pt-8 border-t border-white/10">
            {[
              { value: '60+', label: 'Years in Service' },
              { value: '12‑Month', label: 'Warranty on Every Unit' },
              { value: 'CIE®', label: 'Registered Trade Mark' },
            ].map(s => (
              <div>
                <p class="text-xl sm:text-2xl font-black text-white">{s.value}</p>
                <p class="text-xs text-[#64748B] font-mono uppercase tracking-wide mt-0.5">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: credentials & trusted-by panel -->
        <div class="hidden lg:flex flex-col gap-5">

          <!-- Trusted by block -->
          <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6">
            <p class="text-xs font-mono text-[#E0252E] uppercase tracking-widest mb-4">Trusted By</p>
            <div class="grid grid-cols-2 gap-3">
              {[
                { org: 'PGCIL', desc: 'Power Grid Corporation of India' },
                { org: 'DVC', desc: 'Damodar Valley Corporation' },
                { org: 'WBSETCL', desc: 'West Bengal State Electricity' },
                { org: 'Indian Railways', desc: 'Traction & rolling stock testing' },
                { org: 'NABL Laboratories', desc: 'Calibration & R&D facilities' },
                { org: 'EPC Contractors', desc: 'Substation commissioning across India' },
              ].map(item => (
                <div class="bg-white/5 rounded-lg px-3 py-2.5 border border-white/5">
                  <p class="text-white font-bold text-sm leading-tight">{item.org}</p>
                  <p class="text-[#64748B] text-xs mt-0.5 leading-snug">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Key facts strip -->
          <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6">
            <p class="text-xs font-mono text-[#E0252E] uppercase tracking-widest mb-4">Why CIE</p>
            <ul class="space-y-3">
              {[
                { icon: '🛡️', text: '12-month warranty on every instrument, backed by direct after-sales support' },
                { icon: '🔧', text: 'Custom voltage & measurement ranges manufactured to specification' },
                { icon: '🔬', text: 'Calibrated against reference standards before despatch, with calibration record' },
                { icon: '🇮🇳', text: 'Registered CIE® trade mark — buy direct from the manufacturer' },
              ].map(f => (
                <li class="flex items-start gap-3 text-sm text-[#b0bec5] leading-snug">
                  <span class="shrink-0 mt-0.5">{f.icon}</span>
                  {f.text}
                </li>
              ))}
            </ul>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- PRODUCT CATEGORIES -->
  <section class="bg-[#F5F7FA] py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <EyebrowLabel text="Product Catalogue" class="mb-3" />
        <h2 class="text-3xl font-black text-[#0D2547]">Test &amp; Measurement Instruments</h2>
        <p class="mt-2 text-[#64748B] max-w-2xl">
          Manufactured in Howrah and calibrated against reference standards — every instrument backed by a 12-month warranty.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categoryCount.map(cat => (
          <CategoryCard
            id={cat.id}
            name={cat.name}
            description={cat.description}
            icon={cat.icon}
            count={cat.count}
          />
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href={u('/products')} class="inline-flex items-center gap-2 text-sm font-semibold text-[#1B3A5B] hover:text-[#E0252E] transition-colors">
          Browse full catalogue →
        </a>
      </div>
    </div>
  </section>

  <!-- WHY CIE -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <EyebrowLabel text="Why CIE" class="mb-3" />
        <h2 class="text-3xl font-black text-[#0D2547]">Built for reliability.<br />Backed by six decades.</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {trustPoints.map(tp => (
          <div class="red-stripe">
            <div class="text-2xl mb-3" aria-hidden="true">{tp.icon}</div>
            <h3 class="font-bold text-[#0D2547] mb-2">{tp.label}</h3>
            <p class="text-sm text-[#64748B] leading-relaxed">{tp.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="bg-[#F5F7FA] py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <EyebrowLabel text="Flagship Instruments" class="mb-3" />
        <h2 class="text-3xl font-black text-[#0D2547]">Selected from the CIE Range</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {featured.map(p => (
          <ProductCard
            model={p.model}
            name={p.name}
            tagline={p.tagline}
            categoryId={p.categoryId}
            id={p.id}
            featured={p.featured}
            image={p.image}
            hideImage={p.hideImage}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="blueprint-bg text-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <EyebrowLabel text="Industries Served" class="mb-3" />
        <h2 class="text-3xl font-black">Trusted across India's<br />critical infrastructure.</h2>
        <p class="mt-3 text-[#b0bec5] max-w-xl">
          From grid substations to rolling stock depots — CIE instruments are specified by engineers who need measurements they can stake their signature on.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {industries.map(ind => (
          <div class="bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg p-5 transition-colors">
            <div class="text-2xl mb-3" aria-hidden="true">{ind.icon}</div>
            <h3 class="font-bold text-white mb-1">{ind.name}</h3>
            <p class="text-sm text-[#b0bec5]">{ind.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-8">
        <a href={u('/industries')} class="text-sm font-semibold text-[#E0252E] hover:text-white transition-colors">
          See all applications →
        </a>
      </div>
    </div>
  </section>

  <!-- RTS-33 SPOTLIGHT -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto bg-[#F5F7FA] rounded-xl overflow-hidden border border-[#E8ECF2]">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <div class="p-8 lg:p-10">
            <EyebrowLabel text="Flagship · Protection Testing" class="mb-4" />
            <h2 class="text-2xl font-black text-[#0D2547] mb-3">
              <span class="model-code text-lg block mb-1">RTS-33</span>
              Three-Phase Relay Test Set
            </h2>
            <p class="text-[#64748B] text-sm leading-relaxed mb-6">
              Variable three-phase AC current, AC and DC voltage, and 0–360° continuously variable phase angle.
              250 VA burden. The preferred instrument for commissioning distance, differential, and directional
              protection relays at India's major power utilities and railways.
            </p>
            <ul class="space-y-2 mb-8">
              {['Three-phase output', '250 VA burden', '0–360° phase angle', 'AC & DC voltage', '12-month warranty'].map(f => (
                <li class="flex items-center gap-2 text-sm text-[#1B3A5B]">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#E0252E] shrink-0"></span>
                  {f}
                </li>
              ))}
            </ul>
            <div class="flex gap-3 flex-wrap">
              <a href={u('/products/relay-test-sets/rts-33')} class="px-5 py-2.5 bg-[#1B3A5B] hover:bg-[#0D2547] text-white text-sm font-semibold rounded transition-colors">
                View Specifications
              </a>
              <a href={rts33Mailto} class="px-5 py-2.5 border border-[#E0252E] text-[#E0252E] hover:bg-[#E0252E] hover:text-white text-sm font-semibold rounded transition-colors">
                Request a Quote
              </a>
            </div>
          </div>
          <div class="bg-[#E8ECF2] lg:min-h-full min-h-48 flex items-center justify-center overflow-hidden">
            <img
              src={u('/images/products/rts-33.jpg')}
              alt="RTS-33 — Three-Phase Relay Test Set"
              class="object-contain max-h-64 max-w-full p-4"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABand />

</Base>
