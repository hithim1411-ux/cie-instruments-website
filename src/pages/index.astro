---
import Base from '../layouts/Base.astro';
import { u } from '../utils/url';
import EyebrowLabel from '../components/EyebrowLabel.astro';
import CTABand from '../components/CTABand.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ProductCard from '../components/ProductCard.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';
import clients from '../data/clients.json';
import vartechThermometers from '../data/vartech-thermometers.json';
import vartechLuxMeters from '../data/vartech-lux-meters.json';
import vartechCalibrators from '../data/vartech-calibrators.json';
import vartechDcPowerSupplies from '../data/vartech-dc-power-supplies.json';
import vartechSoundLevelMeters from '../data/vartech-sound-level-meters.json';
import vartechAnemometers from '../data/vartech-anemometers.json';
import vartechOscilloscopes from '../data/vartech-oscilloscopes.json';
import vartechFunctionGenerators from '../data/vartech-function-generators.json';
import vartechLcrMeters from '../data/vartech-lcr-meters.json';
import vartechDcLoads from '../data/vartech-dc-loads.json';

const vartechCounts: Record<string, number> = {
  'vartech-sound-level-meters': (vartechSoundLevelMeters as any[]).length,
  'vartech-anemometers':        (vartechAnemometers as any[]).length,
  'vartech-calibrators':        (vartechCalibrators as any[]).length,
  'vartech-lux-meters':         (vartechLuxMeters as any[]).length,
  'vartech-thermometers':       (vartechThermometers as any[]).length,
  'vartech-dc-power-supplies':  (vartechDcPowerSupplies as any[]).length,
  'vartech-oscilloscopes':      (vartechOscilloscopes as any[]).length,
  'vartech-function-generators':(vartechFunctionGenerators as any[]).length,
  'vartech-lcr-meters':         (vartechLcrMeters as any[]).length,
  'vartech-dc-loads':           (vartechDcLoads as any[]).length,
};

// Remove Vartech categories that duplicate an existing CIE category in the slider.
// "Multimeters" and "Clamp Meters" overlap with CIE's "Clamp Meters & Multimeters".
// Vartech-only categories (oscilloscopes, function generators, LCR meters, DC loads) are kept.
// Vartech multimeters/clamp-meters are excluded because CIE now has separate
// "Clamp Meters" and "Digital Multimeters" categories that already cover those types.
const SLIDER_EXCLUDE = new Set(['vartech-multimeters', 'vartech-clamp-meters']);

const categoryCount = categories
  .filter((cat: any) => !SLIDER_EXCLUDE.has(cat.id))
  .map((cat: any) => ({
    ...cat,
    count: products.filter((p: any) => p.categoryId === cat.id).length || vartechCounts[cat.id] || 0,
  }));

const featured = products.filter(p => p.featured);

const newVartechFeatured = [
  { ...vartechThermometers.find(p => p.id === 'v-6500')!,           slug: 'thermometers'     },
  { ...vartechLuxMeters.find(p => p.id === 'v-6610-b')!,            slug: 'lux-meters'       },
  { ...vartechCalibrators.find(p => p.id === 'ms-7221')!,           slug: 'calibrators'      },
  { ...vartechDcPowerSupplies.find(p => p.id === '3010')!,          slug: 'dc-power-supplies'},
  { ...vartechDcPowerSupplies.find(p => p.id === '3020-sr')!,       slug: 'dc-power-supplies'},
  { ...vartechDcPowerSupplies.find(p => p.id === 'pps-3005-s')!,    slug: 'dc-power-supplies'},
];

const genericMailto = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent('Quote Request — CIE Instruments')}&body=${encodeURIComponent('Hello CIE team,\n\nI would like to request a quote for: [PRODUCT / MODEL].\n\nRequired rated voltage / resistance range:\nQuantity:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.')}`;
const rts33Mailto  = `mailto:cieinstruments@gmail.com?subject=${encodeURIComponent('Quote Request — RTS-33')}&body=${encodeURIComponent('Hello CIE team,\n\nI would like to request a quote for: RTS-33 — Three-Phase Relay Test Set.\n\nRequired rated voltage / resistance range:\nQuantity:\n\nName:\nCompany:\nPhone:\nCity / State:\n\nThank you.')}`;

const trustPoints = [
  { icon: '📅', label: '60+ Years of Service',     body: "Established 1963. Generations of engineers at India's utilities and railways have relied on the CIE® mark." },
  { icon: '🇮🇳', label: 'Made in India',            body: 'Designed and assembled in Howrah, West Bengal, under the registered CIE® trade mark.' },
  { icon: '🛡️', label: '12-Month Warranty',        body: 'Every instrument carries a 12-month warranty against manufacturing defects, with direct after-sales support.' },
  { icon: '🔧', label: 'Custom Ranges to Order',   body: 'Non-standard voltage, resistance, or measurement ranges? We manufacture to your specific requirement.' },
  { icon: '⚡', label: 'Trusted by Power Utilities',body: 'Preferred by PGCIL, WBSETCL, Indian Railways, and EPC contractors across India.' },
  { icon: '🔬', label: 'Calibrated Before Despatch',body: 'Every instrument is calibrated against reference standards before leaving our works.' },
];

const industries = [
  { name: 'Power Utilities',           desc: 'PGCIL, WBSETCL, state electricity boards, generation companies', icon: '⚡' },
  { name: 'Indian Railways',           desc: 'Traction, signalling, and rolling stock testing requirements', icon: '🚂' },
  { name: 'Substation Commissioning',  desc: 'EPC contractors and commissioning engineers', icon: '🏗️' },
  { name: 'Industry & Manufacturing',  desc: 'Motors, cables, panels, transformers in heavy industry', icon: '🏭' },
  { name: 'Test Laboratories',         desc: 'NABL labs, calibration centres, R&D facilities', icon: '🔬' },
  { name: 'EPC Contractors',           desc: 'Project commissioning and acceptance testing', icon: '📋' },
];

---

<Base
  title="Home"
  description="CIE — Cambridge Instruments & Engg. Co., Howrah. Manufacturer and supplier of insulation testers, earth testers, relay test sets, oil BDV testers, clamp meters, HV test sets. Kolkata, West Bengal. Trusted by PGCIL, WBSETCL, Indian Railways since 1963."
  preloadImage={u('/images/products/cie-444.webp')}
  keywords="test and measurement instruments India, electrical test instruments supplier Kolkata, insulation tester manufacturer India, digital multimeters India, oscilloscopes India, clamp meters India, vartech authorised dealer India, cambridge instruments insulation tester, CIE instruments Howrah, megger supplier India"
>
  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="blueprint-bg text-white relative overflow-hidden">
    <!-- Left red accent bar -->
    <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#E0252E]" aria-hidden="true"></div>
    <!-- Top-right glow -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full opacity-10 pointer-events-none"
      style="background: radial-gradient(circle at top right, #E0252E 0%, transparent 65%);" aria-hidden="true">
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- ── Left: copy ── -->
        <div class="max-w-xl">
          <!-- Eyebrow -->
          <div class="inline-flex items-center gap-2 mb-5 px-3 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-[#E0252E] animate-pulse" aria-hidden="true"></span>
            <span class="text-[11px] font-mono text-[#b0bec5] tracking-widest uppercase">CIE® · Instruments for Accuracy and Reliability</span>
          </div>

          <!-- Headline -->
          <h1 class="text-3xl sm:text-4xl lg:text-[2.65rem] xl:text-5xl font-black leading-[1.1] mb-5 text-white">
            <span class="block text-base sm:text-lg lg:text-xl font-semibold text-[#b0bec5] tracking-wide mb-2">Cambridge Instruments &amp; Engg. Co.</span>
            Precision test &amp; measurement instruments,<br class="hidden sm:block" />
            <span class="text-[#E0252E]">built in India</span> since&nbsp;1963.
          </h1>

          <!-- Subhead -->
          <p class="text-base sm:text-lg text-[#b0bec5] mb-8 leading-relaxed">
            Cambridge Instruments &amp; Engg. Co. — manufacturer of insulation testers,
            earth testers, relay test sets, and oil test equipment for India's utilities,
            railways, and industry.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 mb-10">
            <a
              href={u('/products/')}
              class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-[#E0252E] hover:bg-[#D72631] text-white font-bold rounded-lg text-sm transition-all hover:shadow-lg hover:shadow-red-900/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
            >
              Explore Products
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a
              href={genericMailto}
              class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/25 hover:border-white/60 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-lg text-sm transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Request a Quote
            </a>
          </div>

          <!-- Trust row -->
          <div class="flex flex-wrap gap-x-6 gap-y-2 pt-7 border-t border-white/10 text-xs text-[#94a3b8] font-mono uppercase tracking-wide">
            {['60+ Years', 'Made in India', '12-Month Warranty', 'In-House Calibration'].map(t => (
              <span class="flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-[#E0252E]" aria-hidden="true"></span>
                {t}
              </span>
            ))}
          </div>
        </div>

        <!-- ── Right: hero product slider ── -->
        <div class="hidden lg:flex items-center justify-center">
          <div class="relative">
            <!-- Outer glow ring -->
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[#1B3A5B]/60 to-[#E0252E]/10 blur-xl scale-110" aria-hidden="true"></div>
            <!-- Image frame -->
            <div class="relative bg-[#0D2547]/80 border border-white/10 rounded-2xl p-8 backdrop-blur-sm shadow-2xl w-80 xl:w-88">
              <!-- Corner accents -->
              <div class="absolute top-3 left-3 w-5 h-5 border-t-2 border-l-2 border-[#E0252E] rounded-tl" aria-hidden="true"></div>
              <div class="absolute top-3 right-3 w-5 h-5 border-t-2 border-r-2 border-[#E0252E] rounded-tr" aria-hidden="true"></div>
              <div class="absolute bottom-3 left-3 w-5 h-5 border-b-2 border-l-2 border-[#E0252E] rounded-bl" aria-hidden="true"></div>
              <div class="absolute bottom-3 right-3 w-5 h-5 border-b-2 border-r-2 border-[#E0252E] rounded-br" aria-hidden="true"></div>

              <!-- Slides -->
              <div id="hero-slides" class="relative h-64 xl:h-72">
                {[
                  { img: 'cie-444.webp',   model: 'CIE/444',         name: 'Analog Insulation Tester',       href: '/products/insulation-testers-hand/cie-444/' },
                  { img: 'cie-222m.webp',  model: 'CIE/222M',        name: 'Analog Earth Tester',             href: '/products/earth-tester/cie-222m/' },
                  { img: 'det-2000.webp',  model: 'DET-2000',        name: 'Digital Earth Resistance Tester', href: '/products/earth-tester/det-2000/' },
                  { img: 'dit-2500.webp',  model: 'DIT-2500',        name: 'Digital Insulation Tester',       href: '/products/digital-insulation-testers/dit-2500/' },
                  { img: 'dit-5005.webp',  model: 'DIT-5005',        name: 'Digital Insulation Tester',       href: '/products/digital-insulation-testers/dit-5005/' },
                  { img: 'cie-555.webp',   model: 'CIE/555',         name: 'Insulation Tester',               href: '/products/compact-insulation-testers/cie-555/' },
                  { img: 'cie-5050a.webp', model: 'CIE/5050A',       name: 'HV Breakdown Test Set',           href: '/products/hv-phase-sequence/cie-5050a/' },
                  { img: 'cie-7050.webp',  model: 'CIE/7000 Series', name: 'Transformer Oil BDV Tester',      href: '/products/oil-test-sets/cie-7050/' },
                ].map((slide, i) => (
                  <a href={u(slide.href)}
                    class={`hero-slide absolute inset-0 flex flex-col items-center justify-center transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}
                    data-index={i}
                    tabindex={i === 0 ? 0 : -1}
                  >
                    <img
                      src={u(`/images/products/${slide.img}`)}
                      alt={`${slide.model} — ${slide.name}`}
                      width="600"
                      height="600"
                      class="max-h-52 xl:max-h-60 w-auto object-contain mx-auto"
                      loading={i === 0 ? 'eager' : 'lazy'}
                      fetchpriority={i === 0 ? 'high' : 'auto'}
                    />
                  </a>
                ))}
              </div>

              <!-- Caption -->
              <div class="mt-4 text-center min-h-[36px]">
                <p id="hero-model" class="text-xs font-mono text-[#E0252E] uppercase tracking-widest">CIE/444</p>
                <p id="hero-name"  class="text-white text-sm font-semibold mt-0.5">Analog Insulation Tester</p>
              </div>

              <!-- Dot indicators (aria-hidden: purely decorative, tabindex=-1 keeps them unfocusable) -->
              <div class="flex justify-center gap-1.5 mt-4" aria-hidden="true">
                {[0,1,2,3,4,5,6,7].map(i => (
                  <button data-hero-dot={i}
                    tabindex="-1"
                    class={`hero-dot transition-all rounded-full ${i === 0 ? 'w-4 h-1.5 bg-[#E0252E]' : 'w-1.5 h-1.5 bg-white/20'}`}
                  />
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PRODUCT CATEGORIES (horizontal slider) ───────────────────────────── -->
  <section class="bg-[#F5F7FA] py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8 gap-4">
        <div>
          <EyebrowLabel text="Product Catalogue" class="mb-3" />
          <h2 class="text-3xl font-black text-[#0D2547]">Test &amp; Measurement Instruments</h2>
          <p class="mt-2 text-[#64748B] max-w-2xl">
            CIE manufactured instruments from Howrah, plus the full Vartech range — backed by direct after-sales support.
          </p>
        </div>
        <!-- Slider arrows -->
        <div class="hidden sm:flex items-center gap-2 shrink-0">
          <button id="cat-prev" aria-label="Previous categories"
            class="w-9 h-9 rounded-full border border-[#E8ECF2] bg-white hover:border-[#1B3A5B] hover:bg-[#1B3A5B] hover:text-white text-[#1B3A5B] transition-all flex items-center justify-center disabled:opacity-30 disabled:pointer-events-none">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="cat-next" aria-label="Next categories"
            class="w-9 h-9 rounded-full border border-[#E8ECF2] bg-white hover:border-[#1B3A5B] hover:bg-[#1B3A5B] hover:text-white text-[#1B3A5B] transition-all flex items-center justify-center disabled:opacity-30 disabled:pointer-events-none">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <!-- Scrollable track -->
      <div id="cat-track"
        class="flex gap-4 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-3 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8"
        style="scrollbar-width:none; -ms-overflow-style:none;">
        {categoryCount.map(cat => (
          <a href={u((cat as any).brand === 'vartech' ? `/authorised-dealership/${cat.id.replace('vartech-', '')}/` : `/products/${cat.id}/`)}
            class="group snap-start shrink-0 w-[260px] sm:w-[280px] bg-white rounded-lg border border-[#E8ECF2] p-5 hover:shadow-md hover:border-[#1B3A5B]/30 transition-all duration-200 flex flex-col">
            <div class="flex items-start gap-3 mb-3">
              <div class="shrink-0 w-10 h-10 bg-[#F5F7FA] rounded-lg flex items-center justify-center text-xl group-hover:bg-[#1B3A5B]/5 transition-colors">
                {cat.icon}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-bold text-[#0D2547] text-sm leading-snug group-hover:text-[#1B3A5B] transition-colors line-clamp-2">{cat.name}</h3>
                <span class="text-xs font-mono text-[#64748B]">{cat.count} {cat.count === 1 ? 'product' : 'products'}</span>
              </div>
            </div>
            <p class="text-xs text-[#64748B] leading-relaxed line-clamp-3 flex-1">{cat.description}</p>
            <div class="mt-3 pt-3 border-t border-[#F0F2F5] text-xs font-semibold text-[#E0252E] group-hover:translate-x-1 transition-transform duration-200">View products →</div>
          </a>
        ))}
      </div>

      <!-- Dot indicators (aria-hidden: decorative, tabindex=-1 keeps them non-focusable) -->
      <div id="cat-dots" class="flex justify-center gap-1.5 mt-5" aria-hidden="true">
        {categoryCount.map((_, i) => (
          <button data-dot={i}
            tabindex="-1"
            class={`cat-dot w-1.5 h-1.5 rounded-full transition-all ${i === 0 ? 'bg-[#1B3A5B] w-4' : 'bg-[#CBD5E1]'}`}></button>
        ))}
      </div>

      <div class="mt-6 text-center">
        <a href={u('/products/')} class="inline-flex items-center gap-2 text-sm font-semibold text-[#1B3A5B] hover:text-[#E0252E] transition-colors">
          Browse full catalogue →
        </a>
      </div>
    </div>
  </section>

  <script>
  {
    const track = document.getElementById('cat-track');
    const dots  = document.querySelectorAll<HTMLButtonElement>('.cat-dot');
    const prev  = document.getElementById('cat-prev') as HTMLButtonElement | null;
    const next  = document.getElementById('cat-next') as HTMLButtonElement | null;
    if (track) {
      let cachedSlideW = 296;
      const updateSlideW = () => {
        const first = track.querySelector('a');
        if (first) cachedSlideW = first.offsetWidth + 16;
      };
      // Defer initial measurement out of the critical layout path
      requestAnimationFrame(updateSlideW);
      new ResizeObserver(updateSlideW).observe(track);
      const slideW = () => cachedSlideW;
      const scroll = (dir: number) => {
        track.scrollBy({ left: dir * slideW() * 3, behavior: 'smooth' });
      };
      prev?.addEventListener('click', () => scroll(-1));
      next?.addEventListener('click', () => scroll(1));
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          track.scrollTo({ left: i * slideW(), behavior: 'smooth' });
        });
      });
      track.addEventListener('scroll', () => {
        const idx = Math.round(track.scrollLeft / slideW());
        dots.forEach((d, i) => {
          d.classList.toggle('bg-[#1B3A5B]', i === idx);
          d.classList.toggle('!w-4', i === idx);
          d.classList.toggle('bg-[#CBD5E1]', i !== idx);
        });
      }, { passive: true });
    }
  }
  </script>

  <!-- ── WHY CIE ────────────────────────────────────────────────────────────── -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <EyebrowLabel text="Why CIE" class="mb-3" />
        <h2 class="text-3xl font-black text-[#0D2547]">Built for reliability.<br />Backed by six decades.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {trustPoints.map(tp => (
          <div class="red-stripe">
            <div class="text-2xl mb-3" aria-hidden="true">{tp.icon}</div>
            <h3 class="font-bold text-[#0D2547] mb-2">{tp.label}</h3>
            <p class="text-sm text-[#64748B] leading-relaxed">{tp.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FEATURED PRODUCTS ─────────────────────────────────────────────────── -->
  <section class="bg-[#F5F7FA] py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10 gap-4">
        <div>
          <EyebrowLabel text="Flagship Instruments" class="mb-3" />
          <h2 class="text-3xl font-black text-[#0D2547]">Selected from Our Range</h2>
        </div>
        <div class="hidden sm:flex items-center gap-2 shrink-0">
          <button id="feat-prev" aria-label="Previous products"
            class="w-9 h-9 rounded-full border border-[#E8ECF2] bg-white hover:border-[#1B3A5B] hover:bg-[#1B3A5B] hover:text-white text-[#1B3A5B] transition-all flex items-center justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="feat-next" aria-label="Next products"
            class="w-9 h-9 rounded-full border border-[#E8ECF2] bg-white hover:border-[#1B3A5B] hover:bg-[#1B3A5B] hover:text-white text-[#1B3A5B] transition-all flex items-center justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
      <div id="feat-track" class="product-slider product-slider--desktop-scroll gap-6 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
        {featured.map(p => (
          <ProductCard model={p.model} name={p.name} tagline={p.tagline} categoryId={p.categoryId}
            id={p.id} featured={p.featured} image={p.image} hideImage={p.hideImage} />
        ))}
        {newVartechFeatured.map(p => (
          <article class="bg-white rounded-lg border border-[#E8ECF2] overflow-hidden flex flex-col hover:shadow-md transition-shadow duration-200">
            <div class="bg-[#F5F7FA] border-b border-[#E8ECF2] h-[180px] flex items-center justify-center relative">
              <img
                src={u(`/images/vartech/${p.slug}/${p.images[0]}`)}
                alt={`Vartech ${p.model} — ${p.name}`}
                width="300" height="300"
                class="object-contain h-32 w-auto"
                loading="lazy"
                onerror="this.style.display='none'"
              />
              <span class="absolute top-2 left-2 text-[9px] font-mono font-bold uppercase tracking-widest text-emerald-700 bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 rounded">
                Vartech®
              </span>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <p class="text-[11px] font-mono text-[#E0252E] mb-0.5">{p.model}</p>
              <h3 class="font-bold text-[#0D2547] text-sm leading-snug mb-2">{p.name}</h3>
