<script>
{
  const slides  = document.querySelectorAll<HTMLElement>('.hero-slide');
  const dots    = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
  const modelEl = document.getElementById('hero-model');
  const nameEl  = document.getElementById('hero-name');

  const data = [
    { model: 'CIE/444',         name: 'Analog Insulation Tester'       },
    { model: 'CIE/222M',        name: 'Analog Earth Tester'             },
    { model: 'DET-2000',        name: 'Digital Earth Resistance Tester' },
    { model: 'DIT-2500',        name: 'Digital Insulation Tester'       },
    { model: 'DIT-5005',        name: 'Digital Insulation Tester'       },
    { model: 'CIE/555',         name: 'Insulation Tester'               },
    { model: 'CIE/5050A',       name: 'HV Breakdown Test Set'           },
    { model: 'CIE/7000 Series', name: 'Transformer Oil BDV Tester'      },
  ];

  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(idx: number) {
    slides[current].classList.replace('opacity-100','opacity-0');
    slides[current].classList.add('pointer-events-none');
    (slides[current] as HTMLAnchorElement).tabIndex = -1;
    dots[current].className = 'hero-dot transition-all rounded-full w-1.5 h-1.5 bg-white/20';

    current = idx;

    slides[current].classList.replace('opacity-0','opacity-100');
    slides[current].classList.remove('pointer-events-none');
    (slides[current] as HTMLAnchorElement).tabIndex = 0;
    dots[current].className = 'hero-dot transition-all rounded-full w-4 h-1.5 bg-[#E0252E]';

    if (modelEl) modelEl.textContent = data[current].model;
    if (nameEl)  nameEl.textContent  = data[current].name;
  }

  function startTimer() { timer = setInterval(() => goTo((current + 1) % slides.length), 3000); }
  function resetTimer()  { clearInterval(timer); startTimer(); }

  dots.forEach(dot => {
    dot.addEventListener('click', () => { goTo(Number(dot.dataset.heroDot)); resetTimer(); });
  });

  if (slides.length > 1) startTimer();
}
</script>
